				Заказ.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				// сделать запись в журнал
			КонецПопытки 
		КонецЕсли;
	Исключение	
				// сделать запись в журнал   
	КонецПопытки;
	КонецПроцедуры   
	
