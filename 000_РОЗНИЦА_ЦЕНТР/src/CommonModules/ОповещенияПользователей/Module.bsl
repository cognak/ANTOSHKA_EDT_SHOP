		МассивКому = Новый Массив;
		
		СтруктураКому = Новый Структура;
		СтруктураКому.Вставить("Адрес"        , Выборка.ИдентификаторПользователя); 
		СтруктураКому.Вставить("Представление", Выборка.НаименованиеПолучателя);
		
		МассивКому.Добавить(СтруктураКому);
		
		//Копии - добавив в основной массив
		МассивКопии = Новый Массив();
		СписокКопий = Выборка.Копия.Получить();
		                                                                                
		Если СписокКопий <> Неопределено И СписокКопий.Количество() Тогда
			
			Для Каждого Копия ИЗ СписокКопий Цикл
				
				СтруктураКопии = ПолучитьСтруктуруПолучателяЭлектроннойПочты(Копия, ВидКИ);
				
				Если НЕ ПустаяСтрока(СтруктураКопии.Адрес) Тогда
					МассивКопии.Добавить(СтруктураКопии);	
				КонецЕсли;
				
			КонецЦикла;	
			
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивКому, МассивКопии, Истина);
			
		КонецЕсли;		
		
		ПараметрыМессенджер.Вставить("Кому", 			МассивКому);
		ПараметрыМессенджер.Вставить("ТекстСообщения", 	Выборка.Текст);
		ПараметрыМессенджер.Вставить("Бот",  			Выборка.Бот);
		ПараметрыМессенджер.Вставить("ПараметрыПодключения", ПолучитьПараметрыПодключения(Выборка.Бот));
		
		ДанныеВозврат.Добавить(ПараметрыМессенджер);
		
	КонецЦикла;
	
	Возврат ДанныеВозврат;
	
КонецФункции // ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram()	

Функция ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram_Произвольные(Получатель, Бот, ТекстСообщения)

	ДанныеВозврат = Новый Массив;
	ПараметрыМессенджер = Новый Структура;
		
	//Кому
	МассивКому = Новый Массив;
	
	Если ТипЗнч(Получатель) = Тип("СправочникСсылка.Пользователи") Тогда
		
		ИдентификаторТГ = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Получатель, Справочники.ВидыКонтактнойИнформации.TelegramПользователя);
		
		СтруктураКому = Новый Структура;
		СтруктураКому.Вставить("Адрес"        , ИдентификаторТГ); 
		СтруктураКому.Вставить("Представление", СокрЛП(Получатель));
		
		МассивКому.Добавить(СтруктураКому);	
		
	КонецЕсли;	
		
	ПараметрыМессенджер.Вставить("Кому", 			МассивКому);
	ПараметрыМессенджер.Вставить("ТекстСообщения", 	ТекстСообщения);
	ПараметрыМессенджер.Вставить("Бот",  			Бот);
	ПараметрыМессенджер.Вставить("ПараметрыПодключения", ПолучитьПараметрыПодключения(Бот));
			
	ДанныеВозврат.Добавить(ПараметрыМессенджер);
	
	Возврат ДанныеВозврат;
	
КонецФункции // ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram_Произвольные()

Функция ОтправитьСообщениеЧерезМессенджер_Telegram(ПараметрыМессенджер)
	
	// тут копія вхідних параметрів, яку ми повернемо разом із результатами по кожній відправці сповіщення
	ПараметрыВозврат = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыМессенджер);
	ПараметрыВозврат.Вставить("Результаты", Новый Массив()); // вернем результаты отправки
	
	ПолучателиСообщения = ПараметрыВозврат.Кому;
	Для Каждого Получатель ИЗ ПолучателиСообщения Цикл
		
		ПараметрыПодключенияСервер = ПараметрыВозврат.ПараметрыПодключения;
	
		// запит
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("chat_id",  	Получатель.Адрес);
		ПараметрыЗапроса.Вставить("text",		ПараметрыВозврат.ТекстСообщения);
		
		ОтветСервера = Новый Соответствие();
		ОтветОк = ОправитьЗапросНаСерверТелеграм("sendMessage", ПараметрыПодключенияСервер, ПараметрыЗапроса, ОтветСервера);
	
		// результат отправки по каждому ИД
		ПараметрыВозврат.Результаты.Добавить(Новый Структура("Адрес, КодОтвета, ОтветДетально", 
														Получатель.Адрес, 
														ОтветОк, 
														ОтветСервера)
														);

	КонецЦикла;	
	  
    Возврат ПараметрыВозврат;
	
КонецФункции // ОтправитьСообщениеЧерезМессенджер_Telegram()


Функция ПолучитьПараметрыПодключения(Бот)
	
	НастойкиСтрокой = "АдресСервера, Порт, Таймаут, Токен";	
	
	Если Не ЗначениеЗаполнено(Бот) Тогда
		Возврат Новый Структура(НастойкиСтрокой);
	КонецЕсли;	
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Бот, НастойкиСтрокой);
	
КонецФункции	

#КонецОбласти


Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено) 
	Возврат ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
