////////////////////////////////////////////////////////////////////////////////
//  Содержит общие серверные процедуры предназначенные для настройки, а также 
//  формирования сообщений по оповещениям пользователей.
//

#Область ПрограммныйИнтерфейс

// (Устаревшее) Выполняет оповещение пользователей
//
// Параметры:
//  Событие			 - ПеречислениеСсылка.ТипыСобытийОповещений - предопределенное событие оповещения 
//  СсылкаНаОбъект	 - ДокументСсылка - ссылка на объект, по которому проводим оповещение
//  ТелоСообщения	 - Строка	 - текст оповещения
//  ТипТекста		 - Строка	 - тип текста оповещения
//
Процедура ВыполнитьОповещение(Событие, СсылкаНаОбъект = Неопределено, ТелоСообщения = "", ТипТекста = "") Экспорт

	ВыполнитьОповещениеПоЭлектроннойПочте(Событие, СсылкаНаОбъект, ТелоСообщения, ТипТекста);
		
КонецПроцедуры

// (Устаревшее). Отправляет произвольное электронное письмо пользователю через системную учетную запись
//
// Параметры:
//   Получатель - Строка - адрес электронной почты или идентификатор получателя
//   Тема - Строка - тема письма
//   Текст - Строка - текст сообщения
//   Копии - Строка - адреса получателей копии через запятую
//   СкрытыеКопии - Строка - адреса получателей скрытой копии через запятую
// 	 Вложения - Соответствие - вложения письма:
//                Ключ - наименованиеВложения - Строка - наименование вложения
//                Значение - ДвоичныеДанные - данные вложения
Процедура ВыполнитьПроизвольноеОповещение(Получатель, Тема = "", Текст = "", Копии = Неопределено, СкрытыеКопии = Неопределено, Вложения = Неопределено) Экспорт

	УчетнаяЗаписьДляОтправки = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
	
	ПараметрыПисьма = ПолучитьПараметрыЭлектроннаяПочтаПроизвольные(Получатель, Тема, Текст, Копии, СкрытыеКопии, Вложения);
	
	РаботаСПочтовымиСообщениями.ОтправитьСообщение(УчетнаяЗаписьДляОтправки, ПараметрыПисьма);
	
КонецПроцедуры

// Возвращает пустую структуру настроек оповещения
//
// Возвращаемое значение:
//   Структура:
//     * СпособОповещения - Произвольный - способ оповещения
//     * ТипТекста - Строка - тип текста сообщения
//     * ТелоСообщения - Строка - текст сообщения
//     * ЗаголовокСообщения - Строка - заголовок сообщения
//     * Копии - Произвольный - получатели копий
//     * СкрытыеКопии - Произвольный - получатели скрытых копий
//     * Мессенджер - Строка - идентификатор мессенджера
//     * Бот - Произвольный - бот для отправки
Функция ПолучитьСтруктуруНастроекОповещения() Экспорт
	
	Настройки = Новый Структура();
	Настройки.Вставить("СпособОповещения", 	 Неопределено);
	Настройки.Вставить("ТипТекста", 		 "");
	Настройки.Вставить("ТелоСообщения", 	 "");
	Настройки.Вставить("ЗаголовокСообщения", "");
	Настройки.Вставить("Копии", 			 Неопределено);
	Настройки.Вставить("СкрытыеКопии", 		 Неопределено);
	Настройки.Вставить("Мессенджер", 	 	 "telegram");
	Настройки.Вставить("Бот", 	 	 		 Неопределено);
		
	Возврат Настройки;	
	
КонецФункции

// Выполняет оповещение пользователей
//
// Параметры:
//  Событие			 - ПеречислениеСсылка.ТипыСобытийОповещений - предопределенное событие оповещения 
//  НастройкиОповещения - Структура - данные для выполнения оповещения
//  СсылкаНаОбъект	 - ДокументСсылка - ссылка на объект, по которому проводим оповещение
//
Процедура ВыполнитьОповещениеПользователей(Событие, НастройкиОповещения, СсылкаНаОбъект = Неопределено) Экспорт

	СпособОповещенияПользователя 	= СвойствоСтруктуры(НастройкиОповещения, "СпособОповещения");
	ТелоСообщения 					= СвойствоСтруктуры(НастройкиОповещения, "ТелоСообщения", "");
	ДокументИсточник				= ?(ЗначениеЗаполнено(СсылкаНаОбъект), СсылкаНаОбъект, Неопределено);
	
	Если СпособОповещенияПользователя = Неопределено ИЛИ СпособОповещенияПользователя = Перечисления.СпособыОповещения.Email Тогда
		
		ТипТекста = СвойствоСтруктуры(НастройкиОповещения, "ТипТекста", "");
		
		ВыполнитьОповещениеПоЭлектроннойПочте(Событие, ДокументИсточник, ТелоСообщения, ТипТекста);
		
	КонецЕсли;

	Если СпособОповещенияПользователя = Неопределено ИЛИ СпособОповещенияПользователя = Перечисления.СпособыОповещения.Telegram Тогда
		
		Мессенджер = "Telegram";
		
		ВыполнитьОповещениеПоМессенджеру(Событие, ДокументИсточник, Мессенджер, ТелоСообщения);
		
	КонецЕсли;	
		
КонецПроцедуры

// Выполняет произвольное оповещение пользователей
//
// Параметры:
//  Получатель	 - СправочникСсылка.Пользователи - ссылка на пользователя, которому отправляем оповещение
//  НастройкиОповещения - Структура - данные для выполнения оповещения
//
Процедура ВыполнитьПроизвольноеОповещениеПользователей(Получатель, НастройкиОповещения) Экспорт

	СпособОповещенияПользователя 	= СвойствоСтруктуры(НастройкиОповещения, "СпособОповещения");
	ТелоСообщения 					= СвойствоСтруктуры(НастройкиОповещения, "ТелоСообщения", "");
	ЗаголовокСообщения				= СвойствоСтруктуры(НастройкиОповещения, "ЗаголовокСообщения", "");
	Копии							= СвойствоСтруктуры(НастройкиОповещения, "Копии");
	СкрытыеКопии					= СвойствоСтруктуры(НастройкиОповещения, "СкрытыеКопии");
	Бот								= СвойствоСтруктуры(НастройкиОповещения, "Бот");
		
	// має бути визначено конкретний спосіб сповіщення
	Если СпособОповещенияПользователя = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если ПустаяСтрока(ТелоСообщения) Тогда
		Возврат;
	КонецЕсли;	
	
	Если СпособОповещенияПользователя = Перечисления.СпособыОповещения.Email Тогда
		
		ВыполнитьОповещениеПоЭлектроннойПочтеПроизвольное(Получатель, ЗаголовокСообщения, ТелоСообщения, Копии, СкрытыеКопии);
		
	ИначеЕсли СпособОповещенияПользователя = Перечисления.СпособыОповещения.Telegram Тогда
		
		ВыполнитьОповещениеПоМессенджеруПроизвольное(Получатель, Бот, "Telegram", ТелоСообщения);
		
	КонецЕсли;
		
КонецПроцедуры	

// Отправляет уведомление по электронной почте на основе указанного события. 
// Тело письма формируется подстановкой номера и даты объекта при наличии ссылки.
//
// Параметры:
//   Событие - Строка - идентификатор события, по которому выполняется отправка уведомления
//   СсылкаНаОбъект - ЛюбаяСсылка - ссылка на объект, номер и дата которого подставляются в тело письма
//   ТелоСообщения - Строка - текст сообщения, который заменяет стандартное тело письма
//   ТипТекста - Строка - тип текста сообщения (например, "HTML", "Plain")
Процедура ВыполнитьОповещениеПоЭлектроннойПочте(Событие, СсылкаНаОбъект = Неопределено, ТелоСообщения = "", ТипТекста = "") Экспорт

	УчетнаяЗаписьДляОтправки = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
	ПараметрыПисем = ПолучитьПараметрыЭлектроннаяПочта(Событие); 
	
	Для Каждого ПараметрыПисьма ИЗ ПараметрыПисем Цикл 
		
		Если СсылкаНаОбъект <> Неопределено Тогда
			
			ПараметрыПисьма.Тело = СтрЗаменить(ПараметрыПисьма.Тело, "[Номер]", СсылкаНаОбъект.Номер);
			ПараметрыПисьма.Тело = СтрЗаменить(ПараметрыПисьма.Тело, "[Дата]" , Формат(СсылкаНаОбъект.Дата, "ДФ=dd.MM.yyyy"));	
			
		КонецЕсли;		
		
		Если НЕ ПустаяСтрока(ТелоСообщения) Тогда	
			ПараметрыПисьма.Тело = ТелоСообщения;	
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ТипТекста) Тогда
			ПараметрыПисьма.Вставить("ТипТекста", ТипТекста);
		КонецЕсли;	
		
		РаботаСПочтовымиСообщениями.ОтправитьСообщение(УчетнаяЗаписьДляОтправки, ПараметрыПисьма);
		
	КонецЦикла;
	
КонецПроцедуры

// Отправляет электронное письмо с произвольным содержимым через системную учетную запись почты.
//
// Параметры:
//  Получатель - Строка - адрес электронной почты получателя
//  ТемаСообщения - Строка - тема письма
//  ТелоСообщения - Строка - текст письма
//  Копии - Строка, Массив из Строка - адреса копий через запятую или массив адресов
//  СкрытыеКопии - Строка, Массив из Строка - адреса скрытых копий через запятую или массив адресов
//  Вложения - Соответствие - вложения письма:
//                Ключ - наименованиеВложения - Строка - наименование вложения
//                Значение - ДвоичныеДанные - данные вложения
Функция ВыполнитьОповещениеПоЭлектроннойПочтеПроизвольное(Получатель, ТемаСообщения, ТелоСообщения, Копии = Неопределено, СкрытыеКопии = Неопределено, Вложения = Неопределено) Экспорт

	УчетнаяЗаписьДляОтправки = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
	ПараметрыПисьма = ПолучитьПараметрыЭлектроннаяПочтаПроизвольные(Получатель, ТемаСообщения, ТелоСообщения, Копии, СкрытыеКопии, Вложения); 
	
	Возврат РаботаСПочтовымиСообщениями.ОтправитьСообщение(УчетнаяЗаписьДляОтправки, ПараметрыПисьма);
	
КонецФункции

// Выполняет оповещение пользователя через указанный мессенджер.
//
// Параметры:
//   Событие - Структура - параметры события для оповещения
//   СсылкаНаОбъект - ЛюбаяСсылка - ссылка на объект, с которым связано событие
//   Мессенджер - Строка - идентификатор мессенджера. По умолчанию: "telegram"
//   ТелоСообщения - Строка - текст сообщения для отправки
Процедура ВыполнитьОповещениеПоМессенджеру(Событие, СсылкаНаОбъект, Мессенджер, ТелоСообщения) Экспорт

	Если НРег(Мессенджер) = "telegram" Тогда
		ВыполнитьОповещениеПоМессенджеру_Telegram(Событие, СсылкаНаОбъект, ТелоСообщения);	
	КонецЕсли;	
	
КонецПроцедуры

// Отправляет оповещение через мессенджер Telegram по указанному событию. Для каждой настройки
// отправки выполняет подстановку параметров из объекта в шаблон сообщения и отправляет результат.
//
// Параметры:
//   Событие - см. ОповещенияПользователей.ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram
//   СсылкаНаОбъект - ЛюбаяСсылка, Неопределено - объект, данные которого подставляются в шаблон.
//                   В шаблоне поддерживаются подстановки: [Номер] - номер объекта, [Дата] - дата объекта
//   ТелоСообщения - Строка - текст сообщения, если передан, то имеет приоритет над шаблоном настроек
Процедура ВыполнитьОповещениеПоМессенджеру_Telegram(Событие, СсылкаНаОбъект, ТелоСообщения) Экспорт

	МассивНастроек = ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram(Событие); 
	
	Для Каждого ДанныеОтправки ИЗ МассивНастроек Цикл 
		
		Если СсылкаНаОбъект <> Неопределено Тогда
			
			ДанныеОтправки.ТекстСообщения = СтрЗаменить(ДанныеОтправки.ТекстСообщения, "[Номер]", СсылкаНаОбъект.Номер);
			ДанныеОтправки.ТекстСообщения = СтрЗаменить(ДанныеОтправки.ТекстСообщения, "[Дата]" , Формат(СсылкаНаОбъект.Дата, "ДФ=dd.MM.yyyy"));	
			
		КонецЕсли;		
		
		Если НЕ ПустаяСтрока(ТелоСообщения) Тогда	
			ДанныеОтправки.ТекстСообщения = ТелоСообщения; 	
		КонецЕсли;
		
		ОтправитьСообщениеЧерезМессенджер_Telegram(ДанныеОтправки);
		
	КонецЦикла;
	
КонецПроцедуры

// Отправляет произвольное оповещение пользователю в указанный мессенджер.
//
// Параметры:
//   Получатель - Строка - идентификатор получателя в мессенджере
//   Бот - Строка - токен или идентификатор бота для отправки сообщений
//   Мессенджер - Строка - тип мессенджера. По умолчанию "telegram"
//   ТелоСообщения - Строка - текст отправляемого сообщения
Процедура ВыполнитьОповещениеПоМессенджеруПроизвольное(Получатель, Бот, Мессенджер="telegram", ТелоСообщения) Экспорт

	Если НРег(Мессенджер) = "telegram" Тогда
		ВыполнитьОповещениеПоМессенджеру_Telegram_Произвольное(Получатель, Бот, ТелоСообщения);	
	КонецЕсли;	
	
КонецПроцедуры

// Отправляет произвольное оповещение указанному получателю через мессенджер Telegram
//
// Параметры:
//   Получатель - Строка - идентификатор получателя сообщения
//   Бот - Строка - идентификатор бота Telegram
//   ТелоСообщения - Строка - текст сообщения для отправки
Процедура ВыполнитьОповещениеПоМессенджеру_Telegram_Произвольное(Получатель, Бот, ТелоСообщения) Экспорт

	МассивНастроек = ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram_Произвольные(Получатель, Бот, ТелоСообщения); 
	
	// 1 елемент в масиві завжди
	Если МассивНастроек.Количество() Тогда
		ОтправитьСообщениеЧерезМессенджер_Telegram(МассивНастроек[0]);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает ссылку на профиль пользователя в мессенджере Telegram по идентификатору пользователя
//
// Параметры:
//   Пользователь - СправочникСсылка.Пользователи, Строка - ссылка на пользователя или идентификатор пользователя в мессенджере
//   Бот         - СправочникСсылка.НастройкиБотов - настройки бота для выполнения запроса к API мессенджера
//   Мессенджер  - Строка - код мессенджера
// 
// Возвращаемое значение:
//   Строка - ссылка на профиль пользователя в формате "https://t.me/username", или пустая строка - если ссылку не удалось получить
Функция ПолучитьСсылкуНаПрофильПользователя(Пользователь, Бот, Мессенджер="telegram") Экспорт

	СтрокаРезультат = "";
	
	Если НЕ НРег(Мессенджер)="telegram" Тогда
		Возврат СтрокаРезультат;
	КонецЕсли;	
	
	Если ТипЗнч(Пользователь) = Тип("СправочникСсылка.Пользователи") Тогда
		ИдентификаторПользователя = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Пользователь, Справочники.ВидыКонтактнойИнформации.TelegramПользователя);
	Иначе
		ИдентификаторПользователя = Пользователь;
	КонецЕсли;	

	Если ПустаяСтрока(ИдентификаторПользователя) Тогда
		Возврат СтрокаРезультат;
	КонецЕсли;	
	
	ПараметрыПодключенияБот = ПолучитьПараметрыПодключения(Бот);
	
	// запит
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("chat_id", ИдентификаторПользователя);
	
	ОтветСервера = Новый Соответствие();
	ОтветОк = ОправитьЗапросНаСерверТелеграм("getChat", ПараметрыПодключенияБот, ПараметрыЗапроса, ОтветСервера);

	Если ОтветОк Тогда
		ПровильПользователя = ОтветСервера.Получить("username");
		Если Не ПустаяСтрока(ПровильПользователя) Тогда
			СтрокаРезультат = "https://t.me/" + ПровильПользователя;
		КонецЕсли;
	КонецЕсли;	

	Возврат СтрокаРезультат;

КонецФункции

// Отправляет запрос на сервер Telegram и проверяет успешность соединения.
//
// Параметры:
//   Метод - Строка - имя метода API Telegram
//   НастройкиПодключения - Структура:
//     * АдресСервера - Строка
//     * Токен - Строка
//   ДанныеЗапроса - Структура - данные для отправки
//   ОтветСервера - Соответствие - заполняется при успешном соединении
//   ТекстСообщения - Строка - заполняется текстом сообщения о результате операции
//
// Возвращаемое значение:
//   Булево - Истина при успешном выполнении запроса
Функция ОправитьЗапросНаСерверТелеграм(Метод, НастройкиПодключения, ДанныеЗапроса, ОтветСервера = Неопределено, ТекстСообщения = "") Экспорт   

	Если ОтветСервера = Неопределено Тогда
		ОтветСервера = Новый Соответствие();
	КонецЕсли;
	
	СтрокаПодключения = НастройкиПодключения.АдресСервера
		+ "/bot"
		+ НастройкиПодключения.Токен
		+ "/" + СокрЛП(Метод); 

	Результат = КоннекторHTTP.PostJson(СтрокаПодключения, ДанныеЗапроса);
	
	ОтветОк = Результат.Получить("ok") = Истина;
	Если ОтветОк Тогда
		
		ТекстСообщения = НСтр("ru='Соединение с сервером успешно установлено.';uk='З''єднання з сервером успішно встановлено.'");
		ОтветСервера = Результат.Получить("result");
	
	Иначе
		
		ТекстСообщения = НСтр("ru='Не удалось установить соединение.';uk='Не вдалося встановити з''єднання.'");
		ОтветСервера = Результат.Получить("description");
		
	КонецЕсли;

	Возврат ОтветОк;

КонецФункции

#КонецОбласти

