Функция ПолучитьНастройкиОтправкиЧерезМессенджер_Telegram(Событие)
	
	ДанныеВозврат = Новый Массив;
	ВидКИ = Справочники.ВидыКонтактнойИнформации.TelegramПользователя;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОповещенияПользователей.Пользователь.Наименование КАК НаименованиеПолучателя,
	|	ЕСТЬNULL(ПользователиКонтактнаяИнформация.Представление, """") КАК ИдентификаторПользователя,
	|	ОповещенияПользователей.Текст КАК Текст,
	|	ОповещенияПользователей.Копия КАК Копия,
	|	ОповещенияПользователей.Бот КАК Бот,
	|	ОповещенияПользователей.Бот.Токен КАК Токен,
	|	ОповещенияПользователей.Пользователь КАК Пользователь
	|ИЗ
	|	РегистрСведений.ОповещенияПользователей КАК ОповещенияПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|		ПО ОповещенияПользователей.Пользователь = ПользователиКонтактнаяИнформация.Ссылка
	|		И ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.TelegramПользователя)
	|ГДЕ
	|	ОповещенияПользователей.Событие = &Событие
	|	И ОповещенияПользователей.СпособОповещения = ЗНАЧЕНИЕ(Перечисление.СпособыОповещения.Telegram)
	|	И ОповещенияПользователей.Активно
	|	И ТИПЗНАЧЕНИЯ(ОповещенияПользователей.Пользователь) = ТИП(Справочник.Пользователи)
	|	И НЕ ПользователиКонтактнаяИнформация.Ссылка.Недействителен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ГруппыПользователейСостав.Пользователь.Наименование,
	|	ЕСТЬNULL(ПользователиКонтактнаяИнформация.Представление, """"),
	|	ОповещенияПользователей.Текст,
	|	ОповещенияПользователей.Копия,
	|	ОповещенияПользователей.Бот,
	|	ОповещенияПользователей.Бот.Токен,
	|	ГруппыПользователейСостав.Пользователь КАК Пользовател
	|ИЗ
	|	РегистрСведений.ОповещенияПользователей КАК ОповещенияПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|			ПО ГруппыПользователейСостав.Пользователь = ПользователиКонтактнаяИнформация.Ссылка
	|			И ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.TelegramПользователя)
	|		ПО ОповещенияПользователей.Пользователь = ГруппыПользователейСостав.Ссылка
	|ГДЕ
	|	ОповещенияПользователей.Событие = &Событие
	|	И ОповещенияПользователей.СпособОповещения = ЗНАЧЕНИЕ(Перечисление.СпособыОповещения.Telegram)
	|	И ОповещенияПользователей.Активно
	|	И ТИПЗНАЧЕНИЯ(ОповещенияПользователей.Пользователь) = ТИП(Справочник.ГруппыПользователей)
	|	И НЕ ПользователиКонтактнаяИнформация.Ссылка.Недействителен";
	
	Запрос.УстановитьПараметр("Событие", Событие);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ПустаяСтрока(Выборка.ИдентификаторПользователя) Тогда
			Продолжить;
		КонецЕсли;	
		
