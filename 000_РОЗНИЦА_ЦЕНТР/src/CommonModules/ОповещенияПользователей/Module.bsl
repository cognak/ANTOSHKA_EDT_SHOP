#Область СлужебныеФункции_ЭлектроннаяПочта

Функция ПолучитьПараметрыЭлектроннаяПочта(Событие) Экспорт

	ПараметрыПисем = Новый Массив;
	ВидКИ = Справочники.ВидыКонтактнойИнформации.EmailПользователя;
	
	// Якщо запит порожній - по такому Событие немає активних настройок або у користувача не заданий емейл 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОповещенияПользователей.Пользователь.Наименование КАК НаименованиеПолучателя,
	|	ЕСТЬNULL(ПользователиКонтактнаяИнформация.АдресЭП, """") КАК АдресЭП,
	|	ОповещенияПользователей.Тема КАК Тема,
	|	ОповещенияПользователей.Текст КАК Текст,
	|	ОповещенияПользователей.Копия КАК Копия,
	|	ОповещенияПользователей.СкрытаяКопия КАК СкрытаяКопия
	|ИЗ
	|	РегистрСведений.ОповещенияПользователей КАК ОповещенияПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|		ПО ОповещенияПользователей.Пользователь = ПользователиКонтактнаяИнформация.Ссылка
	|		И ПользователиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|ГДЕ
	|	ОповещенияПользователей.Событие = &Событие
	|	И ОповещенияПользователей.СпособОповещения = ЗНАЧЕНИЕ(Перечисление.СпособыОповещения.Email)
	|	И ОповещенияПользователей.Активно
	|	И ТИПЗНАЧЕНИЯ(ОповещенияПользователей.Пользователь) = ТИП(Справочник.Пользователи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ГруппыПользователейСостав.Пользователь.Наименование,
	|	ЕСТЬNULL(ПользователиКонтактнаяИнформация.АдресЭП, """"),
	|	ОповещенияПользователей.Тема,
	|	ОповещенияПользователей.Текст,
	|	ОповещенияПользователей.Копия,
	|	ОповещенияПользователей.СкрытаяКопия
	|ИЗ
	|	РегистрСведений.ОповещенияПользователей КАК ОповещенияПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
	|			ПО ГруппыПользователейСостав.Пользователь = ПользователиКонтактнаяИнформация.Ссылка
	|			И ПользователиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|		ПО ОповещенияПользователей.Пользователь = ГруппыПользователейСостав.Ссылка
	|ГДЕ
	|	ОповещенияПользователей.Событие = &Событие
	|	И ОповещенияПользователей.СпособОповещения = ЗНАЧЕНИЕ(Перечисление.СпособыОповещения.Email)
	|	И ОповещенияПользователей.Активно
	|	И ТИПЗНАЧЕНИЯ(ОповещенияПользователей.Пользователь) = ТИП(Справочник.ГруппыПользователей)";
	
	Запрос.УстановитьПараметр("Событие", Событие);
		
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ПустаяСтрока(Выборка.АдресЭП) Тогда
			Продолжить;
		КонецЕсли;	
		
		ПараметрыПисьма = Новый Структура;
		
		//Кому
		МассивКому = Новый Массив;
		
		СтруктураКому = Новый Структура;
		СтруктураКому.Вставить("Адрес"        , Выборка.АдресЭП); 
		СтруктураКому.Вставить("Представление", Выборка.НаименованиеПолучателя);
		
		МассивКому.Добавить(СтруктураКому);
		
		ПараметрыПисьма.Вставить("Кому", МассивКому);
		
		//Копии
		МассивКопии = Новый Массив;
		
		СписокКопий = Выборка.Копия.Получить();
		                                                                                
		Если СписокКопий <> Неопределено И СписокКопий.Количество() Тогда
			
			Для Каждого Копия ИЗ СписокКопий Цикл
				
				СтруктураКопии = ПолучитьСтруктуруПолучателяЭлектроннойПочты(Копия, ВидКИ);
				
				Если НЕ ПустаяСтрока(СтруктураКопии.Адрес) Тогда
					МассивКопии.Добавить(СтруктураКопии);	
				КонецЕсли;
				
			КонецЦикла;	
			
		КонецЕсли;		
		
		ПараметрыПисьма.Вставить("Копии", МассивКопии);
		
		//Слепые копии
		МассивСлепыеКопии = Новый Массив;
		
		СписокСлепыхКопий = Выборка.СкрытаяКопия.Получить();
		
		Если СписокСлепыхКопий <> Неопределено И СписокСлепыхКопий.Количество() Тогда
			
			Для Каждого СлепаяКопия ИЗ СписокСлепыхКопий Цикл
				
				СтруктураСлепойКопии = ПолучитьСтруктуруПолучателяЭлектроннойПочты(СлепаяКопия, ВидКИ);
				
				Если НЕ ПустаяСтрока(СтруктураСлепойКопии.Адрес) Тогда
					МассивСлепыеКопии.Добавить(СтруктураСлепойКопии);	
				КонецЕсли;
				
			КонецЦикла;	
			
		КонецЕсли;		
		
		ПараметрыПисьма.Вставить("СлепыеКопии", МассивСлепыеКопии);
		
		ПараметрыПисьма.Вставить("Тема", Выборка.Тема);
		ПараметрыПисьма.Вставить("Тело", Выборка.Текст);
		
		ПараметрыПисем.Добавить(ПараметрыПисьма);
		
	КонецЦикла;
	
	Возврат ПараметрыПисем;
	
КонецФункции // ПолучитьПараметрыПисем()	

Функция ПолучитьПараметрыЭлектроннаяПочтаПроизвольные(Получатель, Тема, Текст, Копии, СкрытыеКопии, Вложения)

	ПараметрыПисьма = Новый Структура;
	
	//Кому
	МассивКому = Новый Массив();	
	МассивКому.Добавить(ПолучитьСтруктуруПолучателяЭлектроннойПочты(Получатель, Справочники.ВидыКонтактнойИнформации.EmailПользователя));
    	
	ПараметрыПисьма.Вставить("Кому", МассивКому);
	
	//Копии
	Если Копии = Неопределено Тогда		
		ПараметрыПисьма.Вставить("Копии", Новый Массив());
	Иначе
		ПараметрыПисьма.Вставить("Копии", Копии);
	КонецЕсли;
	
	//Слепые копии
	Если СкрытыеКопии = Неопределено Тогда		
		ПараметрыПисьма.Вставить("СлепыеКопии", Новый Массив());
	Иначе
		ПараметрыПисьма.Вставить("СлепыеКопии", СкрытыеКопии);
	КонецЕсли;		
		
	//Вложения
	Если Вложения = Неопределено Тогда		
		ПараметрыПисьма.Вставить("Вложения", Новый Соответствие());
	Иначе
		ПараметрыПисьма.Вставить("Вложения", Вложения);
	КонецЕсли;		
		
	ПараметрыПисьма.Вставить("Тема", Тема);
	ПараметрыПисьма.Вставить("Тело", Текст);
	
	Возврат ПараметрыПисьма;
	
КонецФункции // ПолучитьПараметрыЭлектроннаяПочтаПроизвольные()

Функция ПолучитьСтруктуруПолучателяЭлектроннойПочты(Получатель, ВидКИ) Экспорт 
	
	Если ТипЗнч(Получатель) = Тип("Структура") Тогда
		Возврат Получатель;
	КонецЕсли;	
	
	СтруктураПолучателя = Новый Структура;
	СтруктураПолучателя.Вставить("Адрес"        , ""); 
	СтруктураПолучателя.Вставить("Представление", "");
	
	// может прилететь элемент СЗ или ссылка
	Если ТипЗнч(Получатель) = Тип("СправочникСсылка.Пользователи") Тогда
		ПолучательСообщения = Получатель;
	Иначе		
		ПолучательСообщения = Получатель.Значение;	
	КонецЕсли;	
	
	Адрес = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(ПолучательСообщения, ВидКИ);
	
	Если НЕ ПустаяСтрока(Адрес) Тогда 
		
		СтруктураПолучателя.Вставить("Адрес"        , Адрес); 
		СтруктураПолучателя.Вставить("Представление", ПолучательСообщения.Наименование);
		
	КонецЕсли;	
	
	Возврат СтруктураПолучателя;
	
КонецФункции // ПолучитьСтруктуруПолучателяЭлектроннойПочты()	

#КонецОбласти

