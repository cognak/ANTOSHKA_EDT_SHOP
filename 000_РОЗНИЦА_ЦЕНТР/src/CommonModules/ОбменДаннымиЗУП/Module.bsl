&НаСервере
Функция ПолучитьМагазинПоПодразделению(УИДПодразделения)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторИсточника КАК Ссылка
	               |ИЗ
	               |	РегистрСведений.СоответствияОбъектовИнформационныхБаз КАК СоответствияОбъектовИнформационныхБаз
	               |ГДЕ
	               |	СоответствияОбъектовИнформационныхБаз.УзелИнформационнойБазы.Код = ""HRM""
	               |	И СоответствияОбъектовИнформационныхБаз.ТипПриемника = ""Справочник.ПодразделенияОрганизаций""
	               |	И СоответствияОбъектовИнформационныхБаз.ТипИсточника = ""Справочник.Магазины""
	               |	И СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторПриемника = &ПодразделениеУИД";
	Запрос.УстановитьПараметр("ПодразделениеУИД", УИДПодразделения);
	Рез_ = Запрос.Выполнить().Выбрать();
	Если Рез_.Следующий() Тогда
		Возврат Рез_.Ссылка;
	Иначе     
		//вешаем признак что обмен по этому товарищу неуспешен.
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

