//Должность ищем по УИД должности в ЗУП
Функция ПолучитьДолжность(СтрокаДок)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ДолжностиОрганизаций.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ДолжностиОрганизаций КАК ДолжностиОрганизаций
	               |ГДЕ
	               |	ДолжностиОрганизаций.КодЗУП = &КодЗУП";
	Запрос.УстановитьПараметр("КодЗУП", СтрокаДок.ДолжностьУИД);
	Рез_ = Запрос.Выполнить().Выбрать();
	Если Рез_.Следующий() Тогда
		Возврат Рез_.Ссылка;
	Иначе     
		//тут я бы заводил должность автоматически на основании данных ЗУП, но это нужно согласовать. 
		СпрДолжность = Справочники.ДолжностиОрганизаций.СоздатьЭлемент();
		СпрДолжность.Наименование = СтрокаДок.Должность;
		СпрДолжность.КодКП = СтрокаДок.КодДолжностиПоКП;
		СпрДолжность.КодЗУП = СтрокаДок.ДолжностьУИД;
		СпрДолжность.Записать();
		Возврат СпрДолжность.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

