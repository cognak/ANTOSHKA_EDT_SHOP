&НаСервере
Функция ПреобразоватьВДату(ДатаСтр)
	ДатаСтр_ = СтрЗаменить(ДатаСтр,"T","");
	ДатаСтр_ = СтрЗаменить(ДатаСтр_,":","");
	ДатаСтр_ = СтрЗаменить(ДатаСтр_,"-","");
	
	Попытка
		Дата_ = Дата(ДатаСтр_);
	Исключение
		Сообщить("Не удалось преобразовать строку "+ДатаСтр+" в дату"); 
		Дата_ = Дата(1,1,1);
	КонецПопытки;
	
	Возврат Дата_;
КонецФункции

&НаСервере
Процедура ОтправитьОповещениеОбНеуспешномОбмене(ПараметрыСотрудника,Ответ)
	УчетныеДанныеОтправителя = РаботаСПочтовымиСообщениями.ПолучитьСистемнуюУчетнуюЗапись();
	
	Если УчетныеДанныеОтправителя.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ОбщегоНазначенияКлиентСервер.ПодсистемаСуществует("СтандартныеПодсистемы.КонтактнаяИнформация") Тогда
		Возврат;	
	КонецЕсли;
	
	ПараметрыПисьма = Новый Структура;
	ПараметрыПисьма.Вставить("Кому", "oleksandr.danyliuk@antoshka.ua");
	ПараметрыПисьма.Вставить("Тема", "Ошибка при обмене с ЗУП: "+ПараметрыСотрудника.ФИО+" ("+ПараметрыСотрудника.ТекущееПодразделение+")");
	ТелоПисьма = "Шановний панове!"+Символы.ПС+"Це автоматичний лист. Прохання не відповідати на нього."+Символы.ПС
		+"Произошла ошибка при загрузке сотрудника "+ПараметрыСотрудника.ФИО+" из ЗУП по причине:"
		+Символы.ПС+Символы.ПС;
		Если ТипЗнч(Ответ.ОписаниеОшибки) = Тип("Массив") Тогда
			Для Каждого ОписаниеОшибки Из Ответ.ОписаниеОшибки Цикл
				ТелоПисьма = ТелоПисьма + ОписаниеОшибки+Символы.ПС; 
			КонецЦикла;
		Иначе
			ТелоПисьма = ТелоПисьма + Ответ.ОписаниеОшибки+Символы.ПС; 
		КонецЕсли;
	ПараметрыПисьма.Вставить("Тело", ТелоПисьма);

	ЭлектроннаяПочта.ОтправитьПочтовоеСообщение(УчетныеДанныеОтправителя, ПараметрыПисьма);
	
КонецПроцедуры

&НаСервере
Функция ОбработатьМассивСотрудников(ТекстЗапроса)  Экспорт
    СтруктураОтвета = Новый Структура;
	МассивОтветовПоСотруднику = Новый Массив;
	ОписаниеОшибки = "";
	ЗагруженныеСотрудники = Новый Массив;
	
	Попытка      

		МассивСотрудников = ОбменWebRetailСервер.ТекстДЖСОНвСтруктуру(ТекстЗапроса); 
		Для Каждого ПараметрыСотрудника Из МассивСотрудников Цикл
			Если ЗагруженныеСотрудники.Найти(СокрЛП(ПараметрыСотрудника.ИНН)) = Неопределено Тогда
				//ОтветПоСотруднику = Новый Структура("УИД,Загружен",ПараметрыСотрудника.УИД,Ложь); 
				ОтветПоСотруднику = ЗагрузитьСотрудникаЗУП(ПараметрыСотрудника);
				Если ОтветПоСотруднику.Успешно = Ложь Тогда
					ОтправитьОповещениеОбНеуспешномОбмене(ПараметрыСотрудника,ОтветПоСотруднику);	
				КонецЕсли;
				МассивОтветовПоСотруднику.Добавить(ОтветПоСотруднику); 
				ЗагруженныеСотрудники.Добавить(СокрЛП(ПараметрыСотрудника.ИНН));
			КонецЕсли;
		КонецЦикла;
		Успешно = Истина;
	Исключение
		Успешно = Ложь;
		ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	СтруктураОтвета.Вставить("Успешно",Успешно);
	СтруктураОтвета.Вставить("ОписаниеОшибки",ОписаниеОшибки);
	СтруктураОтвета.Вставить("Сотрудники",МассивОтветовПоСотруднику);
	
	Возврат СтруктураОтвета;
КонецФункции



#КонецОбласти                                            

