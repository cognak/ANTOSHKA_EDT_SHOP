#Область Поддержка_Обмена_ЗУП_НТТР_Сервис
 &НаСервере 
Функция ОпределитьПолФизЛица(ПолСтрокой)
	
	Если Врег(ПолСтрокой) = "МУЖСКОЙ" Тогда
		ПолФизЛица = Перечисления.ПолФизическогоЛица.Мужской;
	ИначеЕсли Врег(ПолСтрокой) = "ЖЕНСКИЙ" Тогда
		ПолФизЛица = Перечисления.ПолФизическогоЛица.Женский;
	Иначе
		ПолФизЛица = Перечисления.ПолФизическогоЛица.ПустаяСсылка();
	КонецЕсли;
	
	Возврат ПолФизЛица;
КонецФункции

&НаСервере 
//Ищем сотрудника по ИНН. О том что ИНН обязательно заполнен - заботимся на стороне ЗУП.
Функция ПолучитьСотрудника(ПараметрыСотрудника)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	               |	ФизическиеЛица.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ФизическиеЛица КАК ФизическиеЛица
	               |ГДЕ
	               |	ФизическиеЛица.ИНН = &ТекстПоиска"; 
	Запрос.УстановитьПараметр("ТекстПоиска",СокрЛП(ПараметрыСотрудника.ИНН));
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда          
		ПараметрыСотрудника.Вставить("Сотрудник",Рез.Ссылка);
		Возврат Рез.Ссылка;
	Иначе
		ПараметрыСотрудника.Вставить("Сотрудник",Неопределено);
		Возврат Неопределено; 
	КонецЕсли;

КонецФункции


&НаСервере 
Процедура СделатьЗаписьВОтложенныеСообщения(ПараметрыОшибки)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОчередьОтказанныхСообщений.УзелПолучатель КАК УзелПолучатель,
	               |	ОчередьОтказанныхСообщений.Идентификатор КАК Идентификатор,
	               |	ОчередьОтказанныхСообщений.ДанныеСообщения КАК ДанныеСообщения,
	               |	ОчередьОтказанныхСообщений.ОснованиеОтказа КАК ОснованиеОтказа,
	               |	ОчередьОтказанныхСообщений.ДатаИзменения КАК ДатаИзменения
	               |ИЗ
	               |	РегистрСведений.ОчередьОтказанныхСообщений КАК ОчередьОтказанныхСообщений
	               |ГДЕ
	               |	ОчередьОтказанныхСообщений.Идентификатор = &Идентификатор
	               |	И ОчередьОтказанныхСообщений.УзелПолучатель.Код = ""HRM"""; 
	Запрос.УстановитьПараметр("Идентификатор",ПараметрыОшибки.Идентификатор);
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		//такая запись об ошибке уже есть и в принципе делать ничего не надо.
		Возврат;
	КонецЕсли;
    Рег = РегистрыСведений.ОчередьОтказанныхСообщений.СоздатьМенеджерЗаписи();
	Рег.Активность = Истина;
	Рег.УзелПолучатель = ПланыОбмена.ОбменРозницаЗарплатаУправлениеПерсоналом.НайтиПоКоду("HRM");
	Рег.ТипОтправителя = ПараметрыОшибки.ТипОтправителя;
	Рег.Идентификатор = ПараметрыОшибки.Идентификатор;
	Рег.ДанныеСообщения = Новый ХранилищеЗначения(ПараметрыОшибки.ДанныеСообщения,Новый СжатиеДанных(9));
	Рег.ФизЛицо = ПараметрыОшибки.ДанныеСообщения.Сотрудник;
	Рег.ДатаИзменения = ТекущаяДата();
	Рег.ОснованиеОтказа = ПараметрыОшибки.ОписаниеОшибки;
	Рег.Записать(Истина);
	
КонецПроцедуры

&НаСервере 
//Ищем сотрудника по ИНН. О том что ИНН обязательно заполнен - заботимся на стороне ЗУП.
Функция ПроверитьСопоставленияОрганизацийИПодразделений(ПараметрыСотрудника) 
	Успешно = Истина;
	МассивОшибок = Новый Массив;
	Если ЗначениеЗаполнено(ПараметрыСотрудника.ТекущееПодразделение) Тогда
		ТекущийМагазин = ПолучитьМагазинПоПодразделению(ПараметрыСотрудника.ТекущееПодразделениеУИД);
		Если Не ЗначениеЗаполнено(ТекущийМагазин) Тогда 
			ПараметрыОшибки = Новый Структура;
			
			ОснованиеОтказа = "Нет сопоставления магазина по подразделению ЗУП ["+ПараметрыСотрудника.ТекущееПодразделение+"] УИД="+ПараметрыСотрудника.ТекущееПодразделениеУИД;
			ПараметрыОшибки.Вставить("ОписаниеОшибки",ОснованиеОтказа);
			ПараметрыОшибки.Вставить("Идентификатор",ПараметрыСотрудника.ТекущееПодразделениеУИД);
			ПараметрыОшибки.Вставить("ТипОтправителя","Справочник.ПодразделенияОрганизаций");
			ПараметрыОшибки.Вставить("ДанныеСообщения",ПараметрыСотрудника);
			СделатьЗаписьВОтложенныеСообщения(ПараметрыОшибки);
			Успешно = Ложь;
			Если МассивОшибок.Найти(ОснованиеОтказа) = Неопределено Тогда
				МассивОшибок.Добавить(ОснованиеОтказа);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого ЗаписьРаботникиОрганизаций Из ПараметрыСотрудника.РаботникиОрганизаций Цикл
		Организация_ = ПолучитьОрганизацию(ЗаписьРаботникиОрганизаций);
		Если Не ЗначениеЗаполнено(Организация_) Тогда
			ПараметрыОшибки = Новый Структура;
			
			ОснованиеОтказа = "Нет сопоставления по организации ЗУП ["+ЗаписьРаботникиОрганизаций.Организация+"] УИД="+ЗаписьРаботникиОрганизаций.ОрганизацияУИД;
			ПараметрыОшибки.Вставить("ОписаниеОшибки",ОснованиеОтказа);
			ПараметрыОшибки.Вставить("Идентификатор",ЗаписьРаботникиОрганизаций.ОрганизацияУИД);
			ПараметрыОшибки.Вставить("ТипОтправителя","Справочник.Организации");
			ПараметрыОшибки.Вставить("ДанныеСообщения",ПараметрыСотрудника);
			СделатьЗаписьВОтложенныеСообщения(ПараметрыОшибки);
			Успешно = Ложь;
			Если МассивОшибок.Найти(ОснованиеОтказа) = Неопределено Тогда
				МассивОшибок.Добавить(ОснованиеОтказа);
			КонецЕсли;
		КонецЕсли;
		Магазин_ = ПолучитьМагазинПоПодразделению(ЗаписьРаботникиОрганизаций.ПодразделениеОрганизацииУИД);
		Если Не ЗначениеЗаполнено(Магазин_) Тогда
			ПараметрыОшибки = Новый Структура;
			
			ОснованиеОтказа = "Нет сопоставления магазина по подразделению ЗУП ["+ЗаписьРаботникиОрганизаций.ПодразделениеОрганизации+"] УИД="+ЗаписьРаботникиОрганизаций.ПодразделениеОрганизацииУИД;
			ПараметрыОшибки.Вставить("ОписаниеОшибки",ОснованиеОтказа);
			ПараметрыОшибки.Вставить("Идентификатор",ЗаписьРаботникиОрганизаций.ПодразделениеОрганизацииУИД);
			ПараметрыОшибки.Вставить("ТипОтправителя","Справочник.Организации");
			ПараметрыОшибки.Вставить("ДанныеСообщения",ПараметрыСотрудника);
			СделатьЗаписьВОтложенныеСообщения(ПараметрыОшибки);
			Успешно = Ложь;
			Если МассивОшибок.Найти(ОснованиеОтказа) = Неопределено Тогда
				МассивОшибок.Добавить(ОснованиеОтказа);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Запись_ Из ПараметрыСотрудника.СостояниеРаботниковОрганизаций Цикл
		Организация_ = ПолучитьОрганизацию(Запись_);
		Если Не ЗначениеЗаполнено(Организация_) Тогда
			ПараметрыОшибки = Новый Структура;
			
			ОснованиеОтказа = "Нет сопоставления по организации ЗУП ["+Запись_.Организация+"] УИД="+Запись_.ОрганизацияУИД;
			ПараметрыОшибки.Вставить("ОписаниеОшибки",ОснованиеОтказа);
			ПараметрыОшибки.Вставить("Идентификатор",Запись_.ОрганизацияУИД);
			ПараметрыОшибки.Вставить("ТипОтправителя","Справочник.Организации");
			ПараметрыОшибки.Вставить("ДанныеСообщения",ПараметрыСотрудника);
			СделатьЗаписьВОтложенныеСообщения(ПараметрыОшибки);
			Успешно = Ложь;
			Если МассивОшибок.Найти(ОснованиеОтказа) = Неопределено Тогда
				МассивОшибок.Добавить(ОснованиеОтказа);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если Не Успешно Тогда 
		ПараметрыСотрудника.Вставить("ОписаниеОшибки",МассивОшибок);
	КонецЕсли;
	
	Возврат Успешно;
КонецФункции	

&НаСервере
Функция ЗагрузитьСотрудникаЗУП(ПараметрыСотрудника) Экспорт
	ОтветПоСотруднику = Новый Структура("УИД,Успешно,ОписаниеОшибки",ПараметрыСотрудника.УИД,Ложь,""); 
	СотрудникСсылка = ПолучитьСотрудника(ПараметрыСотрудника);

	//проверим возможность сопоставления организаций и подразделений, которые нам понадобятся в процессе.
	//если где-то сопоставление не отработает, то грузить сотрудника нельзя.
	Успешно = ПроверитьСопоставленияОрганизацийИПодразделений(ПараметрыСотрудника);

	Если Не Успешно Тогда
		ОтветПоСотруднику.Вставить("ОписаниеОшибки",ПараметрыСотрудника.ОписаниеОшибки);
		Возврат ОтветПоСотруднику;	
	КонецЕсли;
	Если СотрудникСсылка <> Неопределено Тогда
		СотрудникОбъект = СотрудникСсылка.ПолучитьОбъект();
		//делаем проверку нужно ли вообще трогать справочник или изменения в статусах.
		НужнаЗаписьФизЛица = ПроверитьНеобходимостьЗаписиФизЛица(СотрудникСсылка,ПараметрыСотрудника);
	Иначе
		СотрудникОбъект = Справочники.ФизическиеЛица.СоздатьЭлемент();
		СотрудникОбъект.Сотрудник = Истина;
		СотрудникОбъект.ИНН = ПараметрыСотрудника.ИНН;
		СотрудникОбъект.Магазин = ПолучитьМагазинПоПодразделению(ПараметрыСотрудника.ТекущееПодразделениеУИД);
		НужнаЗаписьФизЛица = Истина;
	КонецЕсли;
	
	//Сообщить("НужнаЗаписьФизЛица="+НужнаЗаписьФизЛица);
	Попытка
		//	1. Если были изменения по реквизитам справочника, обновляем физ.лицо. 
		Если НужнаЗаписьФизЛица Тогда 
			СотрудникОбъект.Наименование 		= ПараметрыСотрудника.ФИО;
			СотрудникОбъект.ДатаРождения 		= ПреобразоватьВДату(ПараметрыСотрудника.ДатаРождения);
			СотрудникОбъект.Пол 				= ОпределитьПолФизЛица(ПараметрыСотрудника.Пол); 
			СотрудникОбъект.Магазин 			= ПолучитьМагазинПоПодразделению(ПараметрыСотрудника.ТекущееПодразделениеУИД);
			СотрудникОбъект.Сотрудник 			= ПараметрыСотрудника.Актуальность;
			СотрудникОбъект.Уволен 				= НЕ ПараметрыСотрудника.Актуальность; 
			СотрудникОбъект.НомерПаспорта 		= ПараметрыСотрудника.ДокументНомер;
			СотрудникОбъект.КемВыданПаспорт 	= ПараметрыСотрудника.ДокументКемВыдан;
			СотрудникОбъект.ДатаВыдачиПаспорта	= ПреобразоватьВДату(ПараметрыСотрудника.ДокументДатаВыдачи);

			Если ПараметрыСотрудника.КонтактнаяИнформация.Количество() > 0 Тогда
				СотрудникОбъект.КонтактнаяИнформация.Очистить();
				ДобавленныеКонтакты = Новый Массив;
				Для Каждого Контакт Из ПараметрыСотрудника.КонтактнаяИнформация Цикл 
					Если Контакт.Тип = "Телефон" Тогда
						НомерТелефона = ОтправкаSMS.ПодготовитьНомерТелефона(Контакт.Представление);
						Если ДобавленныеКонтакты.Найти(НомерТелефона) = Неопределено Тогда
							СтрокаКонтакта = СотрудникОбъект.КонтактнаяИнформация.Добавить();
							СтрокаКонтакта.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
							СтрокаКонтакта.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонФизическогоЛица;
							СтрокаКонтакта.Представление = ОтправкаSMS.ПодготовитьНомерТелефона(Контакт.Представление);
							СтрокаКонтакта.НомерТелефона = ОтправкаSMS.ПодготовитьНомерТелефона(Контакт.Представление);
							СтрокаКонтакта.ЗначенияПолей = УстановитьЗначенияПолейТелефон(НомерТелефона);
							ДобавленныеКонтакты.Добавить(НомерТелефона);
						КонецЕсли;
					ИначеЕсли Контакт.Тип = "ЭлектроннаяПочта" Тогда
						Если ДобавленныеКонтакты.Найти(Контакт.Представление) = Неопределено Тогда
							СтрокаКонтакта = СотрудникОбъект.КонтактнаяИнформация.Добавить();
							СтрокаКонтакта.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
							СтрокаКонтакта.Вид = Справочники.ВидыКонтактнойИнформации.EmailФизическогоЛица;
							СтрокаКонтакта.Представление = Контакт.Представление;              
							ДобавленныеКонтакты.Добавить(Контакт.Представление);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			СотрудникОбъект.ОбменДанными.Загрузка = Истина;
			СотрудникОбъект.Записать();
			СотрудникСсылка = СотрудникОбъект.Ссылка;
		КонецЕсли;                                   
		ПараметрыСотрудника.Вставить("Сотрудник",СотрудникСсылка);
		

	//	2. Фамилия Имя Отчество
		ЗаполнитьРегистрФИОФизЛиц(СотрудникСсылка, ПараметрыСотрудника);

		//Регистр РаботникиОрганизаций.
		ЗаполнитьРегистрРаботникиОрганизаций(СотрудникСсылка,ПараметрыСотрудника);
		
		
		//Регистр СостоянияРаботниковОрганизаций    
		ЗаполнитьРегистрСостояниеРаботниковОрганизаций(СотрудникСсылка,ПараметрыСотрудника); 

		//При необходимости создаем и проверяем заполнение Контрагента.
		//2025-11-08 sa контрагента из ЗУП меняем только если сотрудник еще работает.
		Если ПараметрыСотрудника.Актуальность Тогда
			ЗаполнитьСправочникКонтрагентаПоСотруднику(ПараметрыСотрудника);
		КонецЕсли;
		
		ОтветПоСотруднику.Вставить("Успешно",Истина);
		ОтветПоСотруднику.Вставить("УИД",ПараметрыСотрудника.УИД);
		
		//убрать
		//ФизЛицо = ПараметрыСотрудника.Сотрудник;
		//Контрагент = ПараметрыСотрудника.СотрудникКонтрагент;
		
	Исключение

		ОтветПоСотруднику = Новый Структура("УИД,Успешно,ОписаниеОшибки",ПараметрыСотрудника.УИД,Ложь,ОписаниеОшибки()); 
		
		Сообщить("ОШИБКА: "+ОтветПоСотруднику.ОписаниеОшибки);
	КонецПопытки;

	Возврат ОтветПоСотруднику;
КонецФункции     

&НаСервере
Процедура ЗаполнитьСправочникКонтрагентаПоСотруднику(ПараметрыСотрудника)
	КонтрагентаНужно = ПроверитьНеобходимостьЗаписиКонтрагента(ПараметрыСотрудника);
	Если КонтрагентаНужно.Создавать Тогда
		КонтрагентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
		КонтрагентОбъект.ФизЛицо = ПараметрыСотрудника.Сотрудник;
		КонтрагентОбъект.ДатаСоздания = ТекущаяДата();
		КонтрагентОбъект.Покупатель = Истина;
		КонтрагентОбъект.Родитель = Справочники.Контрагенты.Покупатели;
		КонтрагентОбъект.УстановитьНовыйКод();
		КонтрагентОбъект.IDN = КонтрагентОбъект.Код;
	ИначеЕсли Не КонтрагентаНужно.Обновлять Тогда
		ПараметрыСотрудника.Вставить("СотрудникКонтрагент",КонтрагентаНужно.Ссылка);
		Возврат;
	Иначе
		КонтрагентОбъект = КонтрагентаНужно.Ссылка.ПолучитьОбъект();
		//Блокировка = Новый БлокировкаДанных;

		//ЭлементБлокировки = Блокировка.Добавить("Справочник.Контрагенты");
		//ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		//ЭлементБлокировки.УстановитьЗначение("Ссылка", КонтрагентаНужно.Ссылка);
		//Блокировка.Заблокировать();
	КонецЕсли; 
	
	
	КонтрагентОбъект.Наименование = ПараметрыСотрудника.ФИО;
	КонтрагентОбъект.НаименованиеПолное = ПараметрыСотрудника.ФИО;
	КонтрагентОбъект.ДатаРождения = ПреобразоватьВДату(ПараметрыСотрудника.ДатаРождения);
	КонтрагентОбъект.Комментарий = "обновлен из ЗУП "+ТекущаяДата();
	КонтрагентОбъект.Пол = ОпределитьПолФизЛица(ПараметрыСотрудника.Пол);
	КонтрагентОбъект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
	КонтрагентОбъект.ДокументУдостоверяющийЛичность = ПараметрыСотрудника.ДокументПредставление;
	//Контактная информация
	Если ПараметрыСотрудника.КонтактнаяИнформация.Количество() > 0 Тогда
		ДобавленныеКонтакты = Новый Массив;
		КонтрагентОбъект.КонтактнаяИнформация.Очистить();
		Для Каждого Контакт_ Из ПараметрыСотрудника.КонтактнаяИнформация Цикл
			
			Если Контакт_.Тип = "Телефон" Тогда  
				НомерТелефона = ОтправкаSMS.ПодготовитьНомерТелефона(Контакт_.Представление);
				Если ДобавленныеКонтакты.Найти(НомерТелефона) = Неопределено Тогда
					СтрокаКонтакт = КонтрагентОбъект.КонтактнаяИнформация.Добавить();
					СтрокаКонтакт.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
					СтрокаКонтакт.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
					СтрокаКонтакт.Представление = Контакт_.Представление;
					СтрокаКонтакт.НомерТелефона = ОтправкаSMS.ПодготовитьНомерТелефона(Контакт_.Представление);
					СтрокаКонтакт.ЗначенияПолей = УстановитьЗначенияПолейТелефон(НомерТелефона);
					ДобавленныеКонтакты.Добавить(НомерТелефона);
				КонецЕсли;
			ИначеЕсли Контакт_.Тип = "ЭлектроннаяПочта" Тогда
				Если ДобавленныеКонтакты.Найти(Контакт_.Представление) = Неопределено Тогда
					СтрокаКонтакт = КонтрагентОбъект.КонтактнаяИнформация.Добавить();
					СтрокаКонтакт.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
					СтрокаКонтакт.Вид = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
					СтрокаКонтакт.Представление = Контакт_.Представление;
					ДобавленныеКонтакты.Добавить(Контакт_.Представление);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	//Дети
	Если ПараметрыСотрудника.Дети.Количество()>0 Тогда
		Для Каждого Ребенок_ Из ПараметрыСотрудника.Дети Цикл
			СтрокаРебенок = КонтрагентОбъект.Дети.Найти(ПреобразоватьВДату(Ребенок_.ДатаРождения),"ДатаРождения");
			Если СтрокаРебенок = Неопределено ИЛИ Не ЗначениеЗаполнено(СтрокаРебенок.Имя) Тогда
				СтрокаРебенок = КонтрагентОбъект.Дети.Добавить();
				СтрокаРебенок.ДатаРождения = ПреобразоватьВДату(Ребенок_.ДатаРождения);
				СтрокаРебенок.Пол = ОпределитьПолФизЛица(Ребенок_.ПолРебенка);
			    СтрокаРебенок.Имя = Ребенок_.ИмяРебенка;
			    СтрокаРебенок.Комментарий = "выгружен из ЗУП";
				//СтрокаРебенок.Пол = "";
				СтрокаРебенок.УникальныйИдентификатор = Новый УникальныйИдентификатор;
			КонецЕсли;
			
		КонецЦикла;	
	КонецЕсли;

	КонтрагентОбъект.ОбменДанными.Загрузка = Истина;
	КонтрагентОбъект.Записать();

	ПараметрыСотрудника.Вставить("СотрудникКонтрагент",КонтрагентаНужно.Ссылка);
	
КонецПроцедуры

&НаСервере
Функция ПроверитьНеобходимостьЗаписиКонтрагента(ПараметрыСотрудника) 
	КонтрагентаНужно = Новый Структура("Обновлять,Создавать,Ссылка",Ложь,Ложь,Неопределено);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Контрагенты.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.ПометкаУдаления = ЛОЖЬ
	               |	И Контрагенты.ФизЛицо = &ФизЛицо
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Контрагенты.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.Наименование = &Наименование
	               |	И Контрагенты.ДатаРождения = &ДатаРождения
	               |	И Контрагенты.ДокументУдостоверяющийЛичность ПОДОБНО &ДокументУдостоверяющийЛичность
	               |	И Контрагенты.НаименованиеПолное ПОДОБНО &НаименованиеПолное
	               |	И Контрагенты.Пол = &Пол
	               |	И Контрагенты.ФизЛицо = &ФизЛицо
	               |	И Контрагенты.ПометкаУдаления = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	КонтрагентыДети.Имя КАК Имя,
	               |	КонтрагентыДети.ДатаРождения КАК ДатаРождения,
	               |	КонтрагентыДети.Пол КАК Пол
	               |ИЗ
	               |	Справочник.Контрагенты.Дети КАК КонтрагентыДети
	               |ГДЕ
	               |	КонтрагентыДети.Ссылка.ФизЛицо = &ФизЛицо
	               |	И КонтрагентыДети.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	КонтрагентыКонтактнаяИнформация.Представление КАК Представление
	               |ИЗ
	               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	               |ГДЕ
	               |	КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И КонтрагентыКонтактнаяИнформация.Ссылка.ФизЛицо = &ФизЛицо"; 
	
	Запрос.УстановитьПараметр("ФизЛицо",ПараметрыСотрудника.Сотрудник);
	Запрос.УстановитьПараметр("Наименование",СокрЛП(ПараметрыСотрудника.ФИО));
	Запрос.УстановитьПараметр("НаименованиеПолное",СокрЛП(ПараметрыСотрудника.ФИО));
	Запрос.УстановитьПараметр("ДокументУдостоверяющийЛичность",СокрЛП(ПараметрыСотрудника.ДокументПредставление));
	Запрос.УстановитьПараметр("Пол",ОпределитьПолФизЛица(ПараметрыСотрудника.Пол));
	Запрос.УстановитьПараметр("ДатаРождения",ПреобразоватьВДату(ПараметрыСотрудника.ДатаРождения));
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
    Рез_ = ПакетЗапросов[0].Выбрать();
	Если Не Рез_.Следующий() Тогда 
		//2025-11-12 sa Если не нашли по связи с физ.лицом, попробуем найти по номеру телефона (для случая
		//когда клиент становится сотрудником)
		Для Каждого СтрокаКонтакт Из ПараметрыСотрудника.КонтактнаяИнформация Цикл
			Если СтрокаКонтакт.Тип = "Телефон" Тогда 
				НомерТелефона = ОтправкаSMS.ПодготовитьНомерТелефона(СтрокаКонтакт.Представление);
				КонтрагентСсылка = Справочники.Контрагенты.НайтиПоТелефону(НомерТелефона, Перечисления.ЮрФизЛицо.ФизЛицо, Истина, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);
				Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
					КонтрагентаНужно.Обновлять = Истина;     //т.к. не было связи с физ.лицом.
					КонтрагентаНужно.Ссылка = КонтрагентСсылка;
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	    Если Не ЗначениеЗаполнено(КонтрагентаНужно.Ссылка) Тогда
			КонтрагентаНужно.Создавать = Истина;
		КонецЕсли;
		
		Возврат КонтрагентаНужно;
	Иначе //сюда попадаем, если есть контрагент связанный с этим сотрудником.
		КонтрагентаНужно.Ссылка = Рез_.Ссылка;
	КонецЕсли;

	Рез_ = ПакетЗапросов[1].Выбрать();
	Если Рез_.Следующий() Тогда  //если контрагент со всеми реквизитами найден, то обновлять его не нужно, но нужно проверить табличные части контакты и детей
		//проверяем контактную информацию
		Контакты = ПакетЗапросов[3].Выгрузить().ВыгрузитьКолонку("Представление");
		Для Каждого СтрокаКонтакт Из ПараметрыСотрудника.КонтактнаяИнформация Цикл
			Если СтрокаКонтакт.Тип = "Телефон" Тогда
				Если Контакты.Найти(ОтправкаSMS.ПодготовитьНомерТелефона(СтрокаКонтакт.Представление)) = Неопределено Тогда
					КонтрагентаНужно.Обновлять = Истина;
					Прервать;
				КонецЕсли;
			Иначе
				Если Контакты.Найти(СтрокаКонтакт.Представление) = Неопределено Тогда
					КонтрагентаНужно.Обновлять = Истина;
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		//Проверяем детей
		Если КонтрагентаНужно.Обновлять = Ложь Тогда
			Дети = ПакетЗапросов[2].Выгрузить();
			Для Каждого СтрокаРебенка Из ПараметрыСотрудника.Дети Цикл
				//детей буду определять по ДР и хоть чем-то заполненному имени.
				Ребенок = Дети.Найти(ПреобразоватьВДату(СтрокаРебенка.ДатаРождения),"ДатаРождения");
				Если Ребенок = Неопределено ИЛИ Не ЗначениеЗаполнено(Ребенок.Имя) Тогда
					КонтрагентаНужно.Обновлять = Истина;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
	Иначе
		//Если контрагент тут не найден, значит один из реквизитов изменился и его нужно обновлять
		КонтрагентаНужно.Обновлять = Истина;
	КонецЕсли;
	
	
	Возврат КонтрагентаНужно;
КонецФункции

&НаСервере
Функция ПроверитьНеобходимостьЗаписиФизЛица(СотрудникСсылка,ПараметрыСотрудника)
	ЕстьНеобходимостьОбновлять = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ФизическиеЛица.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ФизическиеЛица КАК ФизическиеЛица
	               |ГДЕ
	               |	ФизическиеЛица.Ссылка = &Ссылка
	               |	И ФизическиеЛица.Наименование = &Наименование
	               |	И ФизическиеЛица.ДатаВыдачиПаспорта = &ДатаВыдачиПаспорта
	               |	И ФизическиеЛица.ДатаРождения = &ДатаРождения
	               |	И ФизическиеЛица.КемВыданПаспорт ПОДОБНО &КемВыданПаспорт
	               |	И ФизическиеЛица.Магазин = &Магазин
	               |	И ФизическиеЛица.НомерПаспорта = &НомерПаспорта
	               |	И ФизическиеЛица.Пол = &Пол
	               |	И ФизическиеЛица.Сотрудник = &Сотрудник
	               |	И ФизическиеЛица.Уволен = &Уволен
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ФизическиеЛицаКонтактнаяИнформация.Представление КАК Представление
	               |ИЗ
	               |	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
	               |ГДЕ
	               |	ФизическиеЛицаКонтактнаяИнформация.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка",СотрудникСсылка);
	Запрос.УстановитьПараметр("Наименование",ПараметрыСотрудника.ФИО);
	Запрос.УстановитьПараметр("ДатаВыдачиПаспорта",ПреобразоватьВДату(ПараметрыСотрудника.ДокументДатаВыдачи));
	Запрос.УстановитьПараметр("ДатаРождения",ПреобразоватьВДату(ПараметрыСотрудника.ДатаРождения));
	Запрос.УстановитьПараметр("КемВыданПаспорт",ПараметрыСотрудника.ДокументКемВыдан);
	Запрос.УстановитьПараметр("Магазин",ПолучитьМагазинПоПодразделению(ПараметрыСотрудника.ТекущееПодразделениеУИД));
	Запрос.УстановитьПараметр("НомерПаспорта",ПараметрыСотрудника.ДокументНомер);
	Запрос.УстановитьПараметр("Пол",ОпределитьПолФизЛица(ПараметрыСотрудника.Пол));
	Запрос.УстановитьПараметр("Сотрудник",ПараметрыСотрудника.Актуальность);
	Запрос.УстановитьПараметр("Уволен",НЕ ПараметрыСотрудника.Актуальность);
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	Рез = ПакетЗапросов[0].Выбрать();
	Если Рез.Следующий() Тогда  //запись со всеми реквизитами найдена, значит ничего обновлять не нужно 
		//второй этап проверяем контактную информацию.
		КонтактнаяИнформация = ПакетЗапросов[1].Выгрузить().ВыгрузитьКолонку("Представление");
		Для Каждого СтрокаКонтакт Из ПараметрыСотрудника.КонтактнаяИнформация Цикл
			Если СтрокаКонтакт.Тип = "Телефон" Тогда
				Если КонтактнаяИнформация.Найти(ОтправкаSMS.ПодготовитьНомерТелефона(СтрокаКонтакт.Представление)) = Неопределено Тогда
					ЕстьНеобходимостьОбновлять = Истина; 
					Прервать;
				КонецЕсли;
			Иначе
				Если КонтактнаяИнформация.Найти(СтрокаКонтакт.Представление) = Неопределено Тогда
					ЕстьНеобходимостьОбновлять = Истина; 
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ЕстьНеобходимостьОбновлять = Истина;
	КонецЕсли;
	
	Возврат ЕстьНеобходимостьОбновлять;
	
КонецФункции 

&НаСервере
Процедура ЗаполнитьРегистрФИОФизЛиц(СотрудникСсылка,ПараметрыСотрудника)
		//Проверим есть ли такая запись
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ФИОФизЛицСрезПоследних.ФизЛицо КАК ФизЛицо
		               |ИЗ
		               |	РегистрСведений.ФИОФизЛиц.СрезПоследних(, ФизЛицо = &ФизЛицо) КАК ФИОФизЛицСрезПоследних
		               |ГДЕ
		               |	ФИОФизЛицСрезПоследних.Фамилия = &Фамилия
		               |	И ФИОФизЛицСрезПоследних.Имя = &Имя
		               |	И ФИОФизЛицСрезПоследних.Отчество = &Отчество";
		Запрос.УстановитьПараметр("ФизЛицо",СотрудникСсылка);
		Запрос.УстановитьПараметр("Фамилия",СокрЛП(ПараметрыСотрудника.Фамилия));
		Запрос.УстановитьПараметр("Имя",СокрЛП(ПараметрыСотрудника.Имя));
		Запрос.УстановитьПараметр("Отчество",СокрЛП(ПараметрыСотрудника.Отчество));
		Рез_ = Запрос.Выполнить().Выбрать();
		Если Рез_.Следующий() Тогда //Запись уже существует, выходим.
			Возврат;
		КонецЕсли;  
		
		Рег_ = РегистрыСведений.ФИОФизЛиц.СоздатьНаборЗаписей();
		Рег_.Отбор.ФизЛицо.Установить(СотрудникСсылка);
		Рег_.Прочитать();
		Рег_.Очистить();
		Строка_ = Рег_.Добавить();
		Строка_.Период = ТекущаяДата();
		Строка_.Активность = Истина;
		Строка_.ФизЛицо = СотрудникСсылка;
		Строка_.Имя 	= СокрЛП(ПараметрыСотрудника.Имя);
		Строка_.Фамилия = СокрЛП(ПараметрыСотрудника.Фамилия);
		Строка_.Отчество = СокрЛП(ПараметрыСотрудника.Отчество);

		Рег_.Записать(Истина);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРегистрРаботникиОрганизаций(СотрудникСсылка,ПараметрыСотрудника)
		РегОрг = РегистрыСведений.РаботникиОрганизаций.СоздатьНаборЗаписей();
		РегОрг.Отбор.Сотрудник.Установить(СотрудникСсылка);
		РегОрг.Прочитать();
		//считаем, если количество записей в ЗУП = количеству записей в Рознице, то регистр не менялся. 
		Если РегОрг.Количество() = ПараметрыСотрудника.РаботникиОрганизаций.Количество() Тогда
			//2026-01-31 sa пока отключу,
			//Так бы все и было, пока я не внес последнюю правку, 
			//когда увольнение и прием на другую организацию сортируются в правильном порядке
			//(основная проблема с прошлым обменом). Там количество записей не меняется, 
			//а меняется только порядок следования (сначала увольнение, потом прием).
			//Но поскольку количество записей остается тем-же, то запись по сотрудникам не обновляется.
			
			//	Возврат;	
		КонецЕсли;
		РегОрг.Очистить();   
		//2025-10-09 кадровые перемещения делают одинаковые записи (должность разная).
		МассивЗаписей = Новый Массив;
		Для Каждого СтрокаДок Из ПараметрыСотрудника.РаботникиОрганизаций Цикл 
			КлючеваяСтрока_ = ""+Строка(СтрокаДок.ОрганизацияУИД)+Строка(СтрокаДок.Регистратор);
			ЕстьСтрока = МассивЗаписей.Найти(КлючеваяСтрока_);
			
			Строка_ = РегОрг.Добавить();
			Строка_.Активность = Истина;
			Строка_.Период = ПреобразоватьВДату(СтрокаДок.Период);
			Строка_.Сотрудник = СотрудникСсылка;
			Строка_.Организация = ПолучитьОрганизацию(СтрокаДок);
			Строка_.Подразделение = ПолучитьМагазинПоПодразделению(СтрокаДок.ПодразделениеОрганизацииУИД);
			Если ЕстьСтрока = Неопределено Тогда
				Строка_.Идентификатор = СтрокаДок.Регистратор;
			Иначе
				н = 0;
				Пока Истина Цикл
					н = н + 1;
					КлючеваяСтрока_ = ""+Строка(СтрокаДок.ОрганизацияУИД)+Строка(СтрокаДок.Регистратор)+"#"+н;
					ЕстьСтрока = МассивЗаписей.Найти(КлючеваяСтрока_);
					Если ЕстьСтрока = Неопределено Тогда
						Строка_.Идентификатор = СтрокаДок.Регистратор+"#"+н;  
						Прервать;	
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Строка_.ВидЗанятости = ПолучитьВидЗанятости(СтрокаДок.ВидЗанятости);
			Строка_.Должность = ПолучитьДолжность(СтрокаДок); 
			Строка_.ЗанимаемыхСтавок = СтрокаДок.ЗанимаемыхСтавок; 
			Строка_.Магазин = ПолучитьМагазинПоПодразделению(СтрокаДок.ПодразделениеОрганизацииУИД);
			Строка_.СостояниеСотрудника =  ПолучитьСостояниеСотрудника(СтрокаДок.ПричинаИзмененияСостояния); 
			Строка_.ДокументДвижения = СтрокаДок.ДокументДвижения;
			Строка_.ПериодНачала = ПреобразоватьВДату(СтрокаДок.Период);
			
			МассивЗаписей.Добавить(КлючеваяСтрока_);
			
		КонецЦикла;
		РегОрг.Записать(Истина);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРегистрСостояниеРаботниковОрганизаций(СотрудникСсылка,ПараметрыСотрудника)
		РегСостояние = РегистрыСведений.СостояниеРаботниковОрганизаций.СоздатьНаборЗаписей();
		РегСостояние.Отбор.Сотрудник.Установить(СотрудникСсылка);
		РегСостояние.Прочитать();
		//считаем если количество записей в ЗУП = количеству записей в Рознице, то по регистру ничего не менялось.
		Если РегСостояние.Количество() = ПараметрыСотрудника.СостояниеРаботниковОрганизаций.Количество() Тогда
			Возврат;
		КонецЕсли;
		РегСостояние.Очистить();
		//2025-10-09 кадровые перемещения делают одинаковые записи (должность разная).
		МассивЗаписей = Новый Массив;
		Для Каждого СтрокаДок Из ПараметрыСотрудника.СостояниеРаботниковОрганизаций Цикл
			КлючеваяСтрока_ = ""+Строка(СтрокаДок.ОрганизацияУИД)+Прав(СтрокаДок.Регистратор,36);
			ЕстьСтрока = МассивЗаписей.Найти(КлючеваяСтрока_); 
			
			Строка_ = РегСостояние.Добавить();
			Строка_.Активность = Истина;
			Строка_.Период = ПреобразоватьВДату(СтрокаДок.Период);
			Строка_.Сотрудник = СотрудникСсылка;
			Строка_.Организация = ПолучитьОрганизацию(СтрокаДок);
			Строка_.Подразделение = ПолучитьПодразделениеНаДату(СотрудникСсылка,Строка_.Период,Строка_.Организация);
			Если ЕстьСтрока = Неопределено Тогда
				Строка_.ДокументДвижения = Прав(СтрокаДок.Регистратор,36);
			Иначе
				н = 0;
				Пока Истина Цикл
					н = н + 1;
					КлючеваяСтрока_ = ""+Строка(СтрокаДок.ОрганизацияУИД)+Прав(СтрокаДок.Регистратор,36)+"#"+н;
					ЕстьСтрока = МассивЗаписей.Найти(КлючеваяСтрока_);
					Если ЕстьСтрока = Неопределено Тогда
						Строка_.ДокументДвижения = Прав(СтрокаДок.Регистратор+"#"+н,36);  
						Прервать;	
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Строка_.Состояние = ПолучитьСостояниеЗанятости(СтрокаДок.Состояние);
			Строка_.ПериодЗавершения = ПреобразоватьВДату(СтрокаДок.ПериодЗавершения);
			Строка_.СостояниеЗавершения = ПолучитьСостояниеЗанятости(СтрокаДок.СостояниеЗавершения);
			//Строка_.Примечание = 
			Строка_.ДокументДвиженияПредставление = СтрокаДок.ДокументДвижения;

			МассивЗаписей.Добавить(КлючеваяСтрока_);
		КонецЦикла;
		РегСостояние.Записать(Истина);
КонецПроцедуры

&НаСервере
Функция ПолучитьПодразделениеНаДату(Сотрудник,Период,Организация) 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|			РаботникиОрганизацийСрезПоследних.Период КАК Период,
	|		РаботникиОрганизацийСрезПоследних.Сотрудник КАК Сотрудник,
	|		РаботникиОрганизацийСрезПоследних.Организация КАК Организация,
	|		РаботникиОрганизацийСрезПоследних.Подразделение КАК Подразделение,
	|		РаботникиОрганизацийСрезПоследних.Магазин КАК Магазин,
	|		РаботникиОрганизацийСрезПоследних.Должность КАК Должность,
	|		РаботникиОрганизацийСрезПоследних.Идентификатор КАК Идентификатор,
	|		РаботникиОрганизацийСрезПоследних.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок
	|	ИЗ
	|		РегистрСведений.РаботникиОрганизаций.СрезПоследних(
	|				&КонецПериода,
	|				Сотрудник = &Сотрудник
	|				И
	|				Организация = &Организация) КАК РаботникиОрганизацийСрезПоследних
	|	ГДЕ
	|		РаботникиОрганизацийСрезПоследних.Период <= &КонецПериода
	|		И РаботникиОрганизацийСрезПоследних.ЗанимаемыхСтавок > 0
    |
	|	УПОРЯДОЧИТЬ ПО
	|		Период УБЫВ
	|";
	Запрос.УстановитьПараметр("КонецПериода",	Период);
	Запрос.УстановитьПараметр("Организация",	Организация);
	Запрос.УстановитьПараметр("Сотрудник",		Сотрудник);
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда
		Подразделение = Рез.Магазин;
	Иначе
		Подразделение = Сотрудник.Магазин;
	КонецЕсли;                
	
	Если Не ЗначениеЗаполнено(Подразделение) Тогда
		Подразделение = Сотрудник.Магазин;	
	КонецЕсли; 
	
	Возврат Подразделение;
КонецФункции
