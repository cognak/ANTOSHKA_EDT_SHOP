Функция СоздатьЧекПоПараметрам(СтруктураЧека) Экспорт               
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка
		НомерЧека = СтруктураЧека.Number;
		ДатаЧека = ПолучитьДату(СтруктураЧека.Date); 
		ЧекСсылка = НайтиЧекПоФН(НомерЧека,ДатаЧека);
		//ЧекСсылка = Документы.ЧекККМ.НайтиПоНомеру(НомерЧека, ДатаЧека);
		Если ЗначениеЗаполнено(ЧекСсылка) Тогда
			//Если СтруктураЧека.Свойство("ПерезаписыватьСуществующий") И СтруктураЧека.ПерезаписыватьСуществующий = Истина Тогда
				ЧекОбъект = ЧекСсылка.ПолучитьОбъект(); 
			//Иначе     
			//	СтруктураЧека.Вставить("ОписаниеОшибки","Документ "+ЧекСсылка+" уже существует в базе");
			//	Возврат Ложь;
			//КонецЕсли;
		Иначе
			ЧекОбъект = Документы.ЧекККМ.СоздатьДокумент();
			ЧекОбъект.Ответственный = Справочники.Пользователи.АдминистраторАвтоматов;
			ЧекОбъект.Автор = Справочники.Пользователи.АдминистраторАвтоматов;
			//ЧекОбъект.Номер = НомерЧека;
			ЧекОбъект.Дата = ДатаЧека;
		КонецЕсли;
		ЧекОбъект.КассаККМ = Справочники.КассыККМ.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураЧека.Kassa));
		ЧекОбъект.Организация = ЧекОбъект.КассаККМ.Владелец;
		ЧекОбъект.ВидОперации = Перечисления.ВидыОперацийЧекККМ.Продажа;   //принимаем через сервисы только чеки продажи
		НомерТелефона = "";
		Если СтруктураЧека.Свойство("Buyer") И ЗначениеЗаполнено(СтруктураЧека.Buyer) Тогда
			ЧекОбъект.ВладелецДисконтнойКарты = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураЧека.Buyer.IDC)); 
			Если ЗначениеЗаполнено(ЧекОбъект.ВладелецДисконтнойКарты) Тогда
				ЧекОбъект.ДисконтнаяКарта = ПолучитьДК(ЧекОбъект.ВладелецДисконтнойКарты);
			//ИначеЕсли Найти(Строка(ЧекОбъект.ВладелецДисконтнойКарты),"<Объект не найден>")>0 Тогда
			//	ЧекОбъект.ВладелецДисконтнойКарты = Неопределено;	
			КонецЕсли;
			Если СтруктураЧека.Buyer.Свойство("phoneNumber") Тогда
				НомерТелефона = СтруктураЧека.Buyer.phoneNumber;	
			КонецЕсли;
		КонецЕсли;            
		
		СтруктураДанныеРасчета = Новый Структура("ДанныеРасчёта",СтруктураЧека);
		ЧекОбъект.Хранилище = Новый ХранилищеЗначения(СтруктураДанныеРасчета, Новый СжатиеДанных(9));
		
		ЧекОбъект.Магазин = ЧекОбъект.КассаККМ.Магазин; 
		Если Не ЗначениеЗаполнено(ЧекОбъект.Ссылка) Тогда   
			//ЧекОбъект.ДополнительныеСвойства.Вставить("Префикс",Формат(ЧекОбъект.Магазин.НомерМагазина,"ЧЦ=3; ЧДЦ=0; ЧВН=; ЧГ=; ЧФ=Ч-"));			
			ЧекОбъект.УстановитьНовыйНомер(); 
			ЧекОбъект.IDN = ЧекОбъект.Номер;
			
			Отказ = ПроверитьКассовуюСмену(ЧекОбъект.Магазин,ЧекОбъект.Дата);
			//пока отключим
			//Если Отказ Тогда
			//	СтруктураЧека.Вставить("ОписаниеОшибки","По касі "+ЧекОбъект.КассаККМ+" не відкрито касовий день. Завантаження чеків неможливо.");
			//	СтруктураЧека.Вставить("КодОшибки",20);
			//	Успешно = Ложь;
			//	Возврат Успешно;
			//КонецЕсли;
		КонецЕсли;
		ЧекОбъект.АналитикаХозяйственнойОперации = Справочники.АналитикаХозяйственныхОпераций.РеализацияТоваров;
		ЧекОбъект.ЦенаВключаетНДС = СтруктураЧека.TaxInclude;
		
		//если чек фискализирован, то должны быть эти параметры
		Если ЗначениеЗаполнено(СтруктураЧека.FiscalInfo) Тогда
			ЧекОбъект.СтатусЧекаККМ = Перечисления.СтатусыЧековККМ.Пробитый;       
			ЧекОбъект.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикDeviceManagerФискальныйРегистратор;
		КонецЕсли;
		ЧекОбъект.СкидкиРассчитаны = Истина;
		
		//Товары
		ЧекОбъект.Товары.Очистить();
		Для Каждого СтруктураСтроки Из СтруктураЧека.Products Цикл
			Строка_ = ЧекОбъект.Товары.Добавить();
			Строка_.Номенклатура = ПолучитьНоменклатуру(СтруктураСтроки.IDN);
			//Строка_.Характеристика = ПолучитьХарактеристику(СтруктураСтроки.IDN);
			Строка_.КлючСвязи = СтруктураСтроки.KeyLink;
			Строка_.КлючСвязиБонусныхБаллов = СтруктураСтроки.KeyLinkBonus;
			Строка_.Количество = СтруктураСтроки.Count;
			Строка_.Цена 		= СтруктураСтроки.Price;
			Строка_.СуммаАвтоматическойСкидки 		= СтруктураСтроки.SummaAutoDiscount;
			Строка_.СуммаРучнойСкидки 				= СтруктураСтроки.SummaManualDiscount;
			Строка_.СуммаБонусныхБалловНачислено 	= СтруктураСтроки.SummaBonusAccrue;
			Строка_.СуммаБонусныхБалловСписано 		= СтруктураСтроки.SummaBonusPay;
			Строка_.СуммаНДС = СтруктураСтроки.TaxSumma;
			Строка_.СтавкаНДС = Строка_.Номенклатура.СтавкаНДС;
			Строка_.КоличествоУпаковок = СтруктураСтроки.Count;
			Строка_.Сумма = Строка_.Количество * Строка_.Цена - Строка_.СуммаАвтоматическойСкидки - Строка_.СуммаРучнойСкидки - Строка_.СуммаБонусныхБалловСписано;
			Строка_.Склад = ЧекОбъект.Магазин.СкладПродажи;
		КонецЦикла;
		
		//СкидкиНаценки
		ЧекОбъект.СкидкиНаценки.Очистить();
		Для Каждого СтруктураСтроки Из СтруктураЧека.Discounts Цикл
			СтрокаСкидкиНаценки = ЧекОбъект.СкидкиНаценки.Добавить();
			СтрокаСкидкиНаценки.КлючСвязи = СтруктураСтроки.KeyLink;
			СтрокаСкидкиНаценки.СкидкаНаценка = Справочники.СкидкиНаценки.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураСтроки.Discount));
			Если СтруктураСтроки.TypeApplication = "ApplyImmediately" Тогда
				СтрокаСкидкиНаценки.СпособПримененияСкидки = Перечисления.СпособыПримененияСкидокНаценок.ПрименитьВМоментРасчетаСкидокНаценок;
			Иначе
				СтрокаСкидкиНаценки.СпособПримененияСкидки = Перечисления.СпособыПримененияСкидокНаценок.НачислитьБонусныеБаллы;
			КонецЕсли;
			СтрокаСкидкиНаценки.Сумма = СтруктураСтроки.Summa;
			//СтрокаСкидкиНаценки.Расшифровка = СтруктураСтроки.KeyLink;
			
		КонецЦикла;

		//НачислениеБонусныхБаллов
		ЧекОбъект.НачислениеБонусныхБаллов.Очистить();
		Для Каждого СтруктураСтроки Из СтруктураЧека.AccrueBonusPoints Цикл
			Строка_ = ЧекОбъект.НачислениеБонусныхБаллов.Добавить();
			Строка_.ДатаНачисления = ПолучитьДату(СтруктураСтроки.DateAccrual);
			Строка_.ДатаСписания = ПолучитьДату(СтруктураСтроки.DateCancel);
			Строка_.ПрограммаЛояльности = Справочники.ПрограммыЛояльности.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураСтроки.LoyaltyProgram)); 
			Строка_.СуммаБонусныхБаллов = СтруктураСтроки.Summa;
			
		КонецЦикла;

		//ОплатаБонуснымиБаллами
		ЧекОбъект.ОплатаБонуснымиБаллами.Очистить();
		Для Каждого СтруктураСтроки Из СтруктураЧека.PayBonusPoints Цикл
			Строка_ = ЧекОбъект.ОплатаБонуснымиБаллами.Добавить();
			Строка_.КлючСвязиБонусныхБаллов = СтруктураСтроки.KeyLinkBonus;
			Строка_.ПрограммаЛояльности = Справочники.ПрограммыЛояльности.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураСтроки.LoyaltyProgram)); 
			Если СтруктураСтроки.TypeBonus = "Attraction" Тогда
				Строка_.ТипБонусов = Перечисления.ТипыБонусов.Привлечение;
			ИначеЕсли СтруктураСтроки.TypeBonus = "Organic" Тогда
				Строка_.ТипБонусов = Перечисления.ТипыБонусов.Органический;
			Иначе
				Строка_.ТипБонусов = Перечисления.ТипыБонусов.Акционный;
			КонецЕсли;
			Строка_.СуммаБонусныхБаллов = СтруктураСтроки.Summa;
		КонецЦикла;
		
		//Оплаты
		ЧекОбъект.Оплата.Очистить();
		Для Каждого СтруктураСтроки Из СтруктураЧека.Payment Цикл
			Строка_ = ЧекОбъект.Оплата.Добавить();
			Если СтруктураСтроки.Type = "Наличные" Тогда
				Строка_.ВидОплаты = Справочники.ВидыОплатЧекаККМ.Наличные;
			ИначеЕсли СтруктураСтроки.Type = "Платіжна картка" Тогда
				Строка_.ВидОплаты = Справочники.ВидыОплатЧекаККМ.ОплатаПлатежнойКартой;
				Строка_.СсылочныйНомер = СтруктураСтроки.TransactionID;
				Если Не ЗначениеЗаполнено(СтруктураСтроки.TerminalID) Тогда
					Строка_.ЭквайринговыйТерминал = ПолучитьТерминалПоКассеККМ(ЧекОбъект.КассаККМ);
				Иначе
					Строка_.ЭквайринговыйТерминал = ПолучитьТерминалПоИД(СтруктураСтроки.TerminalID);
				КонецЕсли;
				Строка_.НомерЧекаЭТ = СтруктураСтроки.TransactionID;
				Если СтруктураСтроки.Свойство("Params") И ЗначениеЗаполнено(СтруктураСтроки.Params) Тогда
					Строка_.СлипЧек = ОбменWebRetailСервер.СтруктуруВТекстДЖСОН(СтруктураСтроки.Params);
				КонецЕсли;
			КонецЕсли;
			Строка_.Сумма = СтруктураСтроки.Summa;
			
		КонецЦикла;  
		
		//ЧекОбъект.ОбменДанными.Загрузка = Истина;
		ЧекОбъект.ДополнительныеСвойства.Вставить("ЗагрузкаДанныхИзРабочегоМеста", Истина);
		ЧекОбъект.ДополнительныеСвойства.Вставить("СлужебнаяЗапись", Истина);
		
		//Коды ошибок 20-29 зарезервированы для случаев когда мы требуем от КСО повторить попытку отправки чека.
		//В остальных случаях, КСО сохраняет чек в своей базе, логирует ошибку но более не пытается ее выгрузить.
		//Какие случаи мы считаем необходимыми для повторной выгрузки, определяем мы сами кодами 20-29.
		Попытка
			ЧекОбъект.Записать(РежимЗаписиДокумента.Проведение); 
			СтруктураЧека.Вставить("ЧекККМСсылка",ЧекОбъект.Ссылка);
			УстановитьИспользованиеКупона(СтруктураЧека);			
			Успешно = Истина;
		Исключение
			ЧекОбъект.Записать(РежимЗаписиДокумента.Запись);
			Успешно = Ложь;
			СтруктураЧека.Вставить("ОписаниеОшибки","Документ "+ЧекОбъект.Ссылка+": "+ОписаниеОшибки());
			СтруктураЧека.Вставить("КодОшибки",1);
		КонецПопытки;			

		//даже если ФН уже существует в данном случае это не ошибка.
		СтруктураОтвета = Документы.ЧекККМ.ЗаписатьФискальныйНомер(ЧекОбъект.Ссылка,НомерЧека,,СтруктураЧека.FiscalInfo);
		
		СтруктураЧека.Вставить("ЧекККМСсылка",Чекобъект.Ссылка);
	Исключение
		СтруктураЧека.Вставить("ОписаниеОшибки","При создании чека №"+НомерЧека+" от "+ДатаЧека+"произошла ошибка: "+ОписаниеОшибки());
		СтруктураЧека.Вставить("КодОшибки",1);
		Успешно = Ложь;
	КонецПопытки;

	//2026-06-09 sa если чек залетел успешно, отправляем покупателю СМС
	Если Успешно И ЗначениеЗаполнено(НомерТелефона) Тогда
		//Чек успешно загружен. К КСО претензий нет. Если при отправке чека возникнет ошибка, то КСО должно нормально завершить операцию.
		Попытка 
			ОтветПРРО = СтруктураЧека.FiscalInfo.fiscal;
			ДанныеПротокола = Новый Структура(
					"Объект, URL, ДанныеPDF, ОтветПРРО"
					, ЧекОбъект.Ссылка
					, ОтветПРРО.info.QR
					, ОтветПРРО.pf_doccmd
					, ОтветПРРО);
			
		
			ПодключаемоеОборудованиеDeviceManagerФискальныйРегистраторСервер.ОтправитьУведомлениеПокупателю(
				НомерТелефона,ЧекОбъект.ВладелецДисконтнойКарты,ДанныеПротокола,Перечисления.ВидыСообщений.SMS,ИмяКомпьютера(),Ложь); 
		Исключение
		КонецПопытки;
			
	КонецЕсли;		
	
	Возврат Успешно;
КонецФункции

Функция УстановитьИспользованиеКупона(СтруктураЧека)
	
	//Таблица купонов
	Если НЕ (СтруктураЧека.Свойство("CouponsRedeemed") И ТипЗнч(СтруктураЧека.CouponsRedeemed)=Тип("Массив")) Тогда 
		Возврат Истина;
	КонецЕсли;       
	
	Если СтруктураЧека.CouponsRedeemed.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.ДвиженияСерийныхНомеровКупонов.СоздатьНаборЗаписей();
	НаборЗаписей.ДополнительныеСвойства.Вставить("ПропуститьПроверкуЗапретаИзменения", Истина);


	НаборЗаписей.Отбор.ЧекККМ.Установить(СтруктураЧека.ЧекККМСсылка);
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();

	Для Каждого СтруктураКупона Из СтруктураЧека.CouponsRedeemed Цикл
		Купон = ПолучитьДанныеКупона(СтруктураКупона); 
		Если Купон = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписьНабора = НаборЗаписей.Добавить();
		ЗаписьНабора.ЧекККМ	 = СтруктураЧека.ЧекККМСсылка;
		ЗаписьНабора.Купон	 = Купон.Номенклатура;
		ЗаписьНабора.СерийныйНомер	 = Купон.СерийныйНомер;
		ЗаписьНабора.Дата	 = ТекущаяДатаСеанса();
		ЗаписьНабора.АналитикаХозяйственнойОперации = Справочники.АналитикаХозяйственныхОпераций.ПогашениеПодарочныхСертификатов;
		ЗаписьНабора.Магазин = СтруктураЧека.ЧекККМСсылка.Магазин;
		ЗаписьНабора.Количество = 1;
	КонецЦикла;

	НаборЗаписей.Записать();
	
	
КонецФункции

Функция ПолучитьДанныеКупона(СтруктураКупона)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	               |	СерийныеНомера.Ссылка КАК СерийныйНомер,
	               |	СерийныеНомера.Владелец КАК Номенклатура
	               |ИЗ
	               |	Справочник.СерийныеНомера КАК СерийныеНомера
	               |ГДЕ
	               |	СерийныеНомера.ПометкаУдаления = ЛОЖЬ
	               |	И СерийныеНомера.Владелец.Код = &Код
	               |	И СерийныеНомера.КодСерийногоНомера = &КодСерийногоНомера"; 
	Запрос.УстановитьПараметр("Код", СтруктураКупона.Coupon);
	Запрос.УстановитьПараметр("КодСерийногоНомера", СтруктураКупона.SerialNumber);
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда 
		Купон = Новый Структура("Номенклатура,СерийныйНомер", Рез.Номенклатура,Рез.СерийныйНомер);
		Возврат Купон;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	

КонецФункции