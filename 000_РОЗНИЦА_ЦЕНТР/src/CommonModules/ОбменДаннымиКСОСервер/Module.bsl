		ПараметрыПисьма = Новый Структура;
		ПараметрыПисьма.Вставить("Кому", "oleksandr.danyliuk@gmail.com");
		ПараметрыПисьма.Вставить("Тема", "Ошибка при выгрузке в КСО от "+ТекущаяДата());
			
		ПараметрыПисьма.Вставить("Тело", ТелоПисьма);

		ЭлектроннаяПочта.ОтправитьПочтовоеСообщение(УчетныеДанныеОтправителя, ПараметрыПисьма);
		
	КонецЕсли;

	
