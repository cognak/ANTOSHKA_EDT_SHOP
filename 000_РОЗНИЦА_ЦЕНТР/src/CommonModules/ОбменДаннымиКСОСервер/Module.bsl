Функция ПолучитьДату(Знач ДатаСтрокой)           
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой,"-","");
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой,"T","");
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой,":","");
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой,"/","");
	
	Попытка
		вДата = Дата(ДатаСтрокой);
	Исключение
		вДата = Дата("00010101");
	КонецПопытки;             
	
	Возврат вДата;	
	
