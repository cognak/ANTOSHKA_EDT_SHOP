
Процедура КСОСправочникиРегистрацияИзмененийПриЗаписи(Источник, Отказ) Экспорт
	УзлыОбмена = ПланыОбмена.ОбменКСО.Выбрать();
	Пока УзлыОбмена.Следующий() Цикл
		Если УзлыОбмена.Ссылка = ПланыОбмена.ОбменКСО.ЭтотУзел() Тогда
			Продолжить;
		КонецЕсли;
		Если УзлыОбмена.Ссылка.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(Источник) = Тип("СправочникСсылка.Номенклатура") 
			ИЛИ ТипЗнч(Источник) = Тип("СправочникОбъект.Номенклатура")  
				Тогда
			ИсточникДанных = Источник.Ссылка;
		ИначеЕсли ТипЗнч(Источник) = Тип("СправочникСсылка.Номенклатура") 
			ИЛИ ТипЗнч(Источник) = Тип("СправочникОбъект.Номенклатура")  
				Тогда 
			ИсточникДанных = Источник.Ссылка;
		Иначе
			ИсточникДанных = Источник;
		КонецЕсли;
		Если ИсточникДанных.ЭтоГруппа Тогда
			Продолжить;
		КонецЕсли;
		Если ИсточникДанных.ВидНоменклатуры.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
			Продолжить;
		КонецЕсли;
		ПланыОбмена.ЗарегистрироватьИзменения(УзлыОбмена.Ссылка,ИсточникДанных.Ссылка);
	КонецЦикла;
	
КонецПроцедуры


Процедура КСОРегистрыРегистрацияИзмененийПриЗаписи(Источник, Отказ, Замещение) Экспорт
	УзлыОбмена = ПланыОбмена.ОбменКСО.Выбрать();
	Пока УзлыОбмена.Следующий() Цикл
		Если УзлыОбмена.Ссылка = ПланыОбмена.ОбменКСО.ЭтотУзел() Тогда
			Продолжить;
		КонецЕсли;
		Если УзлыОбмена.Ссылка.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;
		Для Каждого Строка_ Из Источник Цикл
			Если УзлыОбмена.ВидЦенКСО <> Строка_.ВидЦены Тогда
				Продолжить;
			КонецЕсли;

			Если Строка_.Номенклатура.ВидНоменклатуры.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
				Продолжить;
			КонецЕсли;
			
			ПланыОбмена.ЗарегистрироватьИзменения(УзлыОбмена.Ссылка,Строка_.Номенклатура);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры


Функция ПолучитьУзелОбменаКСО() Экспорт
	Возврат ПланыОбмена.ОбменКСО.НайтиПоКоду("КСО");	
КонецФункции


Функция ЗапуститьОбменДаннымиКСО() Экспорт
	УзелОбмена = ПолучитьУзелОбменаКСО();
	Параметры = Новый Структура();
	Параметры.Вставить("УзелОбмена",УзелОбмена);
	Параметры.Вставить("АдресСервера",УзелОбмена.АдресСервера);
	Параметры.Вставить("АдресРесурса",УзелОбмена.АдресРесурса);
	Параметры.Вставить("Порт",УзелОбмена.Порт);
	Параметры.Вставить("ВидЦены",УзелОбмена.ВидЦенКСО);
	Параметры.Вставить("РезультатОбмена",Новый Массив);
	Параметры.Вставить("ВыгружатьКартинки", Ложь);

	
	ВыгрузкаНоменклатурыГрупповой(Параметры);
	
	Возврат Параметры;
КонецФункции




&НаСервере
Функция СтруктуруВТекстДЖСОН(СтруктураПараметров) Экспорт
	
	Попытка
		ЗаписьДЖСОН = Новый ЗаписьJSON;
		ЗаписьДЖСОН.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьДЖСОН,СтруктураПараметров);
		ТекстДЖСОН = ЗаписьДЖСОН.Закрыть();
	Исключение
		ТелоПисьма = ОбщегоНазначенияКлиентСервер.СтруктураПредставление("Структура параметров", СтруктураПараметров);
		ОтправитьСообщениеОбОшибке("Ошибка при преобразовании структуры в текст: "+ТелоПисьма+Символы.ПС+""+ОписаниеОшибки());
	КонецПопытки;
	Возврат ТекстДЖСОН;
КонецФункции

//2023-01-05 sa преобразование текста JSON в структуру 
Функция ТекстДЖСОНвСтруктуру(ТекстДЖСОН) Экспорт
	СтруктураОтвета = Новый Структура;
	Если ТекстДЖСОН = "" Тогда
		СтруктураОтвета.Вставить("Success",Ложь);
		СтруктураОтвета.Вставить("Description","Текст не в формате JSON (пустой)!");
		Возврат СтруктураОтвета;
	КонецЕсли;
	
	ФайлJSON = Новый ЧтениеJSON;
	ФайлJSON.УстановитьСтроку(ТекстДЖСОН);
	
	Попытка
		СтруктураОтвета = ПрочитатьJSON(ФайлJSON);
		ФайлJSON.Закрыть();
	Исключение
		СтруктураОтвета.Вставить("Success",Ложь);
		СтруктураОтвета.Вставить("Description","Текст не в формате JSON!"+Символы.ПС+ТекстДЖСОН);
	КонецПопытки;
	
	Возврат СтруктураОтвета;
КонецФункции

Функция ПолучитьЗарегистрированныеИзменения()
	//ограничим запрос 1000 записей т.к. иначе оно тупо не успеет выгрузится за промежуток между регламентными заданиями.
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1000
	               |	НоменклатураИзменения.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
	               |ГДЕ
	               |	НоменклатураИзменения.Узел = &Узел";
	
	Запрос.УстановитьПараметр("Узел", ПолучитьУзелОбменаКСО());
	Товары = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");

	Возврат Товары;
	
КонецФункции

Функция СформироватьСтруктуруТовара(Параметры, Товар)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СпрНоменклатура.Ссылка КАК Ссылка,
	               |	СпрНоменклатура.Код КАК id,
	               |	СпрНоменклатура.Код КАК sku,
	               |	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.ВидНоменклатуры) КАК ВидНоменклатуры,
	               |	СпрНоменклатура.ЕдиницаИзмерения.Наименование КАК unit,
	               |	СпрНоменклатура.НаименованиеПолное КАК name,
	               |	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.СтавкаНДС) КАК taxRate,
	               |	ДействующиеЦеныНоменклатурыСрезПоследних.Цена * 100 КАК price,
	               |	ДействующиеЦеныНоменклатурыСрезПоследних.ОбъектЦенообразования.ПравилоЦенообразования.ВидЦен.Наименование КАК priceLevel
	               |ИЗ
	               |	РегистрСведений.ДействующиеЦеныНоменклатуры.СрезПоследних(, ОбъектЦенообразования.ПравилоЦенообразования.ВидЦен = &ВидЦен) КАК ДействующиеЦеныНоменклатурыСрезПоследних
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	               |		ПО ДействующиеЦеныНоменклатурыСрезПоследних.Номенклатура = СпрНоменклатура.Ссылка
	               |ГДЕ
	               |	СпрНоменклатура.Ссылка = &Номенклатура
	               |	И СпрНоменклатура.ПометкаУдаления = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Штрихкоды.Штрихкод КАК barcode,
	               |	ЕСТЬNULL(Штрихкоды.Упаковка.Наименование, Штрихкоды.Владелец.ЕдиницаИзмерения.Наименование) КАК unit
	               |ИЗ
	               |	РегистрСведений.Штрихкоды КАК Штрихкоды
	               |ГДЕ
	               |	Штрихкоды.Владелец = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура",Товар);
	Запрос.УстановитьПараметр("ВидЦен",Параметры.ВидЦены);
	ПакетЗапросов = Запрос.ВыполнитьПакет();

	РезТовары = ПакетЗапросов[0].Выбрать();
	Пока РезТовары.Следующий() Цикл
		СтруктураТовара = Новый Структура("id, sku, taxRate, name, unit, price, priceLevel, barcodes","","","","","",0,"",""); 
		ЗаполнитьЗначенияСвойств(СтруктураТовара,РезТовары);
		СтруктураТовара.Вставить("id", Строка(РезТовары.Ссылка.УникальныйИдентификатор()));
		Если Параметры.ВыгружатьКартинки Тогда
			МассивТоваровДляКартинок = Новый Массив;
			МассивТоваровДляКартинок.Добавить(РезТовары.Ссылка);
			Попытка
				Картинки_ = ЗаказыПокупателейСервер.ПолучитьСоответствиеКартинокТовара(МассивТоваровДляКартинок,Истина);
				ДанныеКартинки = Картинки_.Получить(РезТовары.Ссылка);
				Если ЗначениеЗаполнено(ДанныеКартинки) Тогда          
					СтруктураТовара.Вставить("Картинка",ДанныеКартинки);	
				КонецЕсли;
			Исключение
				ОтправитьСообщениеОбОшибке("Товар: "+СтруктураТовара.id+" "+СтруктураТовара.name+" "+ОписаниеОшибки());
			КонецПопытки;
			
		КонецЕсли;
		
		МассивШК = Новый Массив;
		РезШК = ПакетЗапросов[1].Выбрать();
		Пока РезШК.Следующий() Цикл
			СтруктураШК = Новый Структура("barcode, unit","","");
			ЗаполнитьЗначенияСвойств(СтруктураШК,РезШК);			
			МассивШК.Добавить(СтруктураШК);	
		КонецЦикла;
		СтруктураТовара.Вставить("barcodes",МассивШК); 
	КонецЦикла;

	Возврат СтруктураТовара;	
КонецФункции

Функция ВыгрузкаНоменклатурыГрупповой(Параметры) Экспорт
	ТекстОтвета = "";
    Параметры.Вставить("РезультатОбмена",Новый Массив);
	
	МассивСообщений = Новый Массив;
	НачВремя = ТекущаяДата();
	Параметры.РезультатОбмена.Добавить("Начало выгрузки: " + НачВремя);
	
	ЛимитПакета = 10 * 1024 * 1024; // 10 МБ
	ТекущийРазмер = 0;
	
	Если Не Параметры.Свойство("Товары") Тогда 
		Товары = ПолучитьЗарегистрированныеИзменения(); 
		Параметры.Вставить("Товары",Товары);
	КонецЕсли;
	
	
	// буферы текущего пакета
	МассивТоваров = Новый Массив;
	СоответствиеКартинок = Новый Соответствие;
	// =========================================
	// ОСНОВНОЙ ЦИКЛ
	// =========================================
	Для Каждого Товар Из Параметры.Товары Цикл
		
		СтруктураТовара = СформироватьСтруктуруТовара(Параметры,Товар);
		
		Если Не ЗначениеЗаполнено(СтруктураТовара.priceLevel) Тогда
			Параметры.РезультатОбмена.Добавить(""+СтруктураТовара.sku+" "+СтруктураТовара.name+" не имеет установленной цены");
			Продолжить;
		КонецЕсли;
		
		Если СтруктураТовара.Свойство("Картинка") Тогда
			ДанныеКартинки = СтруктураТовара.Картинка;
			КартинкаРазмер = ДанныеКартинки.Размер();
		Иначе 
		//	ДанныеКартинки = БиблиотекаКартинок.Документ.ПолучитьДвоичныеДанные();
			ДанныеКартинки = Неопределено; 
			КартинкаРазмер = 0;
		КонецЕсли;

		Ключ = СтруктураТовара.id;

		// если не влазит в пакет → отправляем текущий
		Если ТекущийРазмер + КартинкаРазмер > ЛимитПакета Тогда
			
			ОтправитьПакет(Параметры, МассивТоваров,СоответствиеКартинок);

			// очистка
			МассивТоваров = Новый Массив;
			СоответствиеКартинок = Новый Соответствие;
			ТекущийРазмер = 0;

		КонецЕсли;
		//Если ФормироватьЛогФайл Тогда
		//	Сообщить("SKU: " + СтруктураТовара.SKU + " = " + ОКР(КартинкаРазмер/1024) + "К");
		//КонецЕсли;
		
		СтруктураТовара.Удалить("Картинка");
		МассивТоваров.Добавить(СтруктураТовара);
		Если КартинкаРазмер > 0 Тогда
			СоответствиеКартинок.Вставить(Ключ, ДанныеКартинки);
		КонецЕсли;
		
		//один товар без картинок занимает примерно 512 байт. Это нужно учесть при подсчете размера.
		ТекущийРазмер = ТекущийРазмер +512+ КартинкаРазмер;
		
	КонецЦикла;

	// отправка последнего пакета
	ОтправитьПакет(Параметры, МассивТоваров,СоответствиеКартинок);

	КонВремя = ТекущаяДата();
	МассивСообщений.Добавить("Окончание выгрузки: " + КонВремя);
	Длительность = ?(КонВремя=НачВремя, 1, (КонВремя-НачВремя));
	Параметры.РезультатОбмена.Добавить("Длительность: " + Длительность 
		+ " с. Товаров/сек = " 
		+ (Параметры.Товары.Количество()/Длительность));
		
   
КонецФункции

// =========================================
// ПРОЦЕДУРА ОТПРАВКИ ПАКЕТА
// =========================================
Процедура ОтправитьПакет(Параметры, МассивТоваров, СоответствиеКартинок)
 	ХТТПСоединение = Новый HTTPСоединение(Параметры.АдресСервера, Параметры.Порт);


	Если МассивТоваров.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
    ТекстОтвета = "";
	
	Граница = "----1CFormBoundary" + Строка(Новый УникальныйИдентификатор());

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Граница);

	ХТТПЗапрос = Новый HTTPЗапрос(Параметры.АдресРесурса, Заголовки);

	// JSON
	СтруктураВыгрузки = Новый Структура("products", МассивТоваров);
	Попытка
		ТекстЗапроса = СтруктуруВТекстДЖСОН(СтруктураВыгрузки);
	Исключение
		ОтветСервиса = "";
		Параметры.РезультатОбмена.Добавить("Ошибка при формировании пакета: "+ОписаниеОшибки());
		ОтправитьСообщениеОбОшибке("Ошибка при преобразовании структуры в текст: "+ОписаниеОшибки());
		//ОтобразитьСтруктуруРекурсивно("",СтруктураВыгрузки);
		//Сообщить("");
		Возврат;
	КонецПопытки;
	
	Поток = Новый ПотокВПамяти();
	Запись = Новый ЗаписьДанных(Поток, КодировкаТекста.UTF8);

	// --- JSON part ---
	Запись.ЗаписатьСтроку("--" + Граница, КодировкаТекста.UTF8);
	Запись.ЗаписатьСтроку("Content-Disposition: form-data; name=""product""", КодировкаТекста.UTF8);
	Запись.ЗаписатьСтроку("Content-Type: application/json; charset=UTF-8", КодировкаТекста.UTF8);
	Запись.ЗаписатьСтроку("");
	Запись.ЗаписатьСтроку(ТекстЗапроса, КодировкаТекста.UTF8);
	
	ТекущийРазмер = 0;
	// --- IMAGE parts ---
	Для Каждого КлючИЗначение Из СоответствиеКартинок Цикл
		
		ДанныеКартинки = СоответствиеКартинок.Получить(КлючИЗначение.Ключ);
		
		ТекущийРазмер = ТекущийРазмер + ДанныеКартинки.Размер();
		
		Запись.ЗаписатьСтроку("--" + Граница, КодировкаТекста.UTF8);
		Запись.ЗаписатьСтроку(
			"Content-Disposition: form-data; name=""images[" + КлючИЗначение.Ключ + "]""; filename=""" + КлючИЗначение.Ключ + ".jpg""",
			КодировкаТекста.UTF8
		);
		Запись.ЗаписатьСтроку("Content-Type: image/jpeg", КодировкаТекста.UTF8);
		Запись.ЗаписатьСтроку("");

		Запись.Записать(ДанныеКартинки);
		Запись.ЗаписатьСтроку("");

	КонецЦикла;

	// закрытие
	Запись.ЗаписатьСтроку("--" + Граница + "--", КодировкаТекста.UTF8);
	Запись.Закрыть();

	ТелоЗапроса = Поток.ЗакрытьИПолучитьДвоичныеДанные();

	// (опционально дамп)
	//Если ФормироватьЛогФайл Тогда
	//	ТелоЗапроса.Записать(КаталогЛогФайлов+"\dump_"+Формат(ТекущаяДата(),"ДФ=yyyy-MM-dd_ЧЧммсс_")+Строка(Новый УникальныйИдентификатор())+".txt"); 
	//КонецЕсли;
	
	ХТТПЗапрос.УстановитьТелоИзДвоичныхДанных(ТелоЗапроса);

	Сообщить("Отправка пакета: " + МассивТоваров.Количество() 
		+ " товаров, ~" + ОКР(ТекущийРазмер/1024/1024,2) + " МБ");

	ОтветСервиса = ХТТПСоединение.ОтправитьДляОбработки(ХТТПЗапрос);

	Если ОтветСервиса.КодСостояния = 200 Тогда
		
		ТекстОтвета = ТекстОтвета + ОтветСервиса.ПолучитьТелоКакСтроку()+Символы.ПС;

		Если ЗначениеЗаполнено(ТекстОтвета) Тогда
			
			СтруктураОтвета = ТекстДЖСОНвСтруктуру(ТекстОтвета);

			Для Каждого ОтветПоТовару Из СтруктураОтвета.response Цикл
				
				Если ОтветПоТовару.success Тогда                                                
					Попытка
						Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ОтветПоТовару.id));
						Если Найти(Строка(Номенклатура),"<Обмен не найден>")>0 Тогда
							Параметры.РезультатОбмена.Добавить("В базе 1С не найден успешно загруженный товар с УИД "+ОтветПоТовару.id);
							Продолжить;
						КонецЕсли;
						ПланыОбмена.УдалитьРегистрациюИзменений(Параметры.УзелОбмена, Номенклатура);
					Исключение
						Параметры.РезультатОбмена.Добавить("Исключительная ситуация при поиске товара с УИД "+ОтветПоТовару.id);
					КонецПопытки;
				КонецЕсли;

			КонецЦикла;

		КонецЕсли;

	Иначе
		Параметры.РезультатОбмена.Добавить("Ошибка при передаче пакета: " + ОтветСервиса.КодСостояния 
			+ Символы.ПС + ОтветСервиса.ПолучитьТелоКакСтроку());
	КонецЕсли;

КонецПроцедуры

