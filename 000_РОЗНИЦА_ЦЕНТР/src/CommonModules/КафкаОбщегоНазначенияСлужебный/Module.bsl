// Преобразует дату в строку в соответствии с заданным форматом.
//
// Параметры:
//   Значение - Дата - Дата, которую необходимо преобразовать в строку
//   ВариантЗаписи - ВариантЗаписиДатыJSON - Вариант записи даты в формате JSON
//   ЗначениеПустойДаты - Строка - Значение, которое возвращается, если дата пустая (по умолчанию: "")
//
// Возвращаемое значение:
//   Строка - Представление даты в строковом формате
Функция ДатаВСтроку(Значение, ВариантЗаписи, ЗначениеПустойДаты = "") Экспорт
	
	Если Значение = Дата(1, 1, 1) Тогда
		Возврат ЗначениеПустойДаты;
		
	Иначе
		Возврат ЗаписатьДатуJSON(Значение, ФорматДатыJSON.ISO, ВариантЗаписи);
	КонецЕсли;
	
КонецФункции

// Преобразует дату в формате миллисекунд с начала Unix-эпохи в строку в формате ISO с миллисекундами.
//
// Параметры:
//   Значение - Число - Дата в формате миллисекунд с начала Unix-эпохи.
//   ЗначениеПустойДаты - Строка - Значение, которое возвращается, если дата пустая (по умолчанию: "")
//
// Возвращаемое значение:
//   Строка - Дата в формате ISO с миллисекундами
Функция ДатаМсВСтроку(Значение, ЗначениеПустойДаты = "") Экспорт
	
	Если Значение = 0 Тогда
		Возврат ЗначениеПустойДаты;
	КонецЕсли;
	
	Секунды = Цел(Значение / 1000);
	Возврат ЗаписатьДатуJSON(Дата(1, 1, 1) + Секунды, ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.ЛокальнаяДата)
		+ "." + СтрЗаменить(XMLСтрока(Значение - Секунды * 1000), ".", "") + "Z";
	
КонецФункции

#КонецОбласти

