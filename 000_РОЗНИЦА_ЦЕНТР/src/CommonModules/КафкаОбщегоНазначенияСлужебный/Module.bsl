// Проверка того, что переданное значение является ссылочным типом данных.
// Для типа Неопределено возвращается Ложь.
//
// Замеры:
//	* ОбщегоНазначения.ЭтоСсылка - Длительность = 0.014с, Среднее = 0.000014с
//	* КафкаОбщегоНазначенияСлужебный.ЭтоСсылка - Длительность = 0.008с, Среднее = 0.000008с
//	
// Параметры:
//  Значение - Произвольный - для проверки на ссылочный тип данных.
//
// Возвращаемое значение:
//  Булево - Истина, если это ссылка.
//
Функция ЭтоСсылка(Значение) Экспорт
	
	ТипXML = СериализаторXDTO.XMLТипЗнч(Значение);
	Возврат ТипXML <> Неопределено И СтрНайти(ТипXML.ИмяТипа, "Ref.") > 0;
	
КонецФункции

// Создать набор записей.
// 
// Параметры:
//  Менеджер - РегистрСведенийМенеджер - Менеджер
// 
// Возвращаемое значение:
//  РегистрСведенийНаборЗаписейИмяРегистраСведений - Набор записей
Функция СоздатьНаборЗаписей(Менеджер) Экспорт
	
	НаборЗаписей = Менеджер.СоздатьНаборЗаписей();
	кфкИнтеграция.Отключить(НаборЗаписей);
	НаборЗаписей.ОбменДанными.Загрузка = Истина;
	
	Возврат НаборЗаписей;
	
КонецФункции

// Возвращает ключи регистра на основе переданного объекта метаданных.
//
// Параметры:
//   ОбъектМД - ОбъектМетаданныхРегистрСведений - объект метаданных, для которого необходимо получить ключи регистра
//
// Возвращаемое значение:
//   Массив Из Строка - ключи регистра
Функция КлючиРегистра(ОбъектМД) Экспорт
	
	Результат = Новый Массив; // Массив Из Строка
	
	// Периодичность
	Если ОбъектМД.ПериодичностьРегистраСведений <> Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.Непериодический Тогда
		Результат.Добавить(ОбъектМД.СтандартныеРеквизиты.Период.Имя);
	КонецЕсли;
	
	// Регистратор
	Если ОбъектМД.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
		Результат.Добавить(ОбъектМД.СтандартныеРеквизиты.Регистратор.Имя);
	КонецЕсли;
	
	// Измерения
	Для Каждого Измерение Из ОбъектМД.Измерения Цикл
		Результат.Добавить(Измерение.Имя);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область Данные

// Создает массив и копирует в него значения, содержащиеся в колонке выборке запроса.
// 
// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса - Выборка, колонку которой нужно выгрузить в массив.
//  ИмяКолонки - Строка - имя поля коллекции, значения которого нужно выгрузить.
//  ТолькоУникальныеЗначения - Булево - если Истина, то в массив будут включены только различающиеся значения.
// 
// Возвращаемое значение:
//  Массив Из Произвольный - значения колонки.
Функция ВыбратьКолонку(Выборка, ИмяКолонки, ТолькоУникальныеЗначения = Ложь) Экспорт

	Результат = Новый Массив; // Массив Из Произвольный
	
	Пока Выборка.Следующий() Цикл
		
		Значение = Выборка[ИмяКолонки]; // Произвольный
				
		Если ТолькоУникальныеЗначения Тогда
			
			Если Результат.Найти(Значение) = Неопределено Тогда
				//@skip-check typed-value-adding-to-untyped-collection
				Результат.Добавить(Значение);
			КонецЕсли;
			
		Иначе
			//@skip-check typed-value-adding-to-untyped-collection
			Результат.Добавить(Значение);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

