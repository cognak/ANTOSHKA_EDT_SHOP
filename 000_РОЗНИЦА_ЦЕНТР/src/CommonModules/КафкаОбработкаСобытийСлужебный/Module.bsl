// Получить дополнительные свойства.
// 
// Параметры:
//  Источник - СправочникОбъект, ПланВидовХарактеристикОбъект, БизнесПроцессОбъект, ПланОбменаОбъект, ДокументОбъект, ПланВидовРасчетаОбъект, ЗадачаОбъект, ПланСчетовОбъект, РегистрСведенийНаборЗаписей - Источник
// 
// Возвращаемое значение:
//  Структура - Получить дополнительные свойства
Функция ПолучитьДополнительныеСвойства(Источник)
	
	Результат = Новый Структура;
	
	Для Каждого Свойство Из Источник.ДополнительныеСвойства Цикл
		
		Если Свойство.Значение = Неопределено Тогда
			Результат.Вставить(Свойство.Ключ, Неопределено);
			
		Иначе
			ТЗначение = ТипЗнч(Свойство.Значение);
			ТЗначениеXML = СериализаторXDTO.XMLТипЗнч(Свойство.Значение);
			Если ТЗначение = Тип("Структура") Или ТЗначение = Тип("ФиксированнаяСтруктура")
				 Или ТЗначение = Тип("Соответствие") Или ТЗначение = Тип("ФиксированноеСоответствие")
				 Или ТЗначение = Тип("Массив") Или ТЗначение = Тип("ФиксированныйМассив")
				 Или ТЗначение = Тип("ТаблицаЗначений") Или ТЗначение = Тип("ДеревоЗначений") Тогда
				
				Попытка
					
					ОбщегоНазначения.ЗначениеВСтрокуXML(Свойство.Значение);
					
					Результат.Вставить(Свойство.Ключ, Свойство.Значение);
					
				Исключение
					Продолжить;
				КонецПопытки;
				
			ИначеЕсли ТЗначениеXML <> Неопределено
					И Не (ПустаяСтрока(ТЗначениеXML.URIПространстваИмен) Или ПустаяСтрока(ТЗначениеXML.ИмяТипа)) Тогда
				Результат.Вставить(Свойство.Ключ, Свойство.Значение);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
