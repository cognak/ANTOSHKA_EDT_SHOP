#Область СлужебныйПрограммныйИнтерфейс

// Параметры регистрации.
// 
// Параметры:
//  Продюсеры - Неопределено, СправочникСсылка.КафкаПродюсеры, Массив Из СправочникСсылка.КафкаПродюсеры - Ссылка на продюсер
//  ПакетныйРежимЗаписи - Булево - Если Истина, то инициализируется "ОчередьИсходящих". По завершении необходимо вызвать ЗавершитьРегистрацию(Параметры)
// 
// Возвращаемое значение:
//  Структура - Параметры регистрации:
// * Продюсеры - Неопределено, Массив Из СправочникСсылка.КафкаПродюсеры - Ссылка на продюсер 
// * ОчередьИсходящих - Неопределено, РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения - Очередь исходящих, см. ЗавершитьРегистрацию
Функция ПараметрыРегистрации(Продюсеры = Неопределено, ПакетныйРежимЗаписи = Ложь) Экспорт
	
	Результат = Новый Структура;
	
	Если ТипЗнч(Продюсеры) = Тип("Массив") Тогда
		Результат.Вставить("Продюсеры", Продюсеры);
		
	ИначеЕсли ЗначениеЗаполнено(Продюсеры) Тогда
		Результат.Вставить("Продюсеры", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Продюсеры));
		
	Иначе
		 Результат.Вставить("Продюсеры", Неопределено);
	КонецЕсли;
	
	Результат.Вставить("ОчередьИсходящих", ?(ПакетныйРежимЗаписи,
		КафкаОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.КафкаИсходящиеСообщения), Неопределено));
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Завершает пакетную регистрацию.
// 
// Параметры:
//  Параметры - Структура - Параметры регистрации, см. ПараметрыРегистрации:
//	 * Продюсеры - Неопределено, Массив Из СправочникСсылка.КафкаПродюсеры - Ссылка на продюсер 
//	 * ОчередьИсходящих - Неопределено, РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения - Очередь исходящих, см. ЗавершитьРегистрацию
//	ОчиститьОчередь - Булево - Очистить очередь исходящих
Процедура ЗавершитьРегистрацию(Параметры, ОчиститьОчередь = Ложь) Экспорт
	
	ОчередьИсходящих = Параметры.ОчередьИсходящих;
	Если Не ОчередьИсходящих = Неопределено И ОчередьИсходящих.Количество() > 0 Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ОчередьИсходящих.Записать(Истина);
		Если ОчиститьОчередь = Истина Тогда
			ОчередьИсходящих.Очистить();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

