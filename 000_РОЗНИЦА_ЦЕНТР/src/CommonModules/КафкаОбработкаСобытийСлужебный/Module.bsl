КонецФункции

// Помещает данные в очередь исходящих сообщений.
// 
// Параметры:
//  Источник - ЛюбаяСсылка - Ссылка на объект, подлежащий выгрузке;
//  		 - СправочникОбъект, ДокументОбъект, ПланВидовХарактеристикОбъект, ПланВидовРасчетаОбъект, ПланСчетовОбъект, БизнесПроцессОбъект, ЗадачаОбъект, ПланОбменаОбъект - Объект, подлежащий выгрузке;
//			 - РегистрСведенийНаборЗаписей - Набор записей регистра сведений, подлежащий выгрузке;
//			 - Структура, Соответствие Из Произвольный - произвольное сообщение
//			 - Структура - Описание сообщения, см. КафкаИнтеграция.ПараметрыСообщения() 
//	СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
//	ТипОбъект - Строка - Тип объект, подлежащий выгрузке.
//	ЭтоУдаление - Булево - Это удаление
//	ПараметрыРегистрации - Структура - Параметры регистрации, см. ПараметрыРегистрации:
//	 * Продюсеры - Неопределено, Массив Из СправочникСсылка.КафкаПродюсеры - Ссылка на продюсер 
//	 * ОчередьИсходящих - Неопределено, РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения - Очередь исходящих
//	Очередь - Неопределено, РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения - Очередь исходящие сообщений. 
//@skip-check method-too-many-params
Процедура ПоместитьВОчередьИсходящих(Источник, СобытиеРегистрации, ТипОбъект = "", ЭтоУдаление = Ложь, ПараметрыРегистрации = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ТипЗнч(Источник) = Тип("Структура") Или ТипЗнч(Источник) = Тип("Соответствие") Тогда // произвольное сообщение
		Если ПустаяСтрока(ТипОбъект) Тогда
			ВызватьИсключение НСтр("ru = 'В произвольном режиме необходимо явно указать тип объекта!'");
		КонецЕсли;
		
		Продюсеры = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыРегистрации, "Продюсеры");
		Если Продюсеры = Неопределено Тогда
			//@skip-check dynamic-access-method-not-found
			Продюсеры = ПродюсерыОбъектаИнтеграции(ТипОбъект); // ФиксированныйМассив Из СправочникСсылка.КафкаПродюсеры
		КонецЕсли;
		Если Продюсеры = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Очередь = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыРегистрации, "ОчередьИсходящих");
		ОчередьИсходящих = ?(Очередь = Неопределено,
			КафкаОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.КафкаИсходящиеСообщения), Очередь); // РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения
		
		//@skip-check invocation-parameter-type-intersect
		ПоместитьВОчередьИсходящихПроизвольноеСообщение(Источник, СобытиеРегистрации, ТипОбъект, Продюсеры, ОчередьИсходящих);
		
		Если Очередь = Неопределено И ОчередьИсходящих.Количество() > 0 Тогда
			ОчередьИсходящих.Записать(Истина);
		КонецЕсли;
		
	Иначе
		ТипЗнчXML = СериализаторXDTO.XMLТипЗнч(Источник);
		Если ТипЗнчXML = Неопределено
				Или ТипЗнчXML.URIПространстваИмен <> "http://v8.1c.ru/8.1/data/enterprise/current-config" Тогда // проверка на тип конфигурации
			Возврат;
		КонецЕсли;
		ТипОбъектXML = ТипЗнчXML.ИмяТипа;
		
		ОбъектМД = Источник.Метаданные();
		Если ПустаяСтрока(ТипОбъект) Тогда
			ТипОбъект = ОбъектМД.ПолноеИмя();
		КонецЕсли;
		
		Продюсеры = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыРегистрации, "Продюсеры");
		Если Продюсеры = Неопределено Тогда
			Продюсеры = ПродюсерыОбъектаИнтеграции(ТипОбъект); // ФиксированныйМассив Из СправочникСсылка.КафкаПродюсеры
		КонецЕсли;
		Если Продюсеры = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Очередь = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыРегистрации, "ОчередьИсходящих");
		ОчередьИсходящих = ?(Очередь = Неопределено,
			КафкаОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.КафкаИсходящиеСообщения), Очередь); // РегистрСведенийНаборЗаписей.КафкаИсходящиеСообщения
		
		ИмяБазовогоТипа = СтрРазделить(ТипОбъектXML, ".")[0];
		Если СтрЗаканчиваетсяНа(ИмяБазовогоТипа, "Object") Или СтрЗаканчиваетсяНа(ИмяБазовогоТипа, "Ref") Тогда // ссылочный тип
			ПоместитьВОчередьИсходящихСсылочногоТипа(Источник, ЭтоУдаление, СобытиеРегистрации, ТипОбъектXML,
				Продюсеры, ТипОбъект, ОчередьИсходящих);
			
		ИначеЕсли ИмяБазовогоТипа = "InformationRegisterRecordSet"
				И ОбъектМД.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.Независимый Тогда // регистр сведений
			ПоместитьВОчередьИсходящихНезависимыйРегистр(Источник, ЭтоУдаление, ОбъектМД, СобытиеРегистрации,
				ТипОбъектXML, Продюсеры, ТипОбъект, ОчередьИсходящих);
			
		ИначеЕсли ИмяБазовогоТипа = "InformationRegisterRecordSet"
					И ОбъектМД.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору 
				Или ИмяБазовогоТипа = "AccumulationRegisterRecordSet" // регистр накопления
				Или ИмяБазовогоТипа = "AccountingRegisterRecordSet" // регистр бухгалтерии
				Или ИмяБазовогоТипа = "CalculationRegisterRecordSet" Тогда // регистр расчета
			ПоместитьВОчередьИсходящихПодчиненныйРегистр(Источник, ЭтоУдаление, ОбъектМД, СобытиеРегистрации,
				ТипОбъектXML, Продюсеры, ТипОбъект, ОчередьИсходящих);
			
		КонецЕсли;
		
		Если Очередь = Неопределено И ОчередьИсходящих.Количество() > 0 Тогда
			ОчередьИсходящих.Записать(Истина);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает уникальный ключ объекта, который используется в исходящих сообщениях для идентификации объекта.
// 
// Параметры:
//	Данные - ЛюбаяСсылка, СправочникОбъект, ДокументОбъект, РегистрСведенийКлючЗаписи, РегистрНакопленияКлючЗаписи - Данные для регистрации.
//	HexСтрока - Булево - 
// 
// Возвращаемое значение:
//	Неопределено, Строка, ДвоичныеДанные - Ключ объекта
//
Функция КлючОбъекта(Данные, HexСтрока) Экспорт
	
	ТипЗнчXML = СериализаторXDTO.XMLТипЗнч(Данные);
	Если ТипЗнчXML = Неопределено
			Или ТипЗнчXML.URIПространстваИмен <> "http://v8.1c.ru/8.1/data/enterprise/current-config" Тогда // проверка на тип конфигурации
		Возврат Неопределено;
	КонецЕсли;
	ТипОбъектXML = ТипЗнчXML.ИмяТипа;
	ИмяБазовогоТипа = СтрРазделить(ТипОбъектXML, ".")[0];
	
	// Получение ключа объекта
	Если СтрЗаканчиваетсяНа(ИмяБазовогоТипа, "Object") Тогда
		Возврат XMLСтрока(Данные.Ссылка);
		
	ИначеЕсли СтрЗаканчиваетсяНа(ИмяБазовогоТипа, "Ref") Тогда
		Возврат XMLСтрока(Данные);
		
	ИначеЕсли ИмяБазовогоТипа = "InformationRegisterRecordKey"
			И Данные.Метаданные().РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.Независимый Тогда
		ПоляОтбора = СтрСоединить(КафкаОбщегоНазначенияСлужебный.КлючиРегистра(Данные.Метаданные()), ",");
		Отбор = Новый Структура(ПоляОтбора);
		ЗаполнитьЗначенияСвойств(Отбор, Данные);
		СтрокаXML = ОбщегоНазначения.ЗначениеВСтрокуXML(Отбор);
		ХешОбъекта = Новый ХешированиеДанных(ХешФункция.SHA256);
		ХешОбъекта.Добавить(СтрокаXML);
		Возврат ?(HexСтрока, ПолучитьHexСтрокуИзДвоичныхДанных(ХешОбъекта.ХешСумма), ХешОбъекта.ХешСумма);
		
	ИначеЕсли ИмяБазовогоТипа = "InformationRegisterRecordKey"
			И Данные.Метаданные().РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору 
		Или ИмяБазовогоТипа = "AccumulationRegisterRecordKey" // регистр накопления
		Или ИмяБазовогоТипа = "AccountingRegisterRecordKey" // регистр бухгалтерии
		Или ИмяБазовогоТипа = "CalculationRegisterRecordKey" Тогда // регистр расчета
		СтрокаXML = ОбщегоНазначения.ЗначениеВСтрокуXML(Данные.Регистратор);
		ХешОбъекта = Новый ХешированиеДанных(ХешФункция.SHA256);
		ХешОбъекта.Добавить(СтрокаXML);
		Возврат ?(HexСтрока, ПолучитьHexСтрокуИзДвоичныхДанных(ХешОбъекта.ХешСумма), ХешОбъекта.ХешСумма);
		
	Иначе // неизвестный тип
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает ключи записей исходящих сообщений для данных.
// 
// Параметры:
//  Данные - ЛюбаяСсылка, СправочникОбъект, ДокументОбъект, РегистрСведенийКлючЗаписи, РегистрНакопленияКлючЗаписи - Данные для регистрации.
// 
// Возвращаемое значение:
//  Неопределено, Массив Из Строка - Ключи записей исходящих сообщений
Функция КлючЗаписиИсходящихСообщений(Данные) Экспорт
	
	КлючОбъекта = КлючОбъекта(Данные, Ложь);
	Если КлючОбъекта = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипОбъект = Метаданные.НайтиПоТипу(ТипЗнч(Данные)).ПолноеИмя();
	
	Результат = Новый Массив; // Массив Из Строка
	Запрос = Новый Запрос("ВЫБРАТЬ Ссылка ИЗ Справочник.КафкаПродюсеры.ОбъектыМетаданных ГДЕ ТипОбъект = &ТипОбъект");
	Запрос.УстановитьПараметр("ТипОбъект", ТипОбъект);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Хеш = Новый ХешированиеДанных(ХешФункция.SHA256);
		Хеш.Добавить(XMLСтрока(Выборка[0]));
		Хеш.Добавить(НРег(ТипОбъект));
		Хеш.Добавить(КлючОбъекта);
		КлючЗаписи = ПолучитьHexСтрокуИзДвоичныхДанных(Хеш.ХешСумма);
		
		Результат.Добавить(КлючЗаписи);
		
	КонецЦикла;
	
	Возврат ?(Результат.Количество() = 0, Неопределено, Результат);
	
КонецФункции

#Область ОбработчикиПодписок

// Обработчик подписки события "ЗарегистрироватьИзмененияПриЗаписи"
// 
// Параметры:
//  Источник - СправочникОбъект, ПланВидовХарактеристикОбъект, БизнесПроцессОбъект, ПланОбменаОбъект, ДокументОбъект, ПланВидовРасчетаОбъект, ЗадачаОбъект, ПланСчетовОбъект - Источник
//  Отказ - Булево - Отказ
Процедура ЗарегистрироватьИзмененияПриЗаписи(Источник, Отказ) Экспорт
	
	Если ПропуститьРегистрацию(Источник, Отказ) Тогда
		Возврат;
	КонецЕсли;
	
	ОбработчикРегистрацииПриЗаписи(Источник, Ложь);
	
КонецПроцедуры

// Обработчик подписки события "ЗарегистрироватьИзмененияПередУдалением"
// 
// Параметры:
//  Источник - СправочникОбъект, ПланВидовХарактеристикОбъект, БизнесПроцессОбъект, ПланОбменаОбъект, ДокументОбъект, ПланВидовРасчетаОбъект, ЗадачаОбъект, ПланСчетовОбъект - Источник
//  Отказ - Булево - Отказ
Процедура ЗарегистрироватьИзмененияПередУдалением(Источник, Отказ) Экспорт
	
	Если ПропуститьРегистрацию(Источник, Отказ) Тогда
		Возврат;
	КонецЕсли;
	
	ОбработчикРегистрацииПриЗаписи(Источник, Истина);
	
КонецПроцедуры

// Обработчик подписки события "ЗарегистрироватьИзмененияНабораПриЗаписи"
// 
// Параметры:
//  Источник - РегистрСведенийНаборЗаписей, РегистрНакопленияНаборЗаписей, РегистрБухгалтерииНаборЗаписей - Источник
//  Отказ - Булево - Отказ
//  Замещение - Булево - Замещение
Процедура ЗарегистрироватьИзмененияНабораПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если ПропуститьРегистрацию(Источник, Отказ) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоУдаление = (Источник.Количество() = 0); // Булево
	ОбработчикРегистрацииПриЗаписи(Источник, ЭтоУдаление);
	
КонецПроцедуры

// Обработчик подписки события "ЗарегистрироватьИзмененияНабораРасчетаПриЗаписиПередЗаписью"
// 
// Параметры:
//	Источник - РегистрРасчетаНаборЗаписей - Источник
//	Отказ - Булево - Отказ
//	Замещение - Булево - Замещение
//	ТолькоЗапись - Булево - Только запись
//	ЗаписьФактическогоПериодаДействия - Булево - Запись фактического периода действия
//	ЗаписьПерерасчетов - Булево - Запись перерасчетов
Процедура ЗарегистрироватьИзмененияНабораРасчетаПриЗаписиПередЗаписью(Источник, Отказ, Замещение, ТолькоЗапись,
		ЗаписьФактическогоПериодаДействия, ЗаписьПерерасчетов) Экспорт
	
	Если ПропуститьРегистрацию(Источник, Отказ) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоУдаление = Источник.Количество() = 0; // Булево
	ОбработчикРегистрацииПриЗаписи(Источник, ЭтоУдаление);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Продюсеры по ключу.
// 
// Параметры:
//	Ключ - Строка - Ключ
// 
// Возвращаемое значение:
//	Неопределено, ФиксированныйМассив Из СправочникСсылка.КафкаПродюсеры - Продюсеры
Функция ПродюсерыОбъектаИнтеграции(Ключ)
	Возврат КафкаИнтеграцияСлужебныйПовтИсп.ОбъектыИнтеграции().Получить(Ключ);
КонецФункции

// Пропустить регистрацию.
// 
// Параметры:
//	Источник - СправочникОбъект, ДокументОбъект, РегистрСведенийНаборЗаписей, РегистрРасчетаНаборЗаписей - Источник
//	Отказ - Булево - Отказ
// 
// Возвращаемое значение:
//	Булево - Пропустить регистрацию
Функция ПропуститьРегистрацию(Источник, Отказ)
	
	ДополнительныеСвойства = Источник.ДополнительныеСвойства; // Структура
	
	Возврат Отказ
		Или ДополнительныеСвойства.Свойство("кфкПропуститьРегистрацию")
		Или ДополнительныеСвойства.Свойство("ОтключитьМеханизмРегистрацииОбъектов")
		Или ДополнительныеСвойства.Свойство("НеВыполнятьКонтрольУдаляемых")
		Или ДополнительныеСвойства.Свойство("СкрытиеКонфиденциальнойИнформации")
		Или ПродюсерыОбъектаИнтеграции(Источник.Метаданные().ПолноеИмя()) = Неопределено
		Или Не ПолучитьФункциональнуюОпцию("кфкИспользоватьИнтеграцию");
	
КонецФункции

// Обработчик событий "ЗарегистрироватьИзменения*"
// 	см. ЗарегистрироватьИзмененияПриЗаписи
// 	см. ЗарегистрироватьИзмененияНабораПриЗаписи
// 	см. ЗарегистрироватьИзмененияПередУдалением
// 
// Параметры:
//  Источник - СправочникОбъект, ПланВидовХарактеристикОбъект, ДокументОбъект, РегистрСведенийНаборЗаписей, РегистрРасчетаНаборЗаписей - Любой объект или набор записей
//  ЭтоУдаление - Булево - Это удаление
Процедура ОбработчикРегистрацииПриЗаписи(Источник, ЭтоУдаление)
	
	Попытка
		
		ПоместитьВОчередьИсходящих(Источник, Перечисления.кфкСобытияРегистрации.ПриЗаписи, "", ЭтоУдаление);
		
	Исключение
		
		Данные = Неопределено;
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ОбъектМетаданных = Источник.Метаданные();
		Если ОбщегоНазначения.ЭтоОбъектСсылочногоТипа(ОбъектМетаданных) Тогда
			Данные = Источник.Ссылка;
			
		ИначеЕсли ОбщегоНазначения.ЭтоРегистр(ОбъектМетаданных) Тогда
			ТекстОшибки = Строка(Источник.Отбор) + Символы.ПС + Символы.ПС + ТекстОшибки;
			
		КонецЕсли;
		
		ЗаписьЖурналаРегистрации(КафкаОбщегоНазначенияСлужебный.ИмяПодсистемы() + НСтр("ru = '. Регистрация при записи'"),
			УровеньЖурналаРегистрации.Ошибка,
			ОбъектМетаданных,
			Данные,
			ТекстОшибки);
		
	КонецПопытки;
	
КонецПроцедуры

