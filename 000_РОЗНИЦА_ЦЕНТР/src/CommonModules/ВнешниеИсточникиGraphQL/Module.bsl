#Область ПрограммныйИнтерфейс

// Выполняет HTTP-запрос к GraphQL API и возвращает результат

// Отправляет в GraphQL состояние создания заказа в стороннюю систему, выполняя до 5 попыток при ошибке.
//
// Параметры:
//   НомерЗаказа - Строка - номер заказа для идентификации
//   ТекстОшибки - Строка - текст ошибки при создании заказа или пустая строка при успехе
Процедура СостояниеСозданияЗаказа(НомерЗаказа, ТекстОшибки) Экспорт
	
	ЗаказСоздан = ?(ПустаяСтрока(ТекстОшибки), "true", "false");
	
	МакетЗапросов = ПолучитьОбщийМакет("ЗапросыКСтороннимСистемам");

	ОбластьЗапроса = МакетЗапросов.ПолучитьОбласть("Состояние_создания_заказа_GraphQL");
	ОбластьЗапроса.УдалитьСтроку(1);
	ОбластьЗапроса.УдалитьСтроку(ОбластьЗапроса.КоличествоСтрок());
	
	ТекстGraphQL = ОбластьЗапроса.ПолучитьТекст();
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#number#" , СокрЛП(НомерЗаказа));
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#success#" , ЗаказСоздан);
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#error_text#" , ТекстОшибки);
	ДанныеЗапроса = Новый Структура("query", ТекстGraphQL);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();

	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДата;
	НастройкиJSON.ФорматСериализацииДаты = ФорматДатыJSON.ISO;

	ЗаписатьJSON(ЗаписьJSON, ДанныеЗапроса, НастройкиJSON);

	ТекстЗапроса = ЗаписьJSON.Закрыть();
	
	Для Итерация = 1 По 5 Цикл
		
		Результат = ВыполнитьЗапросДляGraphQL(ТекстЗапроса);

		Если Не Результат.Ошибка Тогда
			Прервать;
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.Пауза(1);
			
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

//2026-06-05 sa посылает статус заказа в М2. (Событие тригерится во время отправки статуса заказа в е-спутник)
//Данные в Е-Спутник отправляются в таком виде:
//	{
//		"eventTypeKey": "order_new",
//		"keyValue": "200625472",
//		"params": [
//		{
//			"phone": "380931033310",
//			"externalCustomerId": "cffe9c1b-ba8c-11ef-92dc-001dd8b731f3",
//			"externalOrderId": "200625472",
//			"CustomerId": "Анастасія",
//			"numTTN": "",
//			"shopAddress": "м. Київ, вул. Кільцева, 1",
//			"skus": "5943643"
//		}
//		]
//	}
Процедура ОтправитьСтатусЗаказа(ТекстЗапросаЕСпутник) Экспорт


	//если что-то пошло не так, не мучаем попу.
	Если Не ЗначениеЗаполнено(ТекстЗапросаЕСпутник) Тогда
		Возврат;
	КонецЕсли;
	
	
	//преобразуем его в формат GraphQL
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ТекстЗапросаЕСпутник);
	ДанныеПеременных = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();   
	
	Если ДанныеПеременных.Свойство("keyValue") Тогда
		//запрос пришел от метода ЕСпутникСервер.ВыгрузкаЕСпутникСобытия_V3()
		НомерЗаказа = ДанныеПеременных.keyValue;                             
		СтатусЗаказа = ДанныеПеременных.eventTypeKey;
	ИначеЕсли ДанныеПеременных.Свойство("params") И ДанныеПеременных.params.Количество()>0 И ДанныеПеременных.params[0].Свойство("externalOrderId") Тогда
		Попытка 
			ЗаказСсылка = Документы.ЗаказПокупателя.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеПеременных.params[0].externalOrderId));
			Если Найти(ВРЕГ(ЗаказСсылка),"ОБЪЕКТ НЕ НАЙДЕН")>0 Тогда
				ЗаписьЖурналаРегистрации("Ошибка отправки статуса в M2", УровеньЖурналаРегистрации.Ошибка,,, "Ошибка: не определено номер заказа");
				Возврат;	//это не заказ или мусор. Выходим.	
			Иначе
				НомерЗаказа = ЗаказСсылка.Номер;              
				Если ДанныеПеременных.params[0].Свойство("status") Тогда
					СтатусЗаказа = ДанныеПеременных.params[0].status; 
				Иначе
					ЗаписьЖурналаРегистрации("Ошибка отправки статуса в M2", УровеньЖурналаРегистрации.Ошибка,,, "Ошибка: отсутствует поле status в запросе: "+ТекстЗапросаЕСпутник);
					Возврат;
				КонецЕсли;
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации("Ошибка отправки статуса в M2", УровеньЖурналаРегистрации.Ошибка,,, "Ошибка: "+ОписаниеОшибки());
			Возврат;
		КонецПопытки;
	КонецЕсли;
	

	МакетЗапросов = ПолучитьОбщийМакет("ЗапросыКСтороннимСистемам");

	Схема_ = МакетЗапросов.ПолучитьОбласть("Статус_заказа_М2");
	Схема_.УдалитьСтроку(1);
	Схема_.УдалитьСтроку(Схема_.КоличествоСтрок());
	
	ТекстGraphQL = Схема_.ПолучитьТекст();
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#number#" , СокрЛП(НомерЗаказа));
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#success#" , "true");
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#error_text#" , ""); 
	ТекстGraphQL = СтрЗаменить(ТекстGraphQL, "#order_1c_status#" , СтатусЗаказа);	
	ДанныеЗапроса = Новый Структура("query", ТекстGraphQL);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();

	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДата;
	НастройкиJSON.ФорматСериализацииДаты = ФорматДатыJSON.ISO;

	ЗаписатьJSON(ЗаписьJSON, ДанныеЗапроса, НастройкиJSON);
	
	ТекстЗапросаМ2 = ЗаписьJSON.Закрыть();
	
	//Сообщить(""+ТекстЗапросаМ2);
	//по аналогии с другими запросами делаем 5 попыток
	Для Итерация = 1 По 5 Цикл
		
		Результат = ВыполнитьЗапросДляGraphQL(ТекстЗапросаМ2);

		Если Не Результат.Ошибка Тогда
			Прервать;
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.Пауза(1);
			
	КонецЦикла;
	
	
КонецПроцедуры 


#Область СлужебныйПрограммныйИнтерфейс

// Выполняет HTTP-запрос к GraphQL API и возвращает результат
//
// Параметры:
//   ТекстЗапроса - Строка - текст запроса в формате JSON
//
// Возвращаемое значение:
//   Структура:
//     * ОписаниеОшибки - Строка - описание ошибки или пустая строка
//     * Ошибка - Булево - признак возникновения ошибки
//     * КодОтвета - Число - код состояния HTTP
//     * ТекстJSON - Строка - ответ сервера в формате JSON
Функция ВыполнитьЗапросДляGraphQL(ТекстЗапроса) Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ОписаниеОшибки", "");
	Результат.Вставить("Ошибка", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТекстJSON", "");

	Попытка

	//	Выполняем подключение к серверу "https://graphql.awdev.pro/graphql"...
		Заголовки = Новый Соответствие;
		Если Константы.ИдентификаторУчетнойСистемы.Получить() = "ANTOSHKA" Тогда
			
			Заголовки.Вставить("Authorization", "Bearer Ku7LWeWNrJrD9UtdNs7Ur269om3Yg4anLl4rA6Ip");
			Заголовки.Вставить("Content-Type" , "application/json");
			HTTP = Новый HTTPСоединение("graphql.awdev.pro", 443,,,, 60, Новый ЗащищенноеСоединениеOpenSSL);
			
		Иначе
			
			Заголовки.Вставить("Authorization", "Bearer g0Xfuv2FfSHquzHEYBamB9PHmpDbC4EfwIr5RRxU");
			Заголовки.Вставить("Content-Type" , "application/json");
			HTTP = Новый HTTPСоединение("m2testredwood.antoshka.ua", 443,,,, 60, Новый ЗащищенноеСоединениеOpenSSL);
			
		КонецЕсли;

		Попытка

			HTTPЗапрос = Новый HTTPЗапрос("/graphql", Заголовки);
			HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);

			HTTPОтвет = HTTP.ОтправитьДляОбработки(HTTPЗапрос);
			Результат.ТекстJSON = HTTPОтвет.ПолучитьТелоКакСтроку();

			Результат.КодОтвета = HTTPОтвет.КодСостояния;
			ДанныеRFC2616 = СервисыСерверПовтИсп.КодыRFC2616(HTTPОтвет.КодСостояния);

			Результат.Ошибка = НЕ Результат.КодОтвета = 200;
			Результат.ОписаниеОшибки = Формат(Результат.КодОтвета, "ЧДЦ=; ЧН=000; ЧГ=") + Символы.ПС + ДанныеRFC2616.Описание;

		Исключение

			Результат.Ошибка = Истина;
			Результат.ОписаниеОшибки = "помилка надсилання повідомлення: " + ОписаниеОшибки();

		КонецПопытки;	 

	Исключение

		Результат.Ошибка = Истина;
		Результат.ОписаниеОшибки = "помилка при підключенні до сервера: " + ОписаниеОшибки();

	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти
