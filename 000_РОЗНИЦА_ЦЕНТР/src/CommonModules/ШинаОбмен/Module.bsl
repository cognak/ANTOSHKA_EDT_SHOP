
#Область ПрограммныйИнтерфейс

// Выполняет отправку сообщений из регистра сведений в Kafka через поток продюсера.
//
// Параметры:
//   НомерПотока - Число - номер потока для формирования имени продюсера и отбора сообщений
Процедура ЗаданиеВыполнитьОбмен(НомерПотока) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВсегоВыполнения = 0;
	ПустыхВыполнений = 0;
	
	ИмяПродюсера = "ExchangeStream" + Формат(НомерПотока, "ЧЦ=3; ЧВН=; ЧГ=0;");
	Продюсер = Справочники.КафкаПродюсеры.НайтиПоНаименованию(ИмяПродюсера);
	
	Если Продюсер.Пустая() Тогда
		ВызватьИсключение СтрШаблон("Не найден продюсер с именем: %1", ИмяПродюсера);
	КонецЕсли;
	
	ИмяТопика = "ExchangeStream";
	Сессии = Новый Соответствие();

	Пока Истина Цикл

		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	КафкаИсходящиеСообщения.ВремяСоздания КАК ВремяСоздания,
			|	КафкаИсходящиеСообщения.УникальныйИдентификатор КАК УникальныйИдентификатор,
			|	КафкаИсходящиеСообщения.НомерПотока КАК НомерПотока,
			|	КафкаИсходящиеСообщения.СсылкаДляВыгрузки КАК СсылкаДляВыгрузки,
			|	КафкаИсходящиеСообщения.ОтборДляВыгрузки КАК ОтборДляВыгрузки,
			|	КафкаИсходящиеСообщения.ПолноеНаименованиеОбъектаВыгрузки КАК ПолноеНаименованиеОбъектаВыгрузки,
			|	КафкаИсходящиеСообщения.ДанныеВыгрузки КАК ДанныеВыгрузки,
			|	КафкаИсходящиеСообщения.СтатусВыгрузки КАК СтатусВыгрузки
			|ИЗ
			|	РегистрСведений.КафкаИсходящиеСообщения КАК КафкаИсходящиеСообщения
			|ГДЕ
			|	КафкаИсходящиеСообщения.НомерПотока = &НомерПотока
			|	И КафкаИсходящиеСообщения.СтатусВыгрузки = ЗНАЧЕНИЕ(Перечисление.КафкаСтатус.Новый)";
		
		Запрос.УстановитьПараметр("НомерПотока", НомерПотока);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Количество() = 0 Тогда
			ПустыхВыполнений = ПустыхВыполнений + 1;
		Иначе
			ПустыхВыполнений = 0;
		КонецЕсли;
		
		Пока Выборка.Следующий() Цикл
			
			СтруктураЗаписи = РегистрыСведений.КафкаИсходящиеСообщения.СтруктураЗаписи();
			ЗаполнитьЗначенияСвойств(СтруктураЗаписи, Выборка);
			
			Сообщение = КафкаИнтеграция.ПараметрыСообщения(Выборка.ДанныеВыгрузки
				, Строка(Выборка.УникальныйИдентификатор));

			РезультатОтправки = КафкаИнтеграцияСлужебный.Отправить(Продюсер
				, ИмяТопика
				, Сообщение
				, НомерПотока - 1
				, Сессии);
				
			Если РезультатОтправки.Успешно Тогда
				
				СтруктураЗаписи.СтатусВыгрузки = Перечисления.КафкаСтатус.Выгружен;
				
			Иначе
				
				СтруктураЗаписи.ТекстОшибки = РезультатОтправки.ТекстОшибки;
				СтруктураЗаписи.СтатусВыгрузки = Перечисления.КафкаСтатус.Ошибка;
				
			КонецЕсли;
			
			РегистрыСведений.КафкаИсходящиеСообщения.ЗаписатьИзменениеСтатуса(СтруктураЗаписи);

		КонецЦикла;

		ВсегоВыполнения = ВсегоВыполнения + 1;
		
		Если ВсегоВыполнения >= 100 Или ПустыхВыполнений >= 5 Тогда
			Прервать;
		КонецЕсли;

	КонецЦикла;
	
	КафкаИнтеграцияСлужебный.ЗакрытьСессииПродюсера(Сессии);

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ШинаДанных() Экспорт
	
	КоличествоПотоков = Константы.КоличествоПотоковШина.Получить();
		
	Если КоличествоПотоков = 0 Тогда
		Возврат;
	КонецЕсли;

	Для НомерПотока = 1 По КоличествоПотоков Цикл
		
		НаименованиеПотокаОтправки = "ПотокОтправки" + НомерПотока;		
		Отбор = Новый Структура("Наименование", НаименованиеПотокаОтправки);
		ФоновыеЗаданияПотока = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		
		ЗаданиеСуществует = Ложь;
		Для Каждого ФоновоеЗадание Из ФоновыеЗаданияПотока Цикл
			Если ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
				ЗаданиеСуществует = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если Не ЗаданиеСуществует Тогда
			
			ПараметрыЗадания = Новый Массив;
			ПараметрыЗадания.Добавить(НомерПотока);
			
			ФоновыеЗадания.Выполнить(
				"ШинаОбмен.ЗаданиеВыполнитьОбмен",
				ПараметрыЗадания,
				НаименованиеПотокаОтправки,
				НаименованиеПотокаОтправки);
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Процедура ПоШинеЗарегистрироватьИзменениеПриЗаписи(Источник, Отказ) Экспорт
	
	ЗарегистрироватьИзмененияДанныхОбъекта(Источник);

КонецПроцедуры

Процедура ПоШинеЗарегистрироватьИзменениеДокументаПриЗаписи(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	ЗарегистрироватьИзмененияДанныхОбъекта(Источник);

КонецПроцедуры

Процедура ПоШинеЗарегистрироватьИзменениеКонстантыПриЗаписи(Источник, Отказ) Экспорт
	
	ЗарегистрироватьИзмененияДанных(Источник);

КонецПроцедуры

Процедура ПоШинеЗарегистрироватьИзменениеНабораЗаписейПередЗаписью(Источник, Отказ, Замещение) Экспорт
	
	ЗарегистрироватьИзмененияДанных(Источник);

КонецПроцедуры

Процедура ПоШинеЗарегистрироватьУдалениеПередУдалением(Источник, Отказ) Экспорт
	
	ЗарегистрироватьИзмененияДанныхОбъекта(Источник);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗарегистрироватьИзмененияДанных(Источник)
	
	Если Источник.ДополнительныеСвойства.Свойство("ОтключитьМеханизмРегистрацииОбъектов") Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяИсточника = Метаданные.НайтиПоТипу(ТипЗнч(Источник)).ПолноеИмя();

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КафкаНастройки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КафкаНастройки КАК КафкаНастройки
		|ГДЕ
		|	КафкаНастройки.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", ПолноеИмяИсточника);
	
	Если Не Запрос.Выполнить().Пустой() Тогда

		КоличествоПотоков = Константы.КоличествоПотоковШина.Получить();
		
		Если КоличествоПотоков = 0 Тогда
			Возврат;
		КонецЕсли;
		
		СсылкаНаОбъект = Неопределено;
		ОтборДляВыгрузки = Новый Структура;
		Для Каждого ЭлементОтбора Из Источник.Отбор Цикл
			ОтборДляВыгрузки.Вставить(ЭлементОтбора.Имя, ЭлементОтбора.Значение);
		КонецЦикла;
		ОтборДляВыгрузкиХранилище = Новый ХранилищеЗначения(ОтборДляВыгрузки, Новый СжатиеДанных(9));

		ГСЧ = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
		НомерПотока = ГСЧ.СлучайноеЧисло(1, КоличествоПотоков);
		
		ИсходящиеДанные = РегистрыСведений.КафкаИсходящиеСообщения.СтруктураЗаписи();
		ИсходящиеДанные.УникальныйИдентификатор = Новый УникальныйИдентификатор;
		ИсходящиеДанные.ВремяСоздания = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ИсходящиеДанные.НомерПотока = НомерПотока;
		ИсходящиеДанные.СсылкаДляВыгрузки = СсылкаНаОбъект;
		ИсходящиеДанные.ОтборДляВыгрузки = ОтборДляВыгрузкиХранилище;
		ИсходящиеДанные.ПолноеНаименованиеОбъектаВыгрузки = ПолноеИмяИсточника;
		ИсходящиеДанные.СтатусВыгрузки = Перечисления.КафкаСтатус.Новый;
		КафкаИнтеграция.ПодготовитьСообщение(Источник, ИсходящиеДанные);
		РегистрыСведений.КафкаИсходящиеСообщения.ДобавитьЗаписьРегистра(ИсходящиеДанные);

	КонецЕсли;
//	
КонецПроцедуры

Процедура ЗарегистрироватьИзмененияДанныхОбъекта(Источник)
	
	Если Источник.ДополнительныеСвойства.Свойство("ОтключитьМеханизмРегистрацииОбъектов") Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяИсточника = Метаданные.НайтиПоТипу(ТипЗнч(Источник)).ПолноеИмя();

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КафкаНастройки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КафкаНастройки КАК КафкаНастройки
		|ГДЕ
		|	КафкаНастройки.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", ПолноеИмяИсточника);
	
	Если Не Запрос.Выполнить().Пустой() Тогда

		КоличествоПотоков = Константы.КоличествоПотоковШина.Получить();
		
		Если КоличествоПотоков = 0 Тогда
			Возврат;
		КонецЕсли;

		ОтборДляВыгрузкиХранилище = "";
		СсылкаНаОбъект = Источник.Ссылка;

		ГСЧ = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
		НомерПотока = ГСЧ.СлучайноеЧисло(1, КоличествоПотоков);
		
		ИсходящиеДанные = РегистрыСведений.КафкаИсходящиеСообщения.СтруктураЗаписи();
		ИсходящиеДанные.УникальныйИдентификатор = СсылкаНаОбъект.УникальныйИдентификатор();
		ИсходящиеДанные.ВремяСоздания = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ИсходящиеДанные.НомерПотока = НомерПотока;
		ИсходящиеДанные.СсылкаДляВыгрузки = СсылкаНаОбъект;
		ИсходящиеДанные.ОтборДляВыгрузки = ОтборДляВыгрузкиХранилище;
		ИсходящиеДанные.ПолноеНаименованиеОбъектаВыгрузки = ПолноеИмяИсточника;
		ИсходящиеДанные.СтатусВыгрузки = Перечисления.КафкаСтатус.Новый;
		КафкаИнтеграция.ПодготовитьСообщение(Источник, ИсходящиеДанные);
		РегистрыСведений.КафкаИсходящиеСообщения.ДобавитьЗаписьОбъекта(ИсходящиеДанные);

	КонецЕсли;
//	
КонецПроцедуры

#КонецОбласти 

