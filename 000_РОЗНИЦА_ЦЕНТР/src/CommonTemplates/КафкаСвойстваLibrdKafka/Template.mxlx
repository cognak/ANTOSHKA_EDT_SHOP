			<c>
				<c>
					<f>18</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>enable.sasl.oauthbearer.unsecure.jwt</v8:content>
						</v8:item>
					</tl>
					<r>714</r>
				</c>
			</c>
			<c>
				<c>
