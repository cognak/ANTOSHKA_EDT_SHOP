// Точки получения сообщений.
// 
// Параметры:
//	Консьюмеры - Массив Из СправочникСсылка.КафкаКонсьюмеры - Консьюмеры
// 
// Возвращаемое значение:
//	Соответствие Из КлючИЗначение - Точки получения сообщений:
//	 * Ключ - СправочникСсылка.КафкаКонсьюмеры - Идентификатор консьюмера
//	 * Значение - Структура - Точка получения сообщений:
//		** АдресБрокера - Строка - Адрес брокера
//		** Идентификатор - Строка - Идентификатор группы консьюмера
//		** Топики - Массив Из Строка - Топики консьюмера
Функция ТочкиПолученияСообщений(Консьюмеры) Экспорт
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Консьюмеры.Ссылка КАК Ссылка,
	|	Консьюмеры.Брокер КАК Брокер,
	|	Консьюмеры.Идентификатор КАК Идентификатор
	|ИЗ
	|	Справочник.КафкаКонсьюмеры КАК Консьюмеры
	|ГДЕ
	|	Консьюмеры.Ссылка В (&Консьюмеры)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонсьюмерыТопики.Ссылка КАК Ссылка,
	|	КонсьюмерыТопики.Топик КАК Топик
	|ИЗ
	|	Справочник.КафкаКонсьюмеры.Топики КАК КонсьюмерыТопики
	|ГДЕ
	|	КонсьюмерыТопики.Ссылка В (&Консьюмеры)
	|ИТОГИ
	|ПО
	|	Ссылка";
	Запрос.УстановитьПараметр("Консьюмеры", Консьюмеры);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	ВыборкаТопики = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДоступныеБрокеры = Справочники.КафкаБрокеры.ДоступныеБрокеры();
	
	// АдресБрокера, Идентификатор
	Пока Выборка.Следующий() Цикл
		
		Брокер = ДоступныеБрокеры.Получить(Выборка.Брокер);
		Если Брокер = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Описание = Новый Структура;
		Описание.Вставить("АдресБрокера", Брокер.АдресБрокера);
		Описание.Вставить("Идентификатор", Выборка.Идентификатор);
		Описание.Вставить("Топики", Новый Массив);
		
		Результат.Вставить(Выборка.Ссылка, Описание);
		
	КонецЦикла;
	
	Пока ВыборкаТопики.Следующий() Цикл
		
		Описание = Результат.Получить(ВыборкаТопики.Ссылка);
		Если Описание = Неопределено Тогда
			Продолжить
		КонецЕсли;
		
		Описание.Топики = ОбщегоНазначения.ВыбратьКолонку(ВыборкаТопики.Выбрать(), "Топик");
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Новое описание консьюмера.
// 
// Возвращаемое значение:
//	Структура - описание консьюмера:
//	 * Ссылка - СправочникСсылка.КафкаКонсьюмеры - Консьюмер 
//	 * Наименование - Строка - Наименование консьюмера
//	 * АдресБрокера - Строка - Адрес брокера
//	 * Идентификатор - Строка - Идентификатор группы
//	 * ТаймаутОжидания - Число - Таймаут ожидания сообщений
//	 * ДвоичныеДанные - Булево - Получать сообщения двоичными данными
//	 * Топики - Массив Из Строка - Топики
//	 * ПараметрыПодключения - Соответствие Из КлючИЗначение - Параметры подключения брокера и консьюмера:
//		** Ключ - Строка - Имя параметра
//		** Значение - Строка - Значение параметра
Функция НовоеОписаниеКонсьюмера()
	
	Результат = Новый Структура;
	Результат.Вставить("Ссылка", ПустаяСсылка());
	Результат.Вставить("Наименование", "");
	Результат.Вставить("АдресБрокера", "");
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("ТаймаутОжидания", 0);
	Результат.Вставить("ДвоичныеДанные", Ложь);
	Результат.Вставить("Топики", Новый Массив);
	Результат.Вставить("ПараметрыПодключения", Новый Соответствие);
	
	Возврат Результат;
		
КонецФункции

#КонецОбласти

#КонецЕсли