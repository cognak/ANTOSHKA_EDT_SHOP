// Возвращает описание консьюмера.
// 
// Параметры:
//  Консьюмер - СправочникСсылка.КафкаКонсьюмеры - Консьюмер
// 
// Возвращаемое значение:
//	см. НовоеОписаниеКонсьюмера
Функция ОписаниеКонсьюмера(Консьюмер) Экспорт
	
	Результат = НовоеОписаниеКонсьюмера();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Консьюмеры.Ссылка,
	|	Консьюмеры.Наименование,
	|	Консьюмеры.Брокер,
	|	Консьюмеры.Идентификатор,
	|	Консьюмеры.ТаймаутОжидания,
	|	Консьюмеры.ДвоичныеДанные
	|ИЗ
	|	Справочник.КафкаКонсьюмеры КАК Консьюмеры
	|ГДЕ
	|	Консьюмеры.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонсьюмерыТопики.Топик
	|ИЗ
	|	Справочник.КафкаКонсьюмеры.Топики КАК КонсьюмерыТопики
	|ГДЕ
	|	КонсьюмерыТопики.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонсьюмерыПараметры.Ключ,
	|	КонсьюмерыПараметры.Значение
	|ИЗ
	|	Справочник.КафкаКонсьюмеры.ПараметрыКонсьюмера КАК КонсьюмерыПараметры
	|ГДЕ
	|	КонсьюмерыПараметры.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Консьюмер);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Топики = РезультатЗапроса[1];
	ВыборкаПараметры = РезультатЗапроса[2].Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ДоступныеБрокеры = Справочники.КафкаБрокеры.ДоступныеБрокеры();
		Брокер = ДоступныеБрокеры.Получить(Выборка.Брокер);
		Если Брокер = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		ЗаполнитьЗначенияСвойств(Результат, Брокер, "АдресБрокера,ПараметрыПодключения");
		
		Результат.Топики = Топики.Выгрузить().ВыгрузитьКолонку(0);
		
		Пока ВыборкаПараметры.Следующий() Цикл
			Результат.ПараметрыПодключения.Вставить(ВыборкаПараметры.Ключ, ВыборкаПараметры.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции

