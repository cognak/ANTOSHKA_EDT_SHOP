		Новый Структура("ИмяМетода", Элемент.ТекстРедактирования), ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("ЗавершитьВводаОбработчика", ЭтотОбъект),
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
