&НаКлиенте
Процедура ТопикиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)

	Если Копирование Тогда
		
		Отказ = Истина;
		
		НоваяСтрока = Объект.Топики.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.ТекущиеДанные, , "НомерСтроки,Топик,ИмяПОДДесериализации"); // ИмяМетодаДесериализации
		
		Элементы.Топики.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		Элементы.Топики.ТекущийЭлемент = Элементы.ТопикиТопик;
		Элементы.Топики.ИзменитьСтроку();
		
	КонецЕсли;
	
КонецПроцедуры

