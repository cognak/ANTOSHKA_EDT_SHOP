КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	
	Элементы.ФормаГруппаБлокировка.Доступность = Не Объект.Ссылка.Пустая();
	Элементы.ФормаБлокироватьЧтение.Пометка = Объект.БлокироватьЧтение;
	Элементы.ФормаБлокироватьДесериализацию.Пометка = Объект.БлокироватьДесериализацию;
	
	Элементы.ГруппаДекорацияБлокироватьЧтение.Видимость = Объект.БлокироватьЧтение;
	Элементы.ГруппаДекорацияБлокироватьДесериализацию.Видимость = Объект.БлокироватьДесериализацию;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьСериализации()
	
	// ПроизвольныйОбработчик
	ТипДесериализации = ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.ПроизвольныйОбработчик");
	Строки = Объект.Топики.НайтиСтроки(Новый Структура("ТипДесериализации", ТипДесериализации));
	Элементы.ТопикиИмяМетодаДесериализации.Видимость = Строки.Количество() > 0;
	
	// КонвертацияДанных
	ТипДесериализации = ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.КонвертацияДанных");
	Строки = Объект.Топики.НайтиСтроки(Новый Структура("ТипДесериализации", ТипДесериализации));
	Элементы.ТопикиГруппаДесериализацияКД.Видимость = Строки.Количество() > 0;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПоток(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		Если Результат.Свойство("ИнформацияОбОшибке") И Результат.ИнформацияОбОшибке <> Неопределено Тогда
			СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
			
		ИначеЕсли Не ПустаяСтрока(Результат.ПодробноеПредставлениеОшибки) Тогда // TODO: ИнформацияОбОшибке с БСП 3.1.10
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
			
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не удалось выполнить проверку подключения к брокеру.'"));
		КонецЕсли;
		
		Возврат;
		 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВводаОбработчика(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.Топики.ТекущиеДанные;
	ТекущиеДанные.ИмяМетодаДесериализации = РезультатЗакрытия;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьПравилаОбмена()
	
	ТекущиеДанные = Элементы.Топики.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ПустаяСтрока(ТекущиеДанные.ИмяМодуляДесериализации) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	
	КлючПравилОбмена = ТекущиеДанные.ИмяМодуляДесериализации + ":" + ТекущиеДанные.ФорматДесериализации;
	
	СписокВыбора = Элементы.ТопикиИмяПОДДесериализации.СписокВыбора;
	СписокВыбора.Очистить();
	
	ПОДы = ?(ПравилаОбработкиДанных = Неопределено, Неопределено,
		ПравилаОбработкиДанных.Получить(КлючПравилОбмена)); // Неопределено, Массив
	Если ПОДы = Неопределено Тогда
		
		ПОДы = ДоступныеПОДы(ТекущиеДанные.ФорматДесериализации, ТекущиеДанные.ИмяМодуляДесериализации); // Неопределено, Массив
		
		Правила = ?(ПравилаОбработкиДанных = Неопределено, Новый Соответствие, Новый Соответствие(ПравилаОбработкиДанных));
		Правила.Вставить(КлючПравилОбмена, ПОДы);
		ПравилаОбработкиДанных = Новый ФиксированноеСоответствие(Правила);
		
	КонецЕсли;
	
	Если ТипЗнч(ПОДы) = Тип("Массив") Тогда
		СписокВыбора.ЗагрузитьЗначения(ПОДы);
		
	ИначеЕсли ТекущиеДанные.ТипДесериализации
			= ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.КонвертацияДанных") Тогда
		НомерСтроки = ТекущиеДанные.НомерСтроки;
		ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность",
			НСтр("ru = 'Имя модуля'"), НомерСтроки, НСтр("ru = 'Объекты метаданных'"),
			СтрШаблон(НСтр("ru = '''%1'' - не найден'"), ТекущиеДанные.ИмяМодуляДесериализации));
		Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Топики", НомерСтроки,
			"ИмяМодуляДесериализации");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , Поле, "Объект");
		
	КонецЕсли;
	
КонецПроцедуры

