&НаСервереБезКонтекста
Функция ДоступныеПОДы(XMLСхема, МенеджерОбмена)
	
	Если Метаданные.ОбщиеМодули.Найти(МенеджерОбмена) = Неопределено Тогда
		Возврат МенеджерОбмена + ":" + XMLСхема;
	КонецЕсли;
	
	КомпонентыОбмена = кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена("Получение");
	КомпонентыОбмена.XMLСхема = XMLСхема;
	КомпонентыОбмена.МенеджерОбмена = ОбщегоНазначения.ОбщийМодуль(МенеджерОбмена);
	ПОДы = кфкОбменДаннымиXDTOСервер.ТаблицаПравилОбработкиДанных(КомпонентыОбмена);
	
	Возврат ОбщегоНазначения.ВыгрузитьКолонку(ПОДы, "Имя");
	
КонецФункции

&НаСервере
Процедура ЗаполнитьЗначенияПредставления()
	
	Если СвойстваLibrdKafka = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Строка Из Объект.ПараметрыКонсьюмера Цикл // ТекущийОбъект
		
		Свойство = СвойстваLibrdKafka.Получить(Строка.Ключ); // см. КафкаИнтеграцияСлужебный.НовоеОписаниеСвойстваLibrdKafka
		ТипЗначения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Свойство, "ТипЗначения");
		Строка.ЗначениеПредставление = ?(ТипЗначения = "int" Или ТипЗначения = "float",
			СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Строка.Значение), Строка.Значение);
		
	КонецЦикла;
	
КонецПроцедуры

