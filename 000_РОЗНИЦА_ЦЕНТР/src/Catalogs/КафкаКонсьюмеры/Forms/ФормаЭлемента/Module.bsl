#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗапуститьЧтение(Команда)
	
	ОчиститьСообщения();
	
	Если Модифицированность Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Консьюмер был изменен. Для начала чтения сообщений сохраните настройки.'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗапускДоступен() Тогда
		//@skip-check new-font
		КафкаИнтеграцияСлужебныйКлиент.СообщениеНедоступностиРучногоЗадания();
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ЗапуститьЧтениеНаСервере(Объект.Ссылка, УникальныйИдентификатор);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ЗавершитьПоток", ЭтотОбъект),
		ПараметрыОжидания);
		
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьДесериализацию(Команда)
	
	ОчиститьСообщения();
	
	Если Модифицированность Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Консьюмер был изменен. Для начала десериализации сообщений сохраните настройки.'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗапускДоступен() Тогда
		//@skip-check new-font
		КафкаИнтеграцияСлужебныйКлиент.СообщениеНедоступностиРучногоЗадания();
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ЗапуститьДесериализациюНаСервере(Объект.Ссылка, УникальныйИдентификатор);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ЗавершитьПоток", ЭтотОбъект),
		ПараметрыОжидания);
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтандартныеПараметрыКонсьюмера(Команда)
	
	Объект.ПараметрыКонсьюмера.Очистить();
	
	Для Каждого Параметр Из СтандартныеПараметрыКонсьюмера() Цикл
		НоваяСтрока = Объект.ПараметрыКонсьюмера.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Параметр);
		НоваяСтрока.ЗначениеПредставление = Параметр.Значение;
	КонецЦикла;
	
	Модифицированность = Истина;
	
КонецПроцедуры

