#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// инициализация нового
	Если Объект.Ссылка.Пустая() И Не Объект.РежимАсинх Тогда
		Ключи = ОбщегоНазначения.ВыгрузитьКолонку(Объект.ПараметрыПродюсера, "Ключ");
		Для Каждого ПараметрОтправки Из СтандартныеПараметрыКонсьюмера() Цикл
			Если Ключи.Найти(ПараметрОтправки.Ключ) = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(Объект.ПараметрыПродюсера.Добавить(), ПараметрОтправки);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	// инициализация параметров
	СвойстваLibrdKafka = КафкаИнтеграцияСлужебныйПовтИсп.СвойстваLibrdKafka("P");
	ЗаполнитьЗначенияПредставления();

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ЗаполнитьЗначенияПредставления();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаполнитьЗначенияПредставления();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РежимАсинхПриИзменении(Элемент)
	
	ПараметрыОтправки = СтандартныеПараметрыКонсьюмера();
	
	Ключи = КлючиПараметровПродюсера();
	Для Каждого ПараметрОтправки Из ПараметрыОтправки Цикл
		Если Объект.РежимАсинх Тогда
			ВерхнаяяГраница = Объект.ПараметрыПродюсера.Количество() - 1;
			Для Итератор = 0 по ВерхнаяяГраница Цикл
				Если ПараметрыОтправки.Получить(Объект.ПараметрыПродюсера[ВерхнаяяГраница - Итератор].Ключ) <> Неопределено Тогда
					Объект.ПараметрыПродюсера.Удалить(ВерхнаяяГраница - Итератор);
				КонецЕсли;
			КонецЦикла;
		
		Иначе
			Если Ключи.Найти(ПараметрОтправки.Ключ) = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(Объект.ПараметрыПродюсера.Добавить(), ПараметрОтправки);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

