#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьСтандартныеПараметрыПродюсера(Команда)
	
	Объект.ПараметрыПродюсера.Очистить();
	
	Для Каждого Параметр Из СтандартныеПараметрыКонсьюмера() Цикл
		НоваяСтрока = Объект.ПараметрыПродюсера.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Параметр);
		НоваяСтрока.ЗначениеПредставление = Параметр.Значение;
	КонецЦикла;
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Функция КлючиПараметровПродюсера()
	
	Результат = Новый Массив;
	Для Каждого ПараметрОтправки Из Объект.ПараметрыПродюсера Цикл
		Результат.Добавить(ПараметрОтправки.Ключ);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СтандартныеПараметрыКонсьюмера()
	
//	см. Обработка.КафкаИнтеграция.ОтправитьСообщение()
	
	Результат = Новый Соответствие;
	Результат.Вставить("message.timeout.ms", 5000); // с этим параметром поакуратнее	
	Результат.Вставить("batch.size", 1048576); // с этим параметром поакуратнее	
	Результат.Вставить("batch.num.messages", 10000); // с этим параметром поакуратнее	
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьЗначенияПредставления()
	
	Если СвойстваLibrdKafka = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Строка Из Объект.ПараметрыПродюсера Цикл // ТекущийОбъект
		
		Свойство = СвойстваLibrdKafka.Получить(Строка.Ключ); // см. КафкаИнтеграцияСлужебный.НовоеОписаниеСвойстваLibrdKafka
		ТипЗначения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Свойство, "ТипЗначения");
		Строка.ЗначениеПредставление = ?(ТипЗначения = "int" Или ТипЗначения = "float",
			СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Строка.Значение), Строка.Значение);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти