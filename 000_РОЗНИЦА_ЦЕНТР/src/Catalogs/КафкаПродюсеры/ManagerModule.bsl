// Возвращает топики для указанных продюсеров.
//
// Параметры:
//	Продюсеры - Массив Из СправочникСсылка.КафкаПродюсеры - список ссылок на продюсеров
//
// Возвращаемое значение:
//	Соответствие Из Строка - словарь, где ключ - строка, объединяющая ссылку на продюсер и тип объекта, а значение - имя топика
Функция Топики(Продюсеры) Экспорт
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	кфкПродюсерыОбъектыМетаданных.Ссылка КАК Ссылка,
	|	кфкПродюсерыОбъектыМетаданных.ТипОбъект КАК ТипОбъект,
	|	кфкПродюсерыОбъектыМетаданных.ИмяТопика КАК ИмяТопика
	|ИЗ
	|	Справочник.КафкаПродюсеры.ОбъектыМетаданных КАК кфкПродюсерыОбъектыМетаданных
	|ГДЕ
	|	кфкПродюсерыОбъектыМетаданных.Ссылка В (&Продюсеры)";
	Запрос.УстановитьПараметр("Продюсеры", Продюсеры);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(НРег(XMLСтрока(Выборка.Ссылка) + Выборка.ТипОбъект), Выборка.ИмяТопика);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

