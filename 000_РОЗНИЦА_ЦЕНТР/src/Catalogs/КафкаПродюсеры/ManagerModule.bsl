// Возвращает описание продюсера.
// 
// Параметры:
//  Продюсер - СправочникСсылка.КафкаПродюсеры - Экземпляр продюсера
// 
// Возвращаемое значение:
//  Структура - Описание продюсера:
// * Ссылка - СправочникСсылка.КафкаПродюсеры - Ссылка
// * Наименование - Строка - Наименование
// * АдресБрокера - Строка - Адрес брокера
// * РежимАсинх - Булево - Режим асинхронной отправки
// * ПараметрыПодключения - Соответствие Из Строка - Параметры подключения брокера и продюсера
Функция ОписаниеПродюсера(Продюсер) Экспорт
	
	Результат = НовоеОписаниеПродюсера();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	кфкПродюсеры.Ссылка,
	|	кфкПродюсеры.Наименование,
	|	кфкПродюсеры.Брокер,
	|	кфкПродюсеры.РежимАсинх
	|ИЗ
	|	Справочник.КафкаПродюсеры КАК кфкПродюсеры
	|ГДЕ
	|	кфкПродюсеры.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	кфкПродюсерыПараметрыПродюсера.Ключ,
	|	кфкПродюсерыПараметрыПродюсера.Значение
	|ИЗ
	|	Справочник.КафкаПродюсеры.ПараметрыПродюсера КАК кфкПродюсерыПараметрыПродюсера
	|ГДЕ
	|	кфкПродюсерыПараметрыПродюсера.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Продюсер);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	ВыборкаПараметры = РезультатЗапроса[1].Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ДоступныеБрокеры = Справочники.КафкаБрокеры.ДоступныеБрокеры();
		Брокер = ДоступныеБрокеры.Получить(Выборка.Брокер);
		Если Брокер = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		ЗаполнитьЗначенияСвойств(Результат, Брокер, "АдресБрокера,ПараметрыПодключения");
		
		Пока ВыборкаПараметры.Следующий() Цикл
			Результат.ПараметрыПодключения.Вставить(ВыборкаПараметры.Ключ, ВыборкаПараметры.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции

// Объекты метаданных участвующие в интеграции с Kafka/
// 
// Возвращаемое значение:
//  ФиксированноеСоответствие Из Строка - Объекты интеграции
Функция ОбъектыИнтеграции() Экспорт
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	кфкПродюсерыОбъектыМетаданных.Ссылка КАК Ссылка,
	|	кфкПродюсерыОбъектыМетаданных.ТипОбъект КАК ТипОбъект
	|ИЗ
	|	Справочник.КафкаПродюсеры КАК кфкПродюсеры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КафкаПродюсеры.ОбъектыМетаданных КАК кфкПродюсерыОбъектыМетаданных
	|		ПО кфкПродюсеры.Ссылка = кфкПродюсерыОбъектыМетаданных.Ссылка
	|ГДЕ
	|	кфкПродюсеры.ПометкаУдаления = ЛОЖЬ
	|	И кфкПродюсеры.БлокироватьРегистрацию = ЛОЖЬ
	|ИТОГИ
	|ПО
	|	ТипОбъект";
	ВыборкаОМ = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОМ.Следующий() Цикл
		
		Продюсеры = ОбщегоНазначения.ВыбратьКолонку(ВыборкаОМ.Выбрать(), "Ссылка"); // Массив Из СправочникСсылка.КафкаПродюсеры
		Результат.Вставить(ВыборкаОМ.ТипОбъект, Новый ФиксированныйМассив(Продюсеры));
		
	КонецЦикла;
	
	Возврат Новый ФиксированноеСоответствие(Результат);
	
КонецФункции

