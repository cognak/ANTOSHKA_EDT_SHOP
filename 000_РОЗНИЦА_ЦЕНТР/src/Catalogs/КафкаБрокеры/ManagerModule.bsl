#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает доступные брокеры.
// 
// Возвращаемое значение:
//	Соответствие Из КлючИЗначение - Доступные брокеры:
//	 * Ключ - СправочникСсылка.КафкаБрокеры - Брокер
//	 * Значение см. ПустоеОписаниеБрокера
//
Функция ДоступныеБрокеры() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Новый Соответствие; // Соответствие Из Структура
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Брокеры.Ссылка,
	|	Брокеры.Наименование
	|ИЗ
	|	Справочник.КафкаБрокеры КАК Брокеры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	кфкБрокерыУзлы.Ссылка,
	|	кфкБрокерыУзлы.Адрес
	|ИЗ
	|	Справочник.КафкаБрокеры.Узлы КАК кфкБрокерыУзлы
	|ГДЕ
	|	кфкБрокерыУзлы.Использование = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БрокерыПараметрыПодключения.Ссылка,
	|	БрокерыПараметрыПодключения.Ключ,
	|	БрокерыПараметрыПодключения.Значение
	|ИЗ
	|	Справочник.КафкаБрокеры.ПараметрыПодключения КАК БрокерыПараметрыПодключения
	|ГДЕ
	|	БрокерыПараметрыПодключения.РежимПароля = ЛОЖЬ";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	ВыборкаУзлы = РезультатЗапроса[1].Выбрать();
	ВыборкаПараметры = РезультатЗапроса[2].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Описание = ПустоеОписаниеБрокера();
		ЗаполнитьЗначенияСвойств(Описание, Выборка);
		
		// Узлы
		Узлы = Новый Массив;
		ВыборкаУзлы.Сбросить();
		Пока ВыборкаУзлы.НайтиСледующий(Выборка.Ссылка, "Ссылка") Цикл
			Узлы.Добавить(ВыборкаУзлы.Адрес);
		КонецЦикла;
		Описание.АдресБрокера = СтрСоединить(Узлы, ",");
		
		// Параметры подключения
		ВыборкаПараметры.Сбросить();
		Пока ВыборкаПараметры.НайтиСледующий(Выборка.Ссылка, "Ссылка") Цикл
			Описание.ПараметрыПодключения.Вставить(ВыборкаПараметры.Ключ, ВыборкаПараметры.Значение);
		КонецЦикла;
		
		ДанныеИзБХ = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(Выборка.Ссылка, "ПараметрыПодключения");
		Если Не ДанныеИзБХ = Неопределено Тогда
			Для Каждого КлючЗначение Из ДанныеИзБХ Цикл
				Описание.ПараметрыПодключения.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
			КонецЦикла;
		КонецЕсли;
		
		Результат.Вставить(Описание.Ссылка, Описание);
		
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

// Возвращает адрес брокера
// 
// Параметры:
//	Брокер - СправочникСсылка.КафкаБрокеры - Брокер
// 
// Возвращаемое значение:
//	Строка - Адрес брокера
Функция АдресБрокера(Брокер) Экспорт
	
	Если Не ЗначениеЗаполнено(Брокер) Тогда
		Возврат "";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Адрес ИЗ Справочник.КафкаБрокеры.Узлы ГДЕ Ссылка = &Ссылка И Использование = ИСТИНА";
	Запрос.УстановитьПараметр("Ссылка", Брокер);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат СтрСоединить(ОбщегоНазначения.ВыбратьКолонку(Выборка, "Адрес"), ",");
		
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Пустое описание брокера.
// 
// Возвращаемое значение:
//	Структура - Пустое описание брокера:
//	 * Ссылка - СправочникСсылка.КафкаБрокеры - Брокер
//	 * Наименование - Строка - Наименование брокера
//	 * АдресБрокера - Строка - Адрес брокера
//	 * ПараметрыПодключения - Соответствие Из КлючИЗначение - Параметры подключения:
//		** Ключ - Строка - Имя параметра
//		** Значение - Произвольный - Значение параметра
Функция ПустоеОписаниеБрокера()
	
	Результат = Новый Структура;
	Результат.Вставить("Ссылка", ПустаяСсылка());
	Результат.Вставить("Наименование", "");
	Результат.Вставить("АдресБрокера", "");
	Результат.Вставить("ПараметрыПодключения", Новый Соответствие);
	
	Возврат Результат;
		
КонецФункции

#КонецОбласти

#КонецЕсли