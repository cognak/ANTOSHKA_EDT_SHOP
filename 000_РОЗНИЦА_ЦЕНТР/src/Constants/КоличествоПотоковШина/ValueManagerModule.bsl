Процедура ПередЗаписью(Отказ)
	
	СоответсвтсвиеУзлов = Новый Соответствие;
	Для НомерУзла = 1 По Значение Цикл
		ДанныеСоотвествия = "SHINA_" + Строка(Формат(НомерУзла, "ЧЦ=3; ЧВН=;"));
		СоответсвтсвиеУзлов.Вставить(ДанныеСоотвествия, ДанныеСоотвествия);
	КонецЦикла;
	
	Выборка = ПланыОбмена.Шина.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Не Выборка.ЭтотУзел Тогда
			ТекущийУзелОбъект = Выборка.Ссылка.ПолучитьОбъект();
			Если СоответсвтсвиеУзлов.Получить(СокрЛП(Выборка.Наименование)) = Неопределено Тогда
				ТекущийузелОбъект.УстановитьПометкуУдаления(Истина);
			Иначе
				ТекущийузелОбъект.УстановитьПометкуУдаления(Ложь);
				СоответсвтсвиеУзлов.Удалить(СокрЛП(Выборка.Наименование));
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Для Каждого Выборка Из СоответсвтсвиеУзлов Цикл
		НовыйУзел = ПланыОбмена.Шина.СоздатьУзел();
		НовыйУзел.Наименование = Выборка.Ключ;
		НовыйУзел.Код = Выборка.Ключ;
		НовыйУзел.Записать();
	КонецЦикла;

КонецПроцедуры

