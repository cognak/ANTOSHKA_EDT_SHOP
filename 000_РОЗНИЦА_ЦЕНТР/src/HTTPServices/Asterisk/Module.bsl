
Функция Call_inPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтрокаЗапроса = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
	СтруктураДанных = ДесериализаторJSON(СтрокаЗапроса); 
	
	НомерТелефона = СтруктураДанных.customer_number;         
	
	Если СтрДлина(СтруктураДанных.customer_number) = 10 Тогда 
		НомерТелефона = "38" + СтруктураДанных.customer_number;         
	Иначе 
		НомерТелефона = СтрЗаменить(СтруктураДанных.customer_number, "+", "");         
	КонецЕсли;	
		
	Запись = РегистрыСведений.ВходящиеЗвонкиАстерикс.СоздатьМенеджерЗаписи();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона = &НомерТелефона
	|	И КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления = ЛОЖЬ
    |
	|СГРУППИРОВАТЬ ПО
	|	КонтрагентыКонтактнаяИнформация.Ссылка";
	Запрос.Параметры.Вставить("НомерТелефона", НомерТелефона);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда 
		Контрагент = Результат.Ссылка;
	Иначе 
		Контрагент = НомерТелефона;//Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	
	Запись.НомерКонтрагента = НомерТелефона;  
	Запись.Контрагент 		= Контрагент;
	Запись.НомерКонтрагента = НомерТелефона;
	Запись.НомерОператора 	= СтруктураДанных.operator_number;
	Запись.Период			= ТекущаяДата();
	Запись.СотрудникКоллЦентра			= РегистрыСведений.РаботаСотрудниковКоллЦентра.ПолучитьСотрудникаПоВнутренниемуНомеру(Запись.НомерОператора);
	Запись.ЗвонокПринят		= ?(Запись.НомерОператора = "NULL", Ложь, Истина);
	
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		РегистрыСведений.ОповещенияПользователя.Установить(Контрагент, "Входящий_Звонок", Запись.СотрудникКоллЦентра.Владелец);	
	КонецЕсли;	
	
	Запись.Записать(Ложь);
	
    УстановитьПривилегированныйРежим(Ложь);

	Ответ = Новый HTTPСервисОтвет(200);
	Возврат Ответ;
	
КонецФункции

Функция СериализаторJSON(СтруктураДанных) Экспорт 
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
	СтрокаJSON = ЗаписьJSON.Закрыть();
	
	Возврат СтрокаJSON;
	
КонецФункции	

Функция ДесериализаторJSON(СтруктураДанных) Экспорт
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(СтруктураДанных);
	
	СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON);		
	
	Возврат СтруктураОтвета;
	
КонецФункции	
