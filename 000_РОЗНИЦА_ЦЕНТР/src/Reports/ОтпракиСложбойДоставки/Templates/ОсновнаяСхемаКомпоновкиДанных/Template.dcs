			<dataPath>НомерЗаказа</dataPath>
			<field>НомерЗаказа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Номер заказа</v8:content>
				</v8:item>
			</title>
			<presentationExpression>НомерСамогоЗаказа</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусЗапроса</dataPath>
			<field>СтатусЗапроса</field>
		</field>
		<field xsi:type="DataSetFieldField">
