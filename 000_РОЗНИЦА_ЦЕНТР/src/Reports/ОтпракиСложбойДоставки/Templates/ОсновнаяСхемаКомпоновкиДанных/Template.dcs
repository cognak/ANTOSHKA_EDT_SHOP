					<v8:content>Номер ТТН</v8:content>
				</v8:item>
			</title>
			<presentationExpression>НомерСамогоТТН</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусЭН</dataPath>
			<field>СтатусЭН</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаТТН</dataPath>
			<field>ДатаТТН</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата ТТН</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаСтатуса</dataPath>
