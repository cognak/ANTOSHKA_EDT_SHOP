				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата статуса</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МагазинОтправитель</dataPath>
