#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОткрытьФормуРегистрации(Команда)
	ТекСтрока = Элементы.Список.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекУзел = ПолучитьУзелОбменаПоКоду(ТекСтрока.Код);
	Если ТекУзел = Неопределено Тогда
		ПоказатьПредупреждение(, "Узел обмена не найден");
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("УзелОбмена", ТекУзел);
	ОткрытьФорму("Обработка.РегистрацияИзмененийДляОбменаДанными.Форма.Форма", ПараметрыФормы, ЭтотОбъект);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ПолучитьУзелОбменаПоКоду(Знач Код)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОбменМаженто2.Ссылка КАК Ссылка
	               |ИЗ
	               |	ПланОбмена.ОбменМаженто2 КАК ОбменМаженто2
	               |ГДЕ
	               |	ОбменМаженто2.Код = &Код";
	Запрос.УстановитьПараметр("Код", Код);
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	Если ВыборкаЗапроса.Следующий() Тогда
		Возврат ВыборкаЗапроса.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

#КонецОбласти
