// Создает структуру с параметрами для записи в регистр исходящих сообщений Kafka
//
// Возвращаемое значение:
//   Структура:
//     * УникальныйИдентификатор - УникальныйИдентификатор - идентификатор сообщения
//     * ВремяСоздания - Число - время создания сообщения в миллисекундах
//     * НомерПотока - Число - номер потока для обработки
//     * СсылкаДляВыгрузки - Неопределено, Произвольный - ссылка на объект для выгрузки
//     * ОтборДляВыгрузки - Строка - отбор для выгрузки в хранилище значений
//     * ПолноеНаименованиеОбъектаВыгрузки - Строка - полное наименование объекта выгрузки
//     * ДанныеВыгрузки - Строка - данные для выгрузки
//     * СтатусВыгрузки - ПеречислениеСсылка.КафкаСтатус - статус выгрузки сообщения
//     * ТекстОшибки - Строка - строка с описанием ошибки выгрузки
Функция СтруктураЗаписи() Экспорт
	
	СтруктураЗаписи = Новый Структура;
	СтруктураЗаписи.Вставить("УникальныйИдентификатор", Новый УникальныйИдентификатор);
	СтруктураЗаписи.Вставить("ВремяСоздания", ТекущаяУниверсальнаяДатаВМиллисекундах());
	СтруктураЗаписи.Вставить("НомерПотока", 0);
	СтруктураЗаписи.Вставить("СсылкаДляВыгрузки", Неопределено);
	СтруктураЗаписи.Вставить("ОтборДляВыгрузки", "");
	СтруктураЗаписи.Вставить("ПолноеНаименованиеОбъектаВыгрузки", "");
	СтруктураЗаписи.Вставить("ДанныеВыгрузки", "");
	СтруктураЗаписи.Вставить("СтатусВыгрузки", Перечисления.КафкаСтатус.ПустаяСсылка());
	СтруктураЗаписи.Вставить("ТекстОшибки", "");

	Возврат СтруктураЗаписи;
	
КонецФункции

// Добавить запись в регистр по структуре.
//
// Параметры:
//   СтруктураЗаписи - Структура - ключи соответствуют измерениям и реквизитам регистра сведений:
//     * УникальныйИдентификатор - УникальныйИдентификатор - идентификатор сообщения
//     * ВремяСоздания - Число - время создания сообщения в миллисекундах
//     * НомерПотока - Число - номер потока для обработки
//     * СсылкаДляВыгрузки - Неопределено, Произвольный - ссылка на объект для выгрузки
//     * ОтборДляВыгрузки - Строка - отбор для выгрузки в виде текста
//     * ПолноеНаименованиеОбъектаВыгрузки - Строка - полное наименование объекта выгрузки
//     * ДанныеВыгрузки - Строка - данные для выгрузки
//     * СтатусВыгрузки - ПеречислениеСсылка.КафкаСтатус - статус выгрузки сообщения
//     * ТекстОшибки - Строка - строка с описанием ошибки выгрузки
Процедура ДобавитьЗаписьРегистра(СтруктураЗаписи) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КафкаИсходящиеСообщения.НомерПотока КАК НомерПотока
		|ИЗ
		|	РегистрСведений.КафкаИсходящиеСообщения КАК КафкаИсходящиеСообщения
		|ГДЕ
		|	КафкаИсходящиеСообщения.ПолноеНаименованиеОбъектаВыгрузки = &ПолноеНаименованиеОбъектаВыгрузки
		|	И КафкаИсходящиеСообщения.СтатусВыгрузки = ЗНАЧЕНИЕ(Перечисление.КафкаСтатус.Новый)";
	
	Запрос.УстановитьПараметр("ПолноеНаименованиеОбъектаВыгрузки", СтруктураЗаписи.ПолноеНаименованиеОбъектаВыгрузки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтруктураЗаписи.НомерПотока = Выборка.НомерПотока;
	КонецЕсли;

	ДобавитьЗапись(СтруктураЗаписи);

КонецПроцедуры

// Добавить запись в регистр по структуре.
//
// Параметры:
//   СтруктураЗаписи - Структура - ключи соответствуют измерениям и реквизитам регистра сведений:
//     * УникальныйИдентификатор - УникальныйИдентификатор - идентификатор сообщения
//     * ВремяСоздания - Число - время создания сообщения в миллисекундах
//     * НомерПотока - Число - номер потока для обработки
//     * СсылкаДляВыгрузки - Неопределено, Произвольный - ссылка на объект для выгрузки
//     * ОтборДляВыгрузки - Строка - отбор для выгрузки в виде текста
//     * ПолноеНаименованиеОбъектаВыгрузки - Строка - полное наименование объекта выгрузки
//     * ДанныеВыгрузки - Строка - данные для выгрузки
//     * СтатусВыгрузки - ПеречислениеСсылка.КафкаСтатус - статус выгрузки сообщения
//     * ТекстОшибки - Строка - строка с описанием ошибки выгрузки
Процедура ДобавитьЗаписьОбъекта(СтруктураЗаписи) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.УникальныйИдентификатор.Установить(СтруктураЗаписи.УникальныйИдентификатор);
	Наборзаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		СтруктураЗаписи.НомерПотока = НаборЗаписей[0].НомерПотока;
	КонецЕсли;
	
	ДобавитьЗапись(СтруктураЗаписи);

КонецПроцедуры

// Добавить запись в регистр по структуре.
//
// Параметры:
//   СтруктураЗаписи - Структура - ключи соответствуют измерениям и реквизитам регистра сведений:
//     * УникальныйИдентификатор - УникальныйИдентификатор - идентификатор сообщения
//     * ВремяСоздания - Число - время создания сообщения в миллисекундах
//     * НомерПотока - Число - номер потока для обработки
