//     * ТекстОшибки - Строка - строка с описанием ошибки выгрузки
Процедура ЗаписатьИзменениеСтатуса(СтруктураЗаписи) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.УникальныйИдентификатор.Установить(СтруктураЗаписи.УникальныйИдентификатор);
	НаборЗаписей.Отбор.ВремяСоздания.Установить(СтруктураЗаписи.ВремяСоздания);
	НаборЗаписей.Отбор.НомерПотока.Установить(СтруктураЗаписи.НомерПотока);
	НаборЗаписей.Прочитать();

	Запись = НаборЗаписей[0];

	ЗаполнитьЗначенияСвойств(Запись, СтруктураЗаписи);
	НаборЗаписей.Записать();
	
КонецПроцедуры

