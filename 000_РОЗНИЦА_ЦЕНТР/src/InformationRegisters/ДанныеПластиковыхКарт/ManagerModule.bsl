// Струкура данных для записи.
// 
// Возвращаемое значение:
//  Структура - Струкура данных для записи:
// * ЧекККМ - ДокументСсылка.ЧекККМ - 
// * Контрагент - СправочникСсылка.Контрагенты - 
// * ТипПластиковойКарты - ПеречислениеСсылка.ТипыПластиковыхКарт - 
// * Сумма - Число - 
Функция СтрукураДанныхДляЗаписи() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ЧекККМ", Документы.ЧекККМ.ПустаяСсылка());
	Результат.Вставить("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	Результат.Вставить("ТипПластиковойКарты", Перечисления.ТипыПластиковыхКарт.ПустаяСсылка());
	Результат.Вставить("СуммаРозница", 0);
	Результат.Вставить("СуммаИнтернет", 0);
	
	Возврат Результат;
	
КонецФункции

// Записать данные оплаты.
// 
// Параметры:
//  ДанныеДляЗаписи - см. СтрукураДанныхДляЗаписи
Процедура ЗаписатьДанныеОплаты(ДанныеДляЗаписи) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЧекККМ.Установить(ДанныеДляЗаписи.ЧекККМ);
	НаборЗаписей.Отбор.ТипПластиковойКарты.Установить(ДанныеДляЗаписи.ТипПластиковойКарты);

	НоваяСтрока = НаборЗаписей.Добавить();
	НоваяСтрока.ЧекККМ = ДанныеДляЗаписи.ЧекККМ;
	НоваяСтрока.Контрагент = ДанныеДляЗаписи.Контрагент;
	НоваяСтрока.ТипПластиковойКарты = ДанныеДляЗаписи.ТипПластиковойКарты;
	НоваяСтрока.СуммаРозница = ДанныеДляЗаписи.СуммаРозница;
	НоваяСтрока.СуммаИнтернет = ДанныеДляЗаписи.СуммаИнтернет;
	
	НаборЗаписей.Записать(Истина);
	
КонецПроцедуры

// Очистить регистр.
// 
// Параметры:
//  ДанныеДляЗаписи - см. СтрукураДанныхДляЗаписи
Процедура ОчиститьРегистр(ДанныеДляЗаписи) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЧекККМ.Установить(ДанныеДляЗаписи.ЧекККМ);
	НаборЗаписей.Записать();
	
КонецПроцедуры

