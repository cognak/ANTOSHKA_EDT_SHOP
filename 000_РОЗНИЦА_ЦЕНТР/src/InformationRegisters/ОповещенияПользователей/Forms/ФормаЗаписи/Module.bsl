 
 #Область ОбработчикиСобытийФормы  
   
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МенеджерЗаписи = РеквизитФормыВЗначение("Запись");
	
	Копии = МенеджерЗаписи.Копия.Получить();
	
	Если Копии <> Неопределено Тогда
		СписокКопия = Копии;
	КонецЕсли;
	
	СкрытыеКопии = МенеджерЗаписи.СкрытаяКопия.Получить();
	
	Если СкрытыеКопии <> Неопределено Тогда
		СписокСкрытаяКопия = СкрытыеКопии;
	КонецЕсли;
	
	ПараметрыПисьма = "[Номер] [Дата]";
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)	
	ЗаполнитьКопии(ТекущийОбъект.Копия, ТекущийОбъект.СкрытаяКопия);	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
    УстановитьВидимостьДоступность();
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СпособИнформированияПриИзменении(Элемент)
	УстановитьВидимостьДоступность();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы  

&НаКлиенте
Процедура ТестОповещения(Команда)
	ТестированиеОповещения()
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ТестированиеОповещения()
	
	ВидКИ = ОповещенияПользователейВызовСервера.ПолучитьВидКонтактнойИнформации(Запись.СпособОповещения);
	
	НастройкиОповещения = ОповещенияПользователейВызовСервера.ПолучитьСтруктуруНастроекОповещения();
	НастройкиОповещения.СпособОповещения	= Запись.СпособОповещения;
	НастройкиОповещения.ТелоСообщения		= Запись.Текст;
	НастройкиОповещения.ЗаголовокСообщения	= Запись.Тема;
	НастройкиОповещения.Бот					= Запись.Бот;
	
	Если Запись.СпособОповещения = ПредопределенноеЗначение("Перечисление.СпособыОповещения.Email") Тогда
		НастройкиОповещения.Копии	     = ПолучитьМассивСтруктурПолучателейЭлектроннойПочты(СписокКопия.ВыгрузитьЗначения(), ВидКИ);
		НастройкиОповещения.СкрытыеКопии = ПолучитьМассивСтруктурПолучателейЭлектроннойПочты(СписокСкрытаяКопия.ВыгрузитьЗначения(), ВидКИ);
	КонецЕсли;	
	
	МассивПользователей = Новый Массив();
	МассивПользователей.Добавить(Запись.Пользователь);
	
	// для мессенджерів немає "копій", сповіщення для кожного користувача відправляємо окремо
	Если Запись.СпособОповещения = ПредопределенноеЗначение("Перечисление.СпособыОповещения.Telegram") Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивПользователей, СписокКопия.ВыгрузитьЗначения(), Истина);
	КонецЕсли;	
	
	Для Каждого Пользователь Из МассивПользователей Цикл
	
		// сповіщення робимо по конкретним даним цієї настройки
		ОповещенияПользователейВызовСервера.ВыполнитьПроизвольноеОповещениеПользователей(Пользователь, НастройкиОповещения);
		
	КонецЦикла;	
	
	ТекстСообщения = НСтр("ru = 'Оповещения отправлены!'; uk = 'Сповіщення відправлено!'");
	ПоказатьПредупреждение(, ТекстСообщения);
	
КонецПроцедуры // ТестированиеОповещения()

&НаСервереБезКонтекста
Функция ПолучитьМассивСтруктурПолучателейЭлектроннойПочты(МассивПользователей, ВидКонтактнойИнформации)
	
	МассивРезультат = Новый Массив();	
	
	Для Каждого Пользователь Из МассивПользователей Цикл
		МассивРезультат.Добавить(ОповещенияПользователей.ПолучитьСтруктуруПолучателяЭлектроннойПочты(Пользователь, ВидКонтактнойИнформации));
	КонецЦикла;	
	
	Возврат МассивРезультат;
	
КонецФункции // ПолучитьМассивСтруктурПолучателейЭлектроннойПочты()	

&НаСервере
Процедура ЗаполнитьКопии(Копия, СкрытаяКопия)
	
	Копия        = Новый ХранилищеЗначения(СписокКопия, Новый СжатиеДанных(9));
	СкрытаяКопия = Новый ХранилищеЗначения(СписокСкрытаяКопия, Новый СжатиеДанных(9));
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность()

	EMail 	 = ( Запись.СпособОповещения = ПредопределенноеЗначение("Перечисление.СпособыОповещения.Email") );
	Telegram = ( Запись.СпособОповещения = ПредопределенноеЗначение("Перечисление.СпособыОповещения.Telegram") );
		
	Элементы.ГруппаEMail.Видимость = EMail;
	Элементы.ГруппаTelegram.Видимость = Telegram;
		
КонецПроцедуры

#КонецОбласти
