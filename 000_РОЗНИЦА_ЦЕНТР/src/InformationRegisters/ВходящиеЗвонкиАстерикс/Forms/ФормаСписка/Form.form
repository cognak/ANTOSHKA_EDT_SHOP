        <field>НомерОператора</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ЗвонокПринят</dataPath>
        <field>ЗвонокПринят</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СотрудникКоллЦентра</dataPath>
        <field>СотрудникКоллЦентра</field>
      </fields>
      <parameters>
        <name>СотрудникКоллЦентра</name>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Сотрудник колл центра</value>
            </content>
