		Результат = Коннектор.ОтправитьСообщениеProtobuf(Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	Иначе
		Результат = Коннектор.ОтправитьСообщениеProtobufСОжиданиемРезультата(Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	КонецЕсли;
	
	Если Результат = 1 Тогда
		Возврат 0;
		
	ИначеЕсли Результат = 2 Тогда 
		Возврат 1;
		
	Иначе
		Возврат -1;
		
	КонецЕсли;
	
КонецФункции

