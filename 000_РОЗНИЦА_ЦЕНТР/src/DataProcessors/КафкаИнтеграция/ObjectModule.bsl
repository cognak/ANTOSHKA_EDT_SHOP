// Асинхронная/Синхронная отправка.
// 	В рамках синхронной отправки рекомендуется устанавливать параметры queue.buffering.max.ms и socket.blocking.max.ms в самые минимальные значения,
//		чтобы во внутреннем буфере сообщений не происходило накопление данных и сообщения могли отправляться сразу, минуя буфер.
//	Так же следует обратить внимание на параметр message.timeout.ms. Данным параметром мы указываем, сколько времени в мс. мы должны ждать подтверждения от брокеров.
//		Брокеры могут и не отправить подтверждения, если, к примеру, они не доступны. В этом случае, рекомендуется устанавливать данный параметр в диапазоне от 1000 до 20000 мс.
//		В противном случае - недоступности брокеров и включенном логировании в компоненте - в логе продюсера не будет никакой информации об проблеме.
//
// Параметры:
//  Сообщение - Строка, ДвоичныеДанные - Тело сообщения, например json строка.
//  Топик - Строка - Топик
//  Партиция - Число - (Необязательный) Партиция.
//  Ключ - Строка - (Необязательный) Ключ сообщения, который может использоваться в темах с уплотнением сообщений по ключу.
//  Заголовки - Неопределено, Структура - (Необязательный) Перечень заголовков
// 
// Возвращаемое значение:
//  Число - Результат отправки сообщения: '-1' - исключительная ситуация, '0' - передано БЕЗ подтверждения, '1' - передано С подтверждением. Для '-1' и '0' см. ПолучитьСообщениеОбОшибке
//  
//@skip-check method-too-many-params
Функция ОтправитьСообщение(Сообщение, Топик, Партиция = -1, Ключ = "", Заголовки = Неопределено) Экспорт
	
	Если Заголовки = Неопределено Тогда
		ЗаголовкиСтрокой = "";
		
	Иначе
		Список = Новый Массив; // Массив Из Строка
		Для Каждого КлючЗначение Из Заголовки Цикл
			Список.Добавить(КлючЗначение.Ключ + "," + КлючЗначение.Значение);
		КонецЦикла;
		ЗаголовкиСтрокой = СтрСоединить(Список, ";");
		
	КонецЕсли;
	
//	Метод возвращает значение типа целое:
//	
//	 * RD_KAFKA_MSG_STATUS_NOT_PERSISTED (значение 0) — это статус сообщения в библиотеке librdkafka, который означает,
//	  		что сообщение не было передано брокеру или завершилось с ошибкой, указывающей, что оно не было записано в журнал.
//	
//	 * RD_KAFKA_MSG_STATUS_POSSIBLY_PERSISTED (значение 1) — это статус сообщения в библиотеке librdkafka, который означает,
//	 		что сообщение было передано брокеру, но для него не было получено подтверждения.
//	
//	 * RD_KAFKA_MSG_STATUS_PERSISTED (значение 2) — это статус сообщения в библиотеке librdkafka, который означает,
//	 	что сообщение было записано в журнал, для него было получено подтверждение от брокера, поэтому нет причин для повторной отправки сообщения.
//	 
//	Исключительная ситуация (значение -1) - произошла ошибка отправки.
	
	Если РежимАсинхроннойОтправки = Истина Тогда
		Результат = Коннектор.ОтправитьСообщение(Сообщение, Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	Иначе
		Результат = Коннектор.ОтправитьСообщениеСОжиданиемРезультата(Сообщение, Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	КонецЕсли;
	
	Если Результат = 1 Тогда
		Возврат 0;
		
	ИначеЕсли Результат = 2 Тогда 
		Возврат 1;
		
	Иначе
		Возврат -1;
		
	КонецЕсли;
	
КонецФункции

// Отправить пакет сообщений.
//
//	Пример JSON:
//	[
//		{
//			"message": "Сообщение 1",
//			"key": "order-001",
//			"partition": 0,
//			"headers": "type,order;priority,high"
//		},
//		{
//			"message": "Сообщение 2",
//			"key": "order-002"
//		},
//		{
//			"message": "Сообщение 3"
//		}
//	]
//
// Параметры:
//	Сообщения - Строка, Массив Из Структура - Пакет сообщений. Каждое сообщение в массиве должно быть объектом со следующими полями:
//		* message - Строка - (обязательное) Тело сообщения.
//		* key - Строка - (необязательное) Ключ сообщения.
//		* partition - Число - (необязательное) Номер партиции. Если не указан, используется -1 (автоматический выбор).
//		* headers - Строка - (необязательное) Заголовки в формате "ключ1,значение1;ключ2,значение2".
//	ИмяТопика - Строка - Имя топика
//
// Возвращаемое значение:
//	Число - количество успешно отправленных сообщений. В случае ошибки парсинга JSON или неинициализированного продюсера возвращается -1.
Функция ОтправитьПакетСообщений(Сообщения, ИмяТопика) Экспорт
	
	СтрокаJSON = ?(ТипЗнч(Сообщения) = Тип("Строка"), Сообщения, КафкаОбщегоНазначенияСлужебный.ЗначениеВJSON(Сообщения));
	Возврат Коннектор.ОтправитьПакетСообщений(СтрокаJSON, ИмяТопика);
	
КонецФункции

// Остановка продюсера. После того как была произведена отправка всех необходимых сообщений и больше нет необходимости в использовании инстанса продюсера - необходимо обязательно производить остановку продюсера.
// 
// Возвращаемое значение:
//  Булево - Продюсер остановлен. В случае значения "Ложь" текст ошибки можно получить функцией ПолучитьСообщениеОбОшибке.
//
Функция ОстановитьПродюсера() Экспорт

	Возврат Коннектор.ОстановитьПродюсера();

КонецФункции

#Область Транзакции

// Инициализировать транзакционного продюсера.
//
// Параметры:
//	Брокеры - Строка, Массив Из Строка - Список брокеров кластера, разделенные запятой (например, "localhost:9092").
//	ИдентификаторТранзакции - Строка - Уникальный идентификатор транзакционного продюсера.
//		ИдентификаторТранзакции должен быть уникальным для каждого экземпляра продюсера
//		При перезапуске используйте тот же идентификатор Kafka автоматически завершит незавершенные транзакции
//		Не создавайте несколько продюсеров с одинаковым идентификатором одновременно
// 
// Возвращаемое значение:
//	Булево - Истина при успешной инициализации, Ложь при ошибке. В случае ошибки текст можно получить методом ПолучитьСообщениеОбОшибке().
Функция ИнициализироватьТранзакционногоПродюсера(Брокеры, ИдентификаторТранзакции) Экспорт
