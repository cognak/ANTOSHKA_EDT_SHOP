КонецФункции

// Получить схему AVRO.
// 
// Параметры:
//	ДанныеAVRO - ДвоичныеДанные - AVRO данные в формате OCF (Object Container File).
// 
// Возвращаемое значение:
//	Строка - JSON-представлением схемы. Пустая строка в случае ошибки.
Функция ПолучитьСхемуAVRO(ДанныеAVRO) Экспорт
	
	Возврат Коннектор.ПолучитьСхемуAVRO(ДанныеAVRO);
	
КонецФункции

// Формирование AVRO из JSON.
// Обратите внимание, что:
//	* в каждом поле должен быть массив с одинаковым количеством элементов;
//	* поля должны быть перечислены строго в той последовательности, в которой определены в схеме (описание схемы далее);
//	* поддерживаются следующие типы: AVRO_STRING, AVRO_LONG, AVRO_INT, AVRO_FLOAT, AVRO_DOUBLE, AVRO_BOOL, AVRO_NULL, AVRO_UNION, AVRO_FIXED, AVRO_BYTES;
//	* поддерживается логический тип UUID (передаётся как строка в формате xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx).
// 
// Форматы:
//	''/avro	- Avro Object Container Format — полный контейнер с заголовком, схемой и sync-маркерами. Подходит для сохранения в файл.
//	raw - Raw Avro — чистый бинарный Avro без контейнера. Подходит для отправки в Kafka при интеграции с внешними системами
//	confluent - Confluent Wire Format — magic byte (0x00) + 4 байта schema ID (big-endian) + raw Avro binary. Стандартный формат Confluent Platform для работы со Schema Registry
// 
// Параметры:
//	ДанныеJSON - Строка, Структура, Массив Из Структура - Данные в формате JSON
//	ИмяСхемыJSON - Строка - Имя схемы, которая ранее был сохранена процедурой СохранитьСхемуAVRO
//	Формат - Строка - Формат выходных данных. Допускаются следующие значения: avro, raw, confluent
//	ИдСхемы - Число - Идентификатор схемы в Schema Registry. Используется только при формате "confluent".
// 
// Возвращаемое значение:
//	Булево -  "Истина", если операция выполнена успешно. "Ложь", если была ошибка. Текст ошибки можно получить функцией ПолучитьСообщениеОбОшибке.
Функция ПреобразоватьВФорматAVRO(ДанныеJSON, ИмяСхемыJSON, Формат = "OCF", ИдСхемы = 0) Экспорт
	
	СтрокаJSON = ?(ТипЗнч(ДанныеJSON) = Тип("Строка"), ДанныеJSON, КафкаОбщегоНазначенияСлужебный.ЗначениеВJSON(ДанныеJSON));
	Возврат Коннектор.ПреобразоватьВФорматAVRO(СтрокаJSON, ИмяСхемыJSON);
	
КонецФункции

// Асинхронная/Синхронная отправка AVRO.
// 	В рамках синхронной отправки рекомендуется устанавливать параметры queue.buffering.max.ms и socket.blocking.max.ms в самые минимальные значения,
//		чтобы во внутреннем буфере сообщений не происходило накопление данных и сообщения могли отправляться сразу, минуя буфер.
//	Так же следует обратить внимание на параметр message.timeout.ms. Данным параметром мы указываем, сколько времени в мс. мы должны ждать подтверждения от брокеров.
//		Брокеры могут и не отправить подтверждения, если, к примеру, они не доступны. В этом случае, рекомендуется устанавливать данный параметр в диапазоне от 1000 до 20000 мс.
//		В противном случае - недоступности брокеров и включенном логировании в компоненте - в логе продюсера не будет никакой информации об проблеме.
//
// Параметры:
//  Топик - Строка - Топик
//  Партиция - Число - (Необязательный) Партиция.
//  Ключ - Строка - (Необязательный) Ключ сообщения, который может использоваться в темах с уплотнением сообщений по ключу.
//  Заголовки - Неопределено, Структура - (Необязательный) Перечень заголовков
// 
// Возвращаемое значение:
//  Число - Результат отправки сообщения: '-1' - исключительная ситуация, '0' - передано БЕЗ подтверждения, '1' - передано С подтверждением. Для '-1' и '0' см. ПолучитьСообщениеОбОшибке
//  
Функция ОтправитьСообщениеAVRO(Топик, Партиция = 0, Ключ = "", Заголовки = Неопределено) Экспорт
	
	Если Заголовки = Неопределено Тогда
		ЗаголовкиСтрокой = "";
		
	Иначе
		Список = Новый Массив; // Массив Из Строка
		Для Каждого КлючЗначение Из Заголовки Цикл
			Список.Добавить(КлючЗначение.Ключ + "," + КлючЗначение.Значение);
		КонецЦикла;
		ЗаголовкиСтрокой = СтрСоединить(Список, ";");
		
	КонецЕсли;
	
//	Метод возвращает значение типа целое:
//	
//	 * RD_KAFKA_MSG_STATUS_NOT_PERSISTED (значение 0) — это статус сообщения в библиотеке librdkafka, который означает,
//	  		что сообщение не было передано брокеру или завершилось с ошибкой, указывающей, что оно не было записано в журнал.
//	
//	 * RD_KAFKA_MSG_STATUS_POSSIBLY_PERSISTED (значение 1) — это статус сообщения в библиотеке librdkafka, который означает,
//	 		что сообщение было передано брокеру, но для него не было получено подтверждения.
//	
//	 * RD_KAFKA_MSG_STATUS_PERSISTED (значение 2) — это статус сообщения в библиотеке librdkafka, который означает,
//	 	что сообщение было записано в журнал, для него было получено подтверждение от брокера, поэтому нет причин для повторной отправки сообщения.
//	 
//	Исключительная ситуация (значение -1) - произошла ошибка отправки.
	
	Если РежимАсинхроннойОтправки = Истина Тогда
		Результат = Коннектор.ОтправитьСообщениеAVRO(Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	Иначе
		Результат = Коннектор.ОтправитьСообщениеAVROСОжиданиемРезультата(Топик, Партиция, Ключ, ЗаголовкиСтрокой); // Число - от -1 до 1
		
	КонецЕсли;
	
	Если Результат = 1 Тогда
		Возврат 0;
		
	ИначеЕсли Результат = 2 Тогда 
		Возврат 1;
		
	Иначе
		Возврат -1;
		
	КонецЕсли;
	
КонецФункции

