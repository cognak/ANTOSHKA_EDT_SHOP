// Прочитать сообщение.
// 	Если по результату вернулось значение Истина, можно вызывать следующие нижеперечисленные методы:
// 		ПолучитьДанныеСообщения()
// 		ПолучитьКлючСообщения()
// 		ПолучитьЗаголовкиСообщения()
// 		ПолучитьТопикСообщения()
// 		ПолучитьИдентификаторБрокераСообщения()
// 		ПолучитьВременнуюМеткуСообщения()
// 		ПолучитьРазделСообщения()
// 		ПолучитьСмещениеСообщения()
// 
// Возвращаемое значение:
//  Булево - Истина - было получено очередное сообщение из очереди, Ложь - в очереди нет сообщений.
Функция ПрочитатьСообщение() Экспорт
	
	Возврат Коннектор.ПрочитатьСообщение();
	
КонецФункции

// 	Пакетное чтение нескольких сообщений.
// 
// Параметры:
//	МаксимальноеКоличество - Число - Максимальное количество сообщений для чтения.
//	МаксимальноеВремяОжидания - Число - Максимальное время ожидания сообщений в миллисекундах. см. УстановитьТаймаутОжидания
//	КодироватьВBase64 - Булево - Если Истина, поле message возвращается в Base64 (рекомендуется для бинарных данных).
//	Десериализовать - Булево - (Необязательный) Десериализовать JSON в объекты 1С
// 
// Возвращаемое значение:
//	Неопределено, Строка, Массив Из Структура - JSON сообщениями:
//	 * messages - Массив Из Структура - Сообщения:
//	  ** message - Строка - Тело сообщения (строка, либо Base64 при КодироватьВBase64=Истина)
//	  ** message_encoding - Строка - добавляется, если КодироватьВBase64=Ложь, но сообщение не в UTF-8
//	  ** key - Строка - Ключ сообщения (если есть)
//	  ** key_encoding - Строка - добавляется, если ключ не в UTF-8
//	  ** topic - Строка - Топик
//	  ** partition - Строка - Номер партиции
//	  ** offset - Строка - Смещение
//	  ** timestamp - Строка - Временная метка (ms)
//	  ** broker_id - Строка - ID брокера
//	  ** headers - Массив Из Структура - Заголовки (если есть):
//	    *** key - Строка - Ключ заголовка
//	    *** value - Строка - Значение заголовка
//	 * count - Строка - Количество прочитанных сообщений
//@skip-check method-too-many-params
Функция ЧитатьПакетСообщений(МаксимальноеКоличество = 100, МаксимальноеВремяОжидания = Неопределено,
		КодироватьВBase64 = Ложь, Десериализовать = Истина) Экспорт
	
	Если МаксимальноеВремяОжидания = Неопределено Тогда
		МаксимальноеВремяОжидания = ?(ТаймаОжиданияОтвета = Неопределено, 1000, ТаймаОжиданияОтвета);
	КонецЕсли;
	
	Результат = Коннектор.ЧитатьПакетСообщений(МаксимальноеКоличество, МаксимальноеВремяОжидания, КодироватьВBase64); // Строка
	Если ПустаяСтрока(Результат) Тогда
		Возврат Неопределено;
		
	Иначе
		Возврат ?(Десериализовать И Не КодироватьВBase64, ОбщегоНазначения.JSONВЗначение(Результат, , Ложь), Результат);
	КонецЕсли;
	
КонецФункции

// Данные прочитанного сообщения.
// 
// Параметры:
//  Десериализовать - Булево - (Необязательный) Десериализовать JSON в объекты 1С
// 
// Возвращаемое значение:
//  Структура - Данные прочитанного сообщения:
// * Тело - Строка, ДвоичныеДанные - Данные сообщения
// * Ключ - Строка - ключ сообщения (key)
// * Заголовки - Строка, Массив Из Структура - JSON строка или массив заголовков, каждый заголовок состоит из ключа и значения (key, value)
// * Топик - Строка - Имя топика.
// * ИдентификаторБрокера - Строка - идентификатор брокера.
// * ВременнаяМетка - Число - Фактическое время записи сообщения в топик и указанный раздел.
// * Раздел - Число - Номер партиции.
// * Смещение - Число - Текущее смещение сообщения (offset).
Функция ДанныеПрочитанногоСообщения(Десериализовать = Истина) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Тело", ПолучитьДанныеСообщения());
	Результат.Вставить("Ключ", ПолучитьКлючСообщения());
	Результат.Вставить("Заголовки", ПолучитьЗаголовкиСообщения(Десериализовать));
	Результат.Вставить("Топик", ПолучитьТопикСообщения());
	Результат.Вставить("ИдентификаторБрокера", ПолучитьИдентификаторБрокераСообщения());
	Результат.Вставить("ВременнаяМетка", ПолучитьВременнуюМеткуСообщения());
	Результат.Вставить("Раздел", ПолучитьРазделСообщения());
	Результат.Вставить("Смещение", ПолучитьСмещениеСообщения());
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

#Область ДанныеПрочитанногоСообщения

// Получить данные сообщения.
// 
// Возвращаемое значение:
