&НаКлиенте
Процедура СоздатьНовуюАкцию(Команда)
	 // Проверка на заполненность полей обработки
	Если  Не ЗначениеЗаполнено(Объект.ПрограммаЛояльности) Тогда
		ПоказатьПредупреждение(, "Пожалуйста, выберите новую программу лояльности!");
		Возврат;
	КонецЕсли;
	
	// Проверка на заполненность полей обработки
	Если ПустаяСтрока(Объект.СтрокаПоиска) Тогда
		ПоказатьПредупреждение(, "Пожалуйста, заполните строку поиска!");
		Возврат;
	КонецЕсли;
	
	// Проверка на заполненность полей обработки
	Если  ПустаяСтрока(Объект.СтрокаЗамены) Тогда
		ПоказатьПредупреждение(, "Пожалуйста, заполните строку замены!");
		Возврат;
	КонецЕсли;
	// Проверяем, что обработку открыли именно из формы документа
	Если ТипЗнч(ВладелецФормы) <> Тип("УправляемаяФорма") Тогда
		ПоказатьПредупреждение(, "Эту обработку нужно открывать по кнопке из формы документа!");
		Возврат;
	КонецЕсли;
	
	// Собираем ссылки на акции из табличной части документа
	МассивИсходныхСкидок = Новый Массив;
	Для Каждого СтрокаТЧ Из ВладелецФормы.Объект.СкидкиНаценки Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.СкидкаНаценка) Тогда
			МассивИсходныхСкидок.Добавить(СтрокаТЧ.СкидкаНаценка);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивИсходныхСкидок.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "В документе нет заполненных акций для копирования!");
		Возврат;
	КонецЕсли;
	
	// Передаем данные на сервер для создания новых элементов в базе
	МассивНовыхСкидок = СоздатьСкидкиНаСервере(МассивИсходныхСкидок, Объект.СтрокаПоиска, Объект.СтрокаЗамены, Объект.ПрограммаЛояльности);
	
	// Возвращаемся на клиент и добавляем новые строки в открытый документ
	Для Индекс = 0 По МассивИсходныхСкидок.ВГраница() Цикл
		
		ИсходнаяСкидка = МассивИсходныхСкидок[Индекс];
		НоваяСкидка = МассивНовыхСкидок[Индекс];
		
		// Ищем оригинальную строку, чтобы скопировать из нее даты и другие колонки
		Для Каждого СтрокаТЧ Из ВладелецФормы.Объект.СкидкиНаценки Цикл
			Если СтрокаТЧ.СкидкаНаценка = ИсходнаяСкидка Тогда
				НоваяСтрока = ВладелецФормы.Объект.СкидкиНаценки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ); // Копируем даты начала/окончания
				НоваяСтрока.СкидкаНаценка = НоваяСкидка; // Подставляем новую акцию
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	// Помечаем документ как измененный (появится звездочка) и закрываем обработку
	ВладелецФормы.Модифицированность = Истина;
	ПоказатьОповещениеПользователя("Успешно", , "Новые акции созданы и добавлены в таблицу");
	Закрыть();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СоздатьСкидкиНаСервере(МассивИсходных, Поиск, Замена, Программа)
	
	МассивНовых = Новый Массив;
	
	Для Каждого ТекСсылка Из МассивИсходных Цикл
		
		НоваяСкидка = ТекСсылка.Скопировать();
		
		// Меняем наименование
		Если Не ПустаяСтрока(Поиск) Тогда
			НоваяСкидка.Наименование = СтрЗаменить(НоваяСкидка.Наименование, Поиск, Замена);
		КонецЕсли;
		
		// Меняем программу лояльности
		Если ЗначениеЗаполнено(Программа) Тогда
			НоваяСкидка.ПрограммаЛояльности = Программа;
		КонецЕсли;
		
		НоваяСкидка.Записать();
		МассивНовых.Добавить(НоваяСкидка.Ссылка);
		
	КонецЦикла;
	
	Возврат МассивНовых;
	
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)    
	
	Если Параметры.Свойство("МаркетинговаяАкция") Тогда
		Объект.МаркетинговаяАкция = Параметры.МаркетинговаяАкция;
	КонецЕсли;	
	Объект.ПрограммаЛояльности = Справочники.ПрограммыЛояльности.НайтиПоКоду("000-0000001"); 
	Объект.ПолучательСкидки = Справочники.ГруппыПолучателейСкидки.НайтиПоНаименованию("Сотрудники"); 
КонецПроцедуры

