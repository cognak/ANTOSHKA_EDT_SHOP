#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущийКлюч = Параметры.ТекущийКлюч;
	Для Каждого Свойство Из Параметры.СвойстваLibrdKafka Цикл
		
		НоваяСтрока = Свойства.Добавить();
		НоваяСтрока.ИмяСвойства = Строка(Свойство.Ключ);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Свойство.Значение);
		
		НоваяСтрока.ДоступныеЗначенияПредставление = ?(НоваяСтрока.ДоступныеЗначения = Неопределено,
			СтрШаблон("%1 - %2", НоваяСтрока.ДоступныеЗначенияОт, НоваяСтрока.ДоступныеЗначенияДо),
			СтрСоединить(НоваяСтрока.ДоступныеЗначения, ","));
		
		Если НоваяСтрока.ИмяСвойства = ТекущийКлюч Тогда
			Элементы.Свойства.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
		
		Если НоваяСтрока.Важность = 1 Тогда
			НоваяСтрока.ВажностьПредставление = НСтр("ru = 'Низкая'");
			
		ИначеЕсли НоваяСтрока.Важность = 2 Тогда
			НоваяСтрока.ВажностьПредставление = НСтр("ru = 'Средняя'");
			
		ИначеЕсли НоваяСтрока.Важность = 3 Тогда
			НоваяСтрока.ВажностьПредставление = НСтр("ru = 'Высокая'");
			
		КонецЕсли;
		
	КонецЦикла;
	Свойства.Сортировать("ИмяСвойства");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВажностьПриИзменении(Элемент)
	
	Элементы.Свойства.ОтборСтрок = ?(Важность > 0, Новый ФиксированнаяСтруктура("Важность", Важность), Неопределено);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСвойства

&НаКлиенте
Процедура СвойстваВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(Элемент.ТекущиеДанные.ИмяСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура СвойстваВыборЗначения(Элемент, Значение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(Элемент.ТекущиеДанные.ИмяСвойства);
	
КонецПроцедуры

#КонецОбласти
