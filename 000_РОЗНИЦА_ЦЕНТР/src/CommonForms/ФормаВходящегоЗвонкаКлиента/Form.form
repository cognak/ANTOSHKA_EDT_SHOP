    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ТаблицаЗаказ.Ссылка КАК Ссылка,
	ТаблицаЗаказ.ВерсияДанных КАК ВерсияДанных,
	ТаблицаЗаказ.ПометкаУдаления КАК ПометкаУдаления,
	ТаблицаЗаказ.Номер КАК Номер,
	ТаблицаЗаказ.IDN КАК IDN,
	ТаблицаЗаказ.Дата КАК Дата,
	ТаблицаЗаказ.Проведен КАК Проведен,
	ТаблицаЗаказ.Склад КАК Склад,
	ТаблицаЗаказ.Магазин КАК Магазин,
	ТаблицаЗаказ.МагазинПолучатель КАК МагазинПолучатель,
	ТаблицаЗаказ.Комментарий КАК Комментарий,
	ТаблицаЗаказ.СуммаДокумента КАК СуммаДокумента,
	ТаблицаЗаказ.ДисконтнаяКарта КАК ДисконтнаяКарта,
	ТаблицаЗаказ.Ответственный КАК Ответственный,
	ТаблицаЗаказ.УчитыватьНДС КАК УчитыватьНДС,
	ТаблицаЗаказ.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	ТаблицаЗаказ.АдресДоставки КАК АдресДоставки,
	ТаблицаЗаказ.ВладелецДисконтнойКарты КАК ВладелецДисконтнойКарты,
	ТаблицаЗаказ.Контрагент КАК Контрагент,
	ЕСТЬNULL(ТаблицаСостояния.СотрудникАнтошки, ЛОЖЬ) КАК СотрудникАнтошки,
	ТаблицаЗаказ.Продавец КАК Продавец,
	ТаблицаЗаказ.ПродавецИдентификатор КАК ПродавецИдентификатор,
	ТаблицаЗаказ.Организация КАК Организация,
	ТаблицаЗаказ.СкидкиРассчитаны КАК СкидкиРассчитаны,
	ТаблицаЗаказ.МаксимальныйКодСтроки КАК МаксимальныйКодСтроки,
	ТаблицаЗаказ.КоррекцияНачисленийПоПродаже КАК КоррекцияНачисленийПоПродаже,
	ТаблицаСостояния.Статус КАК Статус,
	ТаблицаЗаказ.НомерЗаказаОсновной КАК НомерЗаказаОсновной,
	ТаблицаЗаказ.НомерЗаказаНаСайте КАК НомерЗаказаНаСайте,
	ТаблицаЗаказ.СтатусИМ КАК СтатусИМ,
	ТаблицаЗаказ.СтатусОплаты КАК СтатусОплаты,
	ТаблицаЗаказ.ТипДоставки КАК ТипДоставки,
	ТаблицаЗаказ.ТипОплаты КАК ТипОплаты,
	ТаблицаЗаказ.ДатаПродажиЖелаемая КАК ДатаПродажиЖелаемая,
	ТаблицаЗаказ.НаличиеНезарезервированныхСтрок КАК НаличиеНезарезервированныхСтрок,
	ТаблицаСостояния.СуммаБалловНачисление КАК СуммаБалловНачисление,
	ТаблицаСостояния.СуммаБалловСписание КАК СуммаБалловСписание,
	ТаблицаЗаказ.Отменено КАК Отменено,
	ТаблицаЗаказ.Автор КАК Автор,
	ТаблицаЗаказ.УзелСоздания КАК УзелСоздания,
	ТаблицаЗаказ.УчетнаяСистема КАК УчетнаяСистема,
	ТаблицаЗаказ.СуммаДоставки КАК СуммаДоставки,
	ТаблицаЗаказ.СуммаДоставкиОператор КАК СуммаДоставкиОператор,
	ТаблицаЗаказ.СуммаДоставкиОплачена КАК СуммаДоставкиОплачена,
	ТаблицаЗаказ.УчтеноNavision КАК УчтеноNavision,
	ТаблицаСостояния.Состояние КАК Состояние,
	ТаблицаЗаказ.ЧастичнаяПродажа КАК ЧастичнаяПродажа,
	ТаблицаЗаказ.НеПерезванивать КАК НеПерезванивать,
	ВЫБОР
		КОГДА ТаблицаЗаказ.УчетнаяСистема = ЗНАЧЕНИЕ(Перечисление.УчетныеСистемыКомпании.Розница)
				ИЛИ ТаблицаЗаказ.УчетнаяСистема = ЗНАЧЕНИЕ(Перечисление.УчетныеСистемыКомпании.ПустаяСсылка)
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ОбработкаВМадженто,
	ТаблицаЗаказ.Телефон КАК Телефон,
	ТаблицаСостояния.ЕстьВозврат КАК ЕстьВозврат,
	ТаблицаСостояния.ПочтаКлиента КАК ПочтаКлиента,
	ТаблицаСостояния.СообщениеЦентр КАК СообщениеЦентр,
	ТаблицаСостояния.СообщениеМагазин КАК СообщениеМагазин,
	ТаблицаСостояния.ВозвратныйДокумент КАК ВозвратныйДокумент,
	ТаблицаСостояния.ДокументОбмена КАК ДокументОбмена
ИЗ
	Документ.ЗаказПокупателя КАК ТаблицаЗаказ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеЗаказаПокупателя КАК ТаблицаСостояния
		ПО (ТаблицаСостояния.ЗаказПокупателя = ТаблицаЗаказ.Ссылка)
ГДЕ
	ТаблицаЗаказ.Контрагент = &amp;Контрагент
{ГДЕ
	ТаблицаЗаказ.Ссылка.*}</queryText>
      <mainTable>Document.ЗаказПокупателя</mainTable>
