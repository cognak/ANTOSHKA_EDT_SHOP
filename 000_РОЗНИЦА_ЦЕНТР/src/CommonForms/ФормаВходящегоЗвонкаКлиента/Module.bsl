&НаКлиенте
Процедура СоздатьЗаказ(Команда)
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда 
		Сообщить("Не выбран контрагент!");
		Возврат;
	КонецЕсли;	
	
	П = Новый Структура; 
	П.Вставить("Контрагент", Контрагент); 
	ОткрытьФорму("Документ.ЗаказПокупателя.ФормаОбъекта", П, ЭтотОбъект); 

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщениеКлиенту(Команда)
	
	Если Не ПустаяСтрока(Телефон) И Не Контрагент.Пустая() Тогда 

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("НомерТелефона", Телефон);
		ПараметрыФормы.Вставить("Контрагент", Контрагент);
		//ПараметрыФормы.Вставить("ЗаказКлиента", Объект.Ссылка);

		ОткрытьФорму("Документ.ЗаказПокупателя.Форма.ФормаОтправкиСообщения", ПараметрыФормы, ЭтаФорма); 
	КонецЕсли;
	
КонецПроцедуры

