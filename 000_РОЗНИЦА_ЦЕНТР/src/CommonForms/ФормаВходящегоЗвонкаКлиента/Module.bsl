&НаСервере
Процедура ЗаписатьОбновитьНаСервере()
	
	Отказ = Ложь;
	
	ПроверитьВозрастДетей(Отказ);
	
	//Если Отказ Тогда 
	//	Сообщить("Не удалось записать данные!");
	//	Возврат;
	//КонецЕсли;	
	
	ДанныеКонтрагента = Новый Структура;
	
	ДанныеКонтрагента.Вставить("Фамилия",	Фамилия);
	ДанныеКонтрагента.Вставить("Имя"	,	Имя);
	ДанныеКонтрагента.Вставить("Отчество",	Отчество);
	
	ДанныеКонтрагента.Вставить("Контрагент",	Контрагент);
	
	ДанныеКонтрагента.Вставить("НомерТелефона", Телефон); 
	
	ДанныеКонтрагента.Вставить("Электропочта", EMail);  
	
	ДанныеКонтрагента.Вставить("Пол", Пол);
	
	ДанныеКонтрагента.Вставить("РасширенныеДанные", Истина);
	
	ДанныеКонтрагента.Вставить("ДатаРождения", ДатаРождения); 
	
	ДанныеКонтрагента.Вставить("Электропочта", EMail);
	
	ДанныеКонтрагента.Вставить("Дети", Дети.Выгрузить());
	
	ДанныеКонтрагента.Вставить("ИнформационнаяКарта", "");  
	
	ДанныеКонтрагента.Вставить("Комментарий", Комментарий);  
	
	Если ВерификацияКлиентовСервер.ЗаписатьВерифицированныеДанныеКонтрагента(ДанныеКонтрагента).Выполнено Тогда
		
		Если СтрДлина(Телефон) = 10 Тогда 
			НомерТелефона = "38" + Телефон;         
		Иначе 
			НомерТелефона = СтрЗаменить(Телефон, "+", "");         
		КонецЕсли;	
		
		Запись = РегистрыСведений.ВходящиеЗвонкиАстерикс.СоздатьМенеджерЗаписи();
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.НомерТелефона = &НомерТелефона
		|	И КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	КонтрагентыКонтактнаяИнформация.Ссылка";
		Запрос.Параметры.Вставить("НомерТелефона", НомерТелефона);
		
		Результат = Запрос.Выполнить().Выбрать();
		
		Если Результат.Следующий() Тогда 
			Контрагент = Результат.Ссылка;
		Иначе 
			Контрагент = Справочники.Контрагенты.ПустаяСсылка();
		КонецЕсли;	   
		
	КонецЕсли;
	
	ПриОткрытииНаСервере();
	
КонецПроцедуры

