&НаКлиенте
Процедура СоздатьЗаказ(Команда)
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда 
		Сообщить("Не выбран контрагент!");
		Возврат;
	КонецЕсли;	
	
	П = Новый Структура; 
	П.Вставить("Контрагент", Контрагент); 
	ОткрытьФорму("Документ.ЗаказПокупателя.ФормаОбъекта", П, ЭтотОбъект); 

КонецПроцедуры

