&НаКлиенте
Процедура ДетиДатаРожденияПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Дети.ТекущиеДанные;
	
	ТекущаяСтрока.КоличествоЛетРебёнку = РассчитатьВозраст(ТекущаяСтрока.ДатаРождения);
	
	Если ТекущаяСтрока.КоличествоЛетРебёнку >= 16 Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Возраст не должен быть больше 16 лет.";
		Сообщение.КлючДанных = Контрагент;
		Сообщение.Поле   = "ЭтотОбъект.Дети["+Элементы.Дети.ТекущаяСтрока+"].ДатаРождения"; 
		Сообщение.ИдентификаторНазначения = ЭтаФорма.УникальныйИдентификатор;
		
		Сообщение.УстановитьДанные(ЭтотОбъект);
		
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

Функция РассчитатьВозраст(ДатаРождения)
	
	  Возврат Окр((ТекущаяДата() - ДатаРождения) / (86400 * 365),0);

КонецФункции	   

Процедура ПроверитьВозрастДетей(Отказ)
	
	Для Каждого Стр Из Дети Цикл 
		Стр.КоличествоЛетРебёнку = РассчитатьВозраст(Стр.ДатаРождения); 
		
		Если Стр.КоличествоЛетРебёнку >= 16 Тогда 
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Возраст ребенка: " + Стр.Имя + " превышает 16 лет!";
			Сообщение.КлючДанных = Контрагент;
			Сообщение.ИдентификаторНазначения = ЭтаФорма.УникальныйИдентификатор;
			
			Сообщение.УстановитьДанные(ЭтотОбъект);
			
			Сообщение.Сообщить();
			
			Отказ = Истина;
			
		КонецЕсли;	
		
	КонецЦикла;	
	
КонецПроцедуры	

